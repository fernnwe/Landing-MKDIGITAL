<script>
(() => {
  const slides = document.querySelectorAll("#mkfarma-carousel .mf-carousel-slide");
  const dots = document.querySelectorAll("#mkfarma-dots .mf-dot");
  const prev = document.getElementById("mkfarma-prev");
  const next = document.getElementById("mkfarma-next");
  let current = 0;
  let interval;

  const goTo = (i) => {
    slides.forEach((s) => s.classList.remove("active"));
    dots.forEach((d) => d.classList.remove("active"));
    current = (i + slides.length) % slides.length;
    slides[current].classList.add("active");
    dots[current].classList.add("active");
  };

  const restartInterval = () => {
    clearInterval(interval);
    interval = setInterval(() => goTo(current + 1), 5000);
  };

  dots.forEach((d) => {
    d.addEventListener("click", () => { goTo(parseInt(d.dataset.slide)); restartInterval(); });
  });
  if (prev) prev.addEventListener("click", () => { goTo(current - 1); restartInterval(); });
  if (next) next.addEventListener("click", () => { goTo(current + 1); restartInterval(); });

  restartInterval();
})();
</script>

<style>
/* ====== HERO ====== */
.mf-hero {
  position: relative;
  min-height: 100vh;
  display: flex;
  align-items: center;
