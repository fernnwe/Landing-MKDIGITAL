              </div>
              <div class="license-item">
                <div class="license-product">Maya 2026</div>
                <div class="license-key">575-32137777:657R1</div>
                <button class="btn-copy" onclick="copyKey('575-32137777:657R1',this)">Copiar clave</button>
              </div>
              <div class="license-item">
                <div class="license-product">AutoCAD LT 2026</div>
                <div class="license-key">575-37043108:128R1</div>
                <button class="btn-copy" onclick="copyKey('575-37043108:128R1',this)">Copiar clave</button>
