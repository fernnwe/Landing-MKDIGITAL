---
import BaseLayout from "../layouts/BaseLayout.astro";
import Navbar from "../components/Navbar.astro";
import Footer from "../components/Footer.astro";
const title = "Canjear licencias - MKDIGITAL Nicaragua";
const desc = "Canjea tu licencia McAfee AntiVirus o Avast Premium aquí. Promoción exclusiva por tiempo limitado en Nicaragua.";
---

<BaseLayout title={title} description={desc}>
  <Navbar />
  <div id="passwordOverlay" class="password-overlay">
    <div class="password-modal">
      <div class="password-lock">
        <svg viewBox="0 0 24 24" width="48" height="48" fill="none" stroke="#CF0A2C" stroke-width="1.5"><rect x="3" y="11" width="18" height="11" rx="2"/><path d="M7 11V7a5 5 0 0110 0v4"/></svg>
      </div>
      <h2>Acceso restringido</h2>
      <p>Ingresa la contraseña para acceder a esta página.</p>
      <input type="password" id="passwordInput" placeholder="Contraseña" onkeydown="if(event.key==='Enter')checkPass()" />
      <button onclick="checkPass()">Ingresar</button>
      <p id="passError" class="pass-error" style="display:none">Contraseña incorrecta</p>
    </div>
  </div>
  <main class="license-page" id="mainContent">
    <section class="page-hero">
      <div class="hero-container">
        <h1>Canjea tu licencia</h1>
        <p class="hero-subtitle">Selecciona el producto y canjea tu licencia original.</p>
      </div>
    </section>

    <!-- McAfee -->
    <section class="product-section" id="mcafee-section">
      <div class="product-inner">
        <div class="product-header">
          <div class="product-icon" style="background:rgba(207,10,44,0.1)">
            <svg viewBox="0 0 24 24" width="32" height="32" fill="none" stroke="#CF0A2C" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
              <path d="M12 2L3 7v6c0 5.25 3.83 10.15 9 11 5.17-.85 9-5.75 9-11V7l-9-5z"/>
              <path d="M9 12l2 2 4-4" stroke="#fff" stroke-width="2"/>
            </svg>
          </div>
          <h2>McAfee AntiVirus</h2>
          <p class="product-subtitle">Licencia original para Windows — 1 año de validez</p>
          <div class="hero-badges">
            <div class="badge">
              <svg viewBox="0 0 24 24" width="18" height="18" fill="none" stroke="currentColor" stroke-width="2"><circle cx="12" cy="12" r="10"/><path d="M12 6v6l4 2"/></svg>
              <span>1 año</span>
            </div>
            <div class="badge">
              <svg viewBox="0 0 24 24" width="18" height="18" fill="none" stroke="currentColor" stroke-width="2"><rect x="2" y="3" width="20" height="14" rx="2"/><path d="M8 21h8"/><path d="M12 17v4"/></svg>
              <span>1 PC</span>
            </div>
            <div class="badge">
              <svg viewBox="0 0 24 24" width="18" height="18" fill="none" stroke="currentColor" stroke-width="2"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/></svg>
              <span>Tiempo real</span>
            </div>
          </div>
          <button class="btn-reveal" id="revealMcAfee" onclick="revealMcAfee()">
            Canjear licencia
            <svg viewBox="0 0 24 24" width="18" height="18" fill="none" stroke="currentColor" stroke-width="2.5"><path d="M5 12h14"/><path d="M12 5l7 7-7 7"/></svg>
          </button>
        </div>

        <div id="mcafeeLicense" class="license-reveal" style="display:none">
          <div class="license-key-card">
            <div class="license-label">Códigos de activación McAfee</div>
            <div class="license-list">
              <div class="license-item">
                <div class="license-key">976ML-N66JZ-EG7PY-RTGD4-A2PA2</div>
                <button class="btn-copy" onclick="copyKey('976ML-N66JZ-EG7PY-RTGD4-A2PA2',this)">Copiar código</button>
              </div>
              <div class="license-item">
                <div class="license-key">29TZD-JZDP5-NRG66-3T2EA-A2FM2</div>
                <button class="btn-copy" onclick="copyKey('29TZD-JZDP5-NRG66-3T2EA-A2FM2',this)">Copiar código</button>
              </div>
              <div class="license-item">
                <div class="license-key">943YR-U9257-4A47M-46CY9-APJFP</div>
                <button class="btn-copy" onclick="copyKey('943YR-U9257-4A47M-46CY9-APJFP',this)">Copiar código</button>
              </div>
              <div class="license-item">
                <div class="license-key">CY35V-F79TY-5PRR5-54SPM-A2DA2</div>
                <button class="btn-copy" onclick="copyKey('CY35V-F79TY-5PRR5-54SPM-A2DA2',this)">Copiar código</button>
              </div>
              <div class="license-item">
                <div class="license-product" style="color:#CF0A2C">3 dispositivos</div>
                <div class="license-key">S447V-HPAD2-926H9-49FLD-APMP4</div>
                <button class="btn-copy" onclick="copyKey('S447V-HPAD2-926H9-49FLD-APMP4',this)">Copiar código</button>
              </div>
            </div>
          </div>

          <div class="activate-steps">
            <h3>Pasos para activar McAfee</h3>
            <div class="step-list">
              <div class="activate-step">
                <span class="step-num">1</span>
                <div>
                  <h4>Ingresa al sitio de activación</h4>
                  <p>Abre <a href="https://www.mcafee.com/es-es/consumer-support/activate-product-key.html" target="_blank" rel="noopener">mcafee.com/activate</a> en tu navegador.</p>
                </div>
              </div>
              <div class="activate-step">
                <span class="step-num">2</span>
                <div>
                  <h4>Ingresa tu código</h4>
                  <p>Copia cualquiera de los códigos de arriba en el campo correspondiente.</p>
                </div>
              </div>
              <div class="activate-step">
                <span class="step-num">3</span>
                <div>
                  <h4>Deja el país que aparezca</h4>
                  <p>No cambies el país predeterminado. Continúa al siguiente paso.</p>
                </div>
              </div>
              <div class="activate-step">
                <span class="step-num">4</span>
                <div>
                  <h4>Ingresa tu email y descarga</h4>
                  <p>Pon tu correo electrónico, crea tu cuenta y descarga el antivirus automáticamente.</p>
                </div>
              </div>
            </div>
          </div>
        </div>
      </div>
    </section>

    <!-- Avast -->
    <section class="product-section" id="avast-section">
      <div class="product-inner">
        <div class="product-header">
          <div class="product-icon" style="background:rgba(255,107,0,0.1)">
            <svg viewBox="0 0 24 24" width="32" height="32" fill="none" stroke="#FF6B00" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
              <path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/>
              <circle cx="12" cy="12" r="3" stroke="#FF6B00" fill="none"/>
            </svg>
          </div>
          <h2>Avast Premium</h2>
          <p class="product-subtitle">Licencia original — 1 año de validez</p>
          <div class="hero-badges">
            <div class="badge">
              <svg viewBox="0 0 24 24" width="18" height="18" fill="none" stroke="currentColor" stroke-width="2"><circle cx="12" cy="12" r="10"/><path d="M12 6v6l4 2"/></svg>
              <span>1 año</span>
            </div>
            <div class="badge">
              <svg viewBox="0 0 24 24" width="18" height="18" fill="none" stroke="currentColor" stroke-width="2"><rect x="2" y="3" width="20" height="14" rx="2"/><path d="M8 21h8"/><path d="M12 17v4"/></svg>
              <span>1 PC</span>
            </div>
            <div class="badge">
              <svg viewBox="0 0 24 24" width="18" height="18" fill="none" stroke="currentColor" stroke-width="2"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/></svg>
              <span>Anti-malware</span>
            </div>
          </div>
          <button class="btn-reveal" id="revealAvast" onclick="revealAvast()">
            Canjear licencia
            <svg viewBox="0 0 24 24" width="18" height="18" fill="none" stroke="currentColor" stroke-width="2.5"><path d="M5 12h14"/><path d="M12 5l7 7-7 7"/></svg>
          </button>
        </div>

        <div id="avastLicense" class="license-reveal" style="display:none">
          <div class="license-key-card">
            <div class="license-label">Código de activación Avast</div>
            <div class="license-list">
              <div class="license-item">
                <div class="license-key">U8TJST-VHHCQ2-4Z448J</div>
                <button class="btn-copy" onclick="copyKey('U8TJST-VHHCQ2-4Z448J',this)">Copiar código</button>
              </div>
              <div class="license-item">
                <div class="license-key">QTULFA-FCQLW2-54UCFW</div>
                <button class="btn-copy" onclick="copyKey('QTULFA-FCQLW2-54UCFW',this)">Copiar código</button>
              </div>
              <div class="license-item">
                <div class="license-key">ES8769-KXH4E2-45LDY6</div>
                <button class="btn-copy" onclick="copyKey('ES8769-KXH4E2-45LDY6',this)">Copiar código</button>
              </div>
            </div>
          </div>

          <div class="activate-steps">
            <h3>Pasos para activar Avast</h3>
            <div class="step-list">
              <div class="activate-step">
                <span class="step-num">1</span>
                <div>
                  <h4>Descarga Avast</h4>
                  <p>Descarga Avast Free desde <a href="https://www.avast.com/es-es/download-thank-you.php?product=ANTIVIRUS&locale=es-es" target="_blank" rel="noopener">avast.com</a> e instálalo en tu PC.</p>
                </div>
              </div>
              <div class="activate-step">
                <span class="step-num">2</span>
                <div>
                  <h4>Ve a Menú &gt; Mis licencias</h4>
                  <p>Abre Avast, haz clic en <strong>Menú</strong> (esquina superior derecha) y selecciona <strong>Mis licencias</strong>.</p>
                </div>
              </div>
              <div class="activate-step">
                <span class="step-num">3</span>
                <div>
                  <h4>Introducir código de activación</h4>
                  <p>Haz clic en <strong>Introducir código de activación</strong> e ingresa el código de arriba.</p>
                </div>
              </div>
              <div class="activate-step">
                <span class="step-num">4</span>
                <div>
                  <h4>Listo</h4>
                  <p>Tu Avast se actualizará automáticamente a la versión Premium. ¡Disfruta de protección completa!</p>
                </div>
              </div>
            </div>
          </div>
        </div>
      </div>
    </section>

    <!-- Autodesk 2026 -->
    <section class="product-section" id="autodesk-section">
      <div class="product-inner">
        <div class="product-header">
          <div class="product-icon" style="background:rgba(0,169,224,0.1)">
            <svg viewBox="0 0 24 24" width="32" height="32" fill="none" stroke="#00A9E0" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
              <rect x="3" y="3" width="18" height="18" rx="2"/>
