                <button class="btn-copy" onclick="copyKey('575-49423870:777R1',this)">Copiar clave</button>
              </div>
              <div class="license-item">
                <div class="license-product">Advance Steel 2026</div>
                <div class="license-key">575-19420582:959R1</div>
                <button class="btn-copy" onclick="copyKey('575-19420582:959R1',this)">Copiar clave</button>
              </div>
              <div class="license-item">
                <div class="license-product">AutoCAD Architecture 2026</div>
                <div class="license-key">575-53390972:185R1</div>
                <button class="btn-copy" onclick="copyKey('575-53390972:185R1',this)">Copiar clave</button>
              </div>
              <div class="license-item">
                <div class="license-product">Civil 3D 2026</div>
                <div class="license-key">575-24703322:237R1</div>
                <button class="btn-copy" onclick="copyKey('575-24703322:237R1',this)">Copiar clave</button>
              </div>
              <div class="license-item">
                <div class="license-product">3ds Max 2026</div>
                <div class="license-key">575-47128435:057R1</div>
                <button class="btn-copy" onclick="copyKey('575-47128435:057R1',this)">Copiar clave</button>
              </div>
            </div>
