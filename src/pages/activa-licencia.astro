---
import BaseLayout from "../layouts/BaseLayout.astro";
import Navbar from "../components/Navbar.astro";
import Footer from "../components/Footer.astro";
const title = "Canjear licencia McAfee - MKDIGITAL Nicaragua";
const desc = "Canjea tu licencia McAfee AntiVirus aquí. Promoción exclusiva por tiempo limitado en Nicaragua.";
---

<BaseLayout title={title} description={desc}>
  <Navbar />
  <div id="passwordOverlay" class="password-overlay">
    <div class="password-modal">
      <div class="password-lock">
        <svg viewBox="0 0 24 24" width="48" height="48" fill="none" stroke="#CF0A2C" stroke-width="1.5"><rect x="3" y="11" width="18" height="11" rx="2"/><path d="M7 11V7a5 5 0 0110 0v4"/></svg>
      </div>
      <h2>Acceso restringido</h2>
      <p>Ingresa la contraseña para acceder a esta página.</p>
      <input type="password" id="passwordInput" placeholder="Contraseña" onkeydown="if(event.key==='Enter')checkPass()" />
      <button onclick="checkPass()">Ingresar</button>
      <p id="passError" class="pass-error" style="display:none">Contraseña incorrecta</p>
    </div>
  </div>
  <main class="mcafee-page" id="mainContent">
    <section class="mcafee-hero">
      <div class="hero-container">
        <div class="brand-shield">
          <svg viewBox="0 0 24 24" width="56" height="56" fill="none" stroke="#CF0A2C" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
            <path d="M12 2L3 7v6c0 5.25 3.83 10.15 9 11 5.17-.85 9-5.75 9-11V7l-9-5z"/>
            <path d="M9 12l2 2 4-4" stroke="#fff" stroke-width="2"/>
          </svg>
        </div>
        <h1>McAfee AntiVirus</h1>
        <p class="hero-subtitle">Canjea tu licencia original para Windows — 1 año de validez</p>
        <div class="hero-price">Monto total: <strong>C$820.00</strong></div>
        <div class="hero-badges">
          <div class="badge">
            <svg viewBox="0 0 24 24" width="20" height="20" fill="none" stroke="currentColor" stroke-width="2"><circle cx="12" cy="12" r="10"/><path d="M12 6v6l4 2"/></svg>
            <span>1 año de protección</span>
          </div>
          <div class="badge">
            <svg viewBox="0 0 24 24" width="20" height="20" fill="none" stroke="currentColor" stroke-width="2"><rect x="2" y="3" width="20" height="14" rx="2"/><path d="M8 21h8"/><path d="M12 17v4"/></svg>
            <span>1 PC con Windows</span>
          </div>
          <div class="badge">
            <svg viewBox="0 0 24 24" width="20" height="20" fill="none" stroke="currentColor" stroke-width="2"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/></svg>
            <span>Protección en tiempo real</span>
          </div>
        </div>
        <div class="hero-cta">
          <button id="revealBtn" class="btn-primary btn-lg" onclick="revealLicense()">
            Canjear licencia
            <svg viewBox="0 0 24 24" width="20" height="20" fill="none" stroke="currentColor" stroke-width="2.5"><path d="M5 12h14"/><path d="M12 5l7 7-7 7"/></svg>
          </button>
        </div>
      </div>
    </section>

    <section id="licenseSection" class="license-section" style="display:none">
      <div class="license-container">
        <div class="success-banner">
          <svg viewBox="0 0 24 24" width="40" height="40" fill="none" stroke="#00c853" stroke-width="1.5"><circle cx="12" cy="12" r="10"/><path d="M8 12l2 2 4-4"/></svg>
          <h2>Licencia lista para canjear</h2>
        </div>
        <div class="license-key-card">
          <div class="license-label">Código de activación</div>
          <div class="license-key license-coming">PROXIMAMENTE</div>
        </div>

        <div class="support-card">
          <p>Tu código de activación está listo para ser canjeado.</p>
          <a href="https://wa.me/50581088124?text=Hola%2C+quiero+informaci%C3%B3n+sobre+la+licencia+McAfee" target="_blank" rel="noopener" class="btn-wa">
            <svg viewBox="0 0 24 24" width="20" height="20" fill="currentColor"><path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/></svg>
            Consultar por WhatsApp
          </a>
        </div>
      </div>
    </section>

    <section class="mcafee-details">
      <div class="details-container">
        <h2>Protección completa para tu PC con Windows</h2>
        <div class="details-grid">
          <div class="detail-card">
            <div class="detail-icon">
              <svg viewBox="0 0 24 24" width="32" height="32" fill="none" stroke="#CF0A2C" stroke-width="1.5"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/></svg>
            </div>
            <h3>Anti-malware avanzado</h3>
            <p>Detección y eliminación de virus, spyware, ransomware y otras amenazas en tiempo real.</p>
          </div>
          <div class="detail-card">
            <div class="detail-icon">
              <svg viewBox="0 0 24 24" width="32" height="32" fill="none" stroke="#CF0A2C" stroke-width="1.5"><circle cx="12" cy="12" r="3"/><path d="M19.4 15a1.65 1.65 0 0 0 .33 1.82l.06.06a2 2 0 0 1 0 2.83 2 2 0 0 1-2.83 0l-.06-.06a1.65 1.65 0 0 0-1.82-.33 1.65 1.65 0 0 0-1 1.51V21a2 2 0 0 1-2 2 2 2 0 0 1-2-2v-.09A1.65 1.65 0 0 0 9 19.4a1.65 1.65 0 0 0-1.82.33l-.06.06a2 2 0 0 1-2.83 0 2 2 0 0 1 0-2.83l.06-.06A1.65 1.65 0 0 0 4.68 15a1.65 1.65 0 0 0-1.51-1H3a2 2 0 0 1-2-2 2 2 0 0 1 2-2h.09A1.65 1.65 0 0 0 4.6 9a1.65 1.65 0 0 0-.33-1.82l-.06-.06a2 2 0 0 1 0-2.83 2 2 0 0 1 2.83 0l.06.06A1.65 1.65 0 0 0 9 4.68a1.65 1.65 0 0 0 1-1.51V3a2 2 0 0 1 2-2 2 2 0 0 1 2 2v.09a1.65 1.65 0 0 0 1 1.51 1.65 1.65 0 0 0 1.82-.33l.06-.06a2 2 0 0 1 2.83 0 2 2 0 0 1 0 2.83l-.06.06a1.65 1.65 0 0 0-.33 1.82V9a1.65 1.65 0 0 0 1.51 1H21a2 2 0 0 1 2 2 2 2 0 0 1-2 2h-.09a1.65 1.65 0 0 0-1.51 1z"/></svg>
            </div>
            <h3>Navegación segura</h3>
            <p>Protege tus datos mientras navegas, compras en línea y realizas transacciones bancarias.</p>
          </div>
          <div class="detail-card">
            <div class="detail-icon">
              <svg viewBox="0 0 24 24" width="32" height="32" fill="none" stroke="#CF0A2C" stroke-width="1.5"><rect x="3" y="11" width="18" height="11" rx="2"/><path d="M7 11V7a5 5 0 0 1 10 0v4"/></svg>
            </div>
            <h3>Firewall inteligente</h3>
            <p>Monitorea el tráfico de red y bloquea accesos no autorizados a tu equipo.</p>
          </div>
          <div class="detail-card">
            <div class="detail-icon">
              <svg viewBox="0 0 24 24" width="32" height="32" fill="none" stroke="#CF0A2C" stroke-width="1.5"><path d="M12 2L2 7l10 5 10-5-10-5z"/><path d="M2 17l10 5 10-5"/><path d="M2 12l10 5 10-5"/></svg>
            </div>
            <h3>Actualizaciones automáticas</h3>
            <p>McAfee se actualiza solo para estar siempre protegido contra las últimas amenazas.</p>
          </div>
        </div>
      </div>
    </section>
  </main>
  <Footer />
</BaseLayout>

<script is:inline>
  function checkPass() {
    if (document.getElementById('passwordInput').value === 'mkdigital2026$') {
      sessionStorage.setItem('activa-licencia-auth', '1');
      document.getElementById('passwordOverlay').style.display = 'none';
    } else {
      document.getElementById('passError').style.display = 'block';
    }
  }
  (function() {
    if (sessionStorage.getItem('activa-licencia-auth') === '1') {
      document.getElementById('passwordOverlay').style.display = 'none';
    }
  })();
  function revealLicense() {
    var btn = document.getElementById('revealBtn');
    btn.disabled = true;
    btn.innerHTML = 'Listo <svg viewBox="0 0 24 24" width="20" height="20" fill="none" stroke="currentColor" stroke-width="2.5"><path d="M20 6L9 17l-5-5"/></svg>';
    var section = document.getElementById('licenseSection');
    section.style.display = 'block';
    section.scrollIntoView({ behavior: 'smooth', block: 'start' });
  }
</script>

<style is:global>
.mcafee-page {
  padding-top: 80px;
  font-family: system-ui, -apple-system, sans-serif;
  background: #0a0a12;
}

/* ── Password gate ── */
.password-overlay {
  position: fixed;
  top: 0; left: 0; right: 0; bottom: 0;
  background: #0a0a12;
  z-index: 9999;
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 20px;
}
.password-modal {
  background: #11111e;
  border: 1px solid #1e1e32;
  border-radius: 16px;
  padding: 40px 36px;
  text-align: center;
  max-width: 380px;
  width: 100%;
}
.password-lock { margin-bottom: 16px; }
.password-modal h2 {
  font-size: 1.3rem;
  font-weight: 700;
  color: #fff;
  margin: 0 0 6px;
}
.password-modal p {
  font-size: 0.9rem;
  color: #888;
  margin: 0 0 24px;
}
.password-modal input {
  width: 100%;
  box-sizing: border-box;
  padding: 12px 14px;
  border: 1px solid #222;
  border-radius: 10px;
  background: #0a0a14;
  color: #fff;
  font-size: 1rem;
  margin-bottom: 16px;
  text-align: center;
}
.password-modal input:focus {
  outline: none;
  border-color: #CF0A2C;
}
.password-modal button {
  width: 100%;
  padding: 14px;
  background: #CF0A2C;
  color: #fff;
  border: none;
  border-radius: 10px;
  font-size: 1rem;
  font-weight: 700;
  cursor: pointer;
  transition: background 0.2s;
}
.password-modal button:hover { background: #b00926; }
.pass-error {
  color: #CF0A2C;
  font-size: 0.85rem;
  margin: 12px 0 0 !important;
}

/* ── Hero ── */
.mcafee-hero {
  background: linear-gradient(135deg, #0d0d1a 0%, #1a0a0e 40%, #0d0d1a 100%);
  border-bottom: 1px solid #1a1a2e;
  padding: 64px 20px 56px;
}
.hero-container {
  max-width: 640px;
  margin: 0 auto;
  text-align: center;
}
.brand-shield {
  margin-bottom: 16px;
  display: inline-flex;
  background: rgba(207,10,44,0.08);
  padding: 14px;
  border-radius: 20px;
}
.hero-container h1 {
  font-size: 2.6rem;
  font-weight: 700;
  color: #fff;
  letter-spacing: -0.5px;
  margin: 0 0 8px;
}
.hero-subtitle {
  font-size: 1.15rem;
  color: #888;
  margin: 0 0 12px;
}
.hero-price {
  font-size: 1.6rem;
  font-weight: 400;
  color: #aaa;
  margin-bottom: 28px;
}
.hero-price strong {
  color: #00c853;
  font-size: 2rem;
}
.hero-badges {
  display: flex;
  justify-content: center;
  gap: 24px;
  flex-wrap: wrap;
  margin-bottom: 36px;
}
.badge {
  display: flex;
  align-items: center;
  gap: 8px;
  color: #bbb;
  font-size: 0.9rem;
}
.badge svg { color: #CF0A2C; flex-shrink: 0; }

/* ── CTA ── */
.hero-cta { margin-bottom: 0; }
.btn-lg {
  display: inline-flex;
  align-items: center;
  gap: 10px;
  padding: 16px 40px;
  background: #CF0A2C;
  color: #fff;
  border: none;
  border-radius: 12px;
  font-size: 1.1rem;
  font-weight: 700;
  cursor: pointer;
  transition: background 0.2s, transform 0.15s;
}
.btn-lg:hover {
  background: #b00926;
  transform: translateY(-2px);
}
.btn-lg:disabled {
  background: #1a3a1a;
  cursor: default;
  transform: none;
}

/* ── License section ── */
.license-section {
  padding: 48px 20px;
}
.license-container {
  max-width: 640px;
  margin: 0 auto;
}
.success-banner {
  display: flex;
  align-items: center;
  gap: 14px;
  justify-content: center;
  margin-bottom: 32px;
}
.success-banner h2 {
  font-size: 1.4rem;
  font-weight: 700;
  color: #fff;
  margin: 0;
}

/* Key card */
.license-key-card {
  background: #11111e;
  border: 1px solid rgba(0,200,83,0.2);
  border-radius: 16px;
  padding: 32px;
  text-align: center;
  margin-bottom: 32px;
}
.license-label {
  font-size: 0.8rem;
  text-transform: uppercase;
  letter-spacing: 1px;
  color: #666;
  margin-bottom: 12px;
}
.license-key {
  font-family: 'SF Mono', 'Fira Code', 'Courier New', monospace;
  font-size: 1.15rem;
  font-weight: 600;
  color: #00c853;
  background: #0a0a14;
  border: 1px dashed rgba(0,200,83,0.3);
  border-radius: 10px;
  padding: 16px 20px;
  word-break: break-all;
  letter-spacing: 1.5px;
  user-select: all;
  margin-bottom: 20px;
}
.license-coming {
  color: #f59e0b;
  border-color: rgba(245,158,11,0.3);
  font-family: system-ui, -apple-system, sans-serif;
  letter-spacing: 4px;
  font-size: 1.4rem;
  text-transform: uppercase;
}
.btn-copy {
  background: transparent;
  color: #00c853;
  border: 1px solid #00c853;
  padding: 10px 28px;
  border-radius: 8px;
  font-weight: 600;
  font-size: 0.9rem;
  cursor: pointer;
  transition: background 0.2s;
}
.btn-copy:hover { background: rgba(0,200,83,0.1); }

/* Activate steps */
.activate-steps {
  background: #11111e;
  border: 1px solid #1e1e32;
  border-radius: 16px;
  padding: 36px;
  margin-bottom: 32px;
}
.activate-steps h3 {
  font-size: 1.1rem;
  font-weight: 700;
  color: #fff;
  margin: 0 0 24px;
  text-align: center;
}
.step-list {
  display: flex;
  flex-direction: column;
  gap: 20px;
}
.activate-step {
  display: flex;
  gap: 16px;
  align-items: flex-start;
}
.step-num {
  flex-shrink: 0;
  width: 32px;
  height: 32px;
  border-radius: 8px;
  background: rgba(207,10,44,0.1);
  color: #CF0A2C;
  display: flex;
  align-items: center;
  justify-content: center;
  font-weight: 700;
  font-size: 0.85rem;
}
.activate-step h4 {
  font-size: 0.95rem;
  font-weight: 700;
  color: #fff;
  margin: 0 0 4px;
}
.activate-step p {
  font-size: 0.85rem;
  color: #888;
  margin: 0;
  line-height: 1.5;
}
.activate-step a {
  color: #CF0A2C;
  text-decoration: underline;
}
.activate-notice {
  display: flex;
  align-items: flex-start;
  gap: 8px;
  margin-top: 24px;
  padding: 12px 16px;
  background: rgba(245,158,11,0.06);
  border: 1px solid rgba(245,158,11,0.15);
  border-radius: 10px;
}
.activate-notice span {
  font-size: 0.82rem;
  color: #a88;
  line-height: 1.4;
}

/* Support */
.support-card {
  text-align: center;
  background: #11111e;
  border: 1px solid #1e1e32;
  border-radius: 16px;
  padding: 32px;
}
.support-card p {
  color: #888;
  font-size: 0.95rem;
  margin: 0 0 20px;
}
.btn-wa {
  display: inline-flex;
  align-items: center;
  gap: 10px;
  background: #25D366;
  color: #fff;
  padding: 14px 32px;
  border-radius: 10px;
  font-weight: 700;
  font-size: 1rem;
  text-decoration: none;
  transition: background 0.2s, transform 0.15s;
}
.btn-wa:hover {
  background: #1ebe5b;
  transform: translateY(-1px);
}

/* ── Details ── */
.mcafee-details {
  padding: 64px 20px;
  border-top: 1px solid #14141e;
}
.details-container {
  max-width: 860px;
  margin: 0 auto;
}
.details-container h2 {
  font-size: 1.6rem;
  font-weight: 700;
  color: #fff;
  text-align: center;
  margin: 0 0 44px;
}
.details-grid {
  display: grid;
  grid-template-columns: repeat(2, 1fr);
  gap: 20px;
}
.detail-card {
  background: #11111e;
  border: 1px solid #1a1a2a;
  border-radius: 14px;
  padding: 28px 24px;
  transition: border-color 0.2s, transform 0.2s;
}
.detail-card:hover {
  border-color: #CF0A2C;
  transform: translateY(-2px);
}
.detail-icon { margin-bottom: 16px; }
.detail-card h3 {
  font-size: 1.05rem;
  font-weight: 700;
  color: #fff;
  margin: 0 0 10px;
}
.detail-card p {
  font-size: 0.88rem;
  color: #888;
  line-height: 1.6;
  margin: 0;
}

/* ── Responsive ── */
@media (max-width: 640px) {
  .hero-container h1 { font-size: 1.8rem; }
  .hero-price { font-size: 1.3rem; }
  .hero-price strong { font-size: 1.6rem; }
  .license-key { font-size: 1rem; padding: 14px; }
  .activate-steps { padding: 24px; }
  .details-grid { grid-template-columns: 1fr; }
  .btn-lg { width: 100%; padding: 16px 20px; }
}
</style>
