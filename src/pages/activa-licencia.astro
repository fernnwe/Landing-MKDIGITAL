<script is:inline>
  function checkPass() {
    if (document.getElementById('passwordInput').value === 'mkdigital2026$') {
      sessionStorage.setItem('activa-licencia-auth', '1');
      document.getElementById('passwordOverlay').style.display = 'none';
    } else {
      document.getElementById('passError').style.display = 'block';
    }
  }
  (function() {
    if (sessionStorage.getItem('activa-licencia-auth') === '1') {
      document.getElementById('passwordOverlay').style.display = 'none';
    }
  })();
  function revealMcAfee() {
    var btn = document.getElementById('revealMcAfee');
    var section = document.getElementById('mcafeeLicense');
    if (section.style.display === 'block') { return; }
    section.style.display = 'block';
    btn.disabled = true;
    btn.innerHTML = 'Listo <svg viewBox="0 0 24 24" width="18" height="18" fill="none" stroke="currentColor" stroke-width="2.5"><path d="M20 6L9 17l-5-5"/></svg>';
    section.scrollIntoView({ behavior: 'smooth', block: 'start' });
  }
  function revealAvast() {
    var btn = document.getElementById('revealAvast');
    var section = document.getElementById('avastLicense');
    if (section.style.display === 'block') { return; }
    section.style.display = 'block';
    btn.disabled = true;
    btn.innerHTML = 'Listo <svg viewBox="0 0 24 24" width="18" height="18" fill="none" stroke="currentColor" stroke-width="2.5"><path d="M20 6L9 17l-5-5"/></svg>';
    section.scrollIntoView({ behavior: 'smooth', block: 'start' });
  }
  function revealAutodesk() {
    var btn = document.getElementById('revealAutodesk');
    var section = document.getElementById('autodeskLicense');
    if (section.style.display === 'block') { return; }
    section.style.display = 'block';
    btn.disabled = true;
    btn.innerHTML = 'Listo <svg viewBox="0 0 24 24" width="18" height="18" fill="none" stroke="currentColor" stroke-width="2.5"><path d="M20 6L9 17l-5-5"/></svg>';
    section.scrollIntoView({ behavior: 'smooth', block: 'start' });
  }
  function copyKey(code, btn) {
    navigator.clipboard.writeText(code);
    btn.textContent = 'Copiado';
    setTimeout(function() { btn.textContent = 'Copiar código'; }, 2000);
  }
</script>

<style is:global>
.license-page {
  padding-top: 80px;
  font-family: system-ui, -apple-system, sans-serif;
  background: #0a0a12;
}

/* ── Password gate ── */
.password-overlay {
  position: fixed;
  top: 0; left: 0; right: 0; bottom: 0;
  background: #0a0a12;
  z-index: 9999;
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 20px;
}
.password-modal {
  background: #11111e;
  border: 1px solid #1e1e32;
  border-radius: 16px;
  padding: 40px 36px;
  text-align: center;
  max-width: 380px;
  width: 100%;
}
.password-lock { margin-bottom: 16px; }
.password-modal h2 {
  font-size: 1.3rem;
  font-weight: 700;
  color: #fff;
  margin: 0 0 6px;
}
.password-modal p {
  font-size: 0.9rem;
  color: #888;
  margin: 0 0 24px;
}
.password-modal input {
  width: 100%;
  box-sizing: border-box;
  padding: 12px 14px;
  border: 1px solid #222;
  border-radius: 10px;
  background: #0a0a14;
  color: #fff;
  font-size: 1rem;
  margin-bottom: 16px;
  text-align: center;
}
.password-modal input:focus {
  outline: none;
  border-color: #CF0A2C;
}
.password-modal button {
  width: 100%;
  padding: 14px;
  background: #CF0A2C;
  color: #fff;
  border: none;
  border-radius: 10px;
  font-size: 1rem;
  font-weight: 700;
  cursor: pointer;
  transition: background 0.2s;
}
.password-modal button:hover { background: #b00926; }
.pass-error {
  color: #CF0A2C;
  font-size: 0.85rem;
  margin: 12px 0 0 !important;
}

