---
import BaseLayout from "../layouts/BaseLayout.astro";
import Navbar from "../components/Navbar.astro";
import CatalogoSection from "../components/CatalogoSection.astro";
import Footer from "../components/Footer.astro";

const catalogoImgs = [
  "/catalogo/1.png",
  "/catalogo/2.jpg",
  "/catalogo/3.jpg",
  "/catalogo/4.jpg",
  "/catalogo/5.jpg",
  "/catalogo/6.png",
];
---

<BaseLayout title="Catálogo de productos - MKDIGITAL Nicaragua" description="Licencias originales de Office, Windows, Antivirus, Adobe y más. Precios en Nicaragua con entrega inmediata." ogImage="https://mkdigitalnic.com/soporte.jpg">
  <Navbar />

  <section class="catalogo-carrusel">
    <div class="carrusel-track" id="carruselTrack">
      {catalogoImgs.map((src, i) => (
        <div class="carrusel-slide">
          <img src={src} alt={`Catálogo ${i + 1}`} loading="lazy" />
        </div>
      ))}
    </div>
    <div class="carrusel-dots" id="carruselDots">
      {catalogoImgs.map((_, i) => (
        <button class="carrusel-dot" data-index={i} aria-label={`Ir a imagen ${i + 1}`}></button>
      ))}
    </div>
  </section>

  <CatalogoSection />

  <Footer />
</BaseLayout>

<script>
  const track = document.getElementById('carruselTrack');
  const dots = document.querySelectorAll('.carrusel-dot');
  const slides = track.querySelectorAll('.carrusel-slide');
  let current = 0;
  const total = slides.length;
  let interval;

  function goTo(index) {
    current = (index + total) % total;
    track.style.transform = `translateX(-${current * 100}%)`;
    dots.forEach((d, i) => d.classList.toggle('active', i === current));
  }

  dots.forEach((dot) => {
    dot.addEventListener('click', () => {
      goTo(parseInt(dot.dataset.index));
      clearInterval(interval);
      interval = setInterval(() => goTo(current + 1), 4000);
    });
  });

  interval = setInterval(() => goTo(current + 1), 4000);
</script>

<style>
  .catalogo-carrusel {
    padding-top: 96px;
    max-width: 560px;
    margin: 0 auto;
    overflow: hidden;
    border-radius: 14px;
  }
  .carrusel-track {
    display: flex;
    transition: transform 0.5s ease;
  }
  .carrusel-slide {
    flex: 0 0 100%;
    box-sizing: border-box;
  }
  .carrusel-slide img {
    width: 100%;
    height: auto;
    display: block;
    border-radius: 14px;
  }
  .carrusel-dots {
    display: flex;
    justify-content: center;
    gap: 8px;
    margin-top: 16px;
  }
  .carrusel-dot {
    width: 8px;
    height: 8px;
    border-radius: 50%;
    border: 1.5px solid var(--on-surface-variant);
    background: transparent;
    cursor: pointer;
    transition: all 0.3s;
    padding: 0;
  }
  .carrusel-dot.active {
    background: var(--primary);
    border-color: var(--primary);
    width: 24px;
    border-radius: 4px;
  }
</style>
