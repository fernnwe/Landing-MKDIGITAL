---
import BaseLayout from "../layouts/BaseLayout.astro";
import Navbar from "../components/Navbar.astro";
import Footer from "../components/Footer.astro";
---

<BaseLayout title="Catálogo - MKDIGITAL Nicaragua" description="Catálogo en mantenimiento. Consulta nuestros precios por WhatsApp.">
  <Navbar />
  <main class="maintenance-page">
    <div class="mt-bg">
      <div class="mt-orb mt-orb-1"></div>
      <div class="mt-orb mt-orb-2"></div>
      <div class="mt-orb mt-orb-3"></div>
      <div class="mt-grid"></div>
    </div>
    <section class="mt-section">
      <div class="mt-card glow-card">
        <div class="mt-icon-wrap">
          <svg viewBox="0 0 24 24" width="32" height="32" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
            <rect x="2" y="2" width="20" height="8" rx="2" ry="2"/>
            <rect x="2" y="14" width="20" height="8" rx="2" ry="2"/>
            <path d="M6 6h.01M6 18h.01"/>
          </svg>
        </div>
        <span class="mt-badge">ACTUALIZANDO</span>
        <h1>Catálogo en mantenimiento</h1>
        <p>Estamos renovando nuestro catálogo para ofrecerte una mejor experiencia. Mientras tanto, puedes consultar nuestros precios directamente con nuestro equipo.</p>
        <div class="mt-contact">
          <a href="https://wa.me/50581088124" target="_blank" rel="noopener" class="mt-wa">
            <svg viewBox="0 0 24 24" width="20" height="20" fill="currentColor"><path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/></svg>
            <span>+505 8108 8124</span>
          </a>
          <a href="mailto:soporte.mkdigital1604@gmail.com" class="mt-email">
            <svg viewBox="0 0 24 24" width="16" height="16" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M4 4h16c1.1 0 2 .9 2 2v12c0 1.1-.9 2-2 2H4c-1.1 0-2-.9-2-2V6c0-1.1.9-2 2-2z"/><polyline points="22,6 12,13 2,6"/></svg>
            <span>soporte.mkdigital1604@gmail.com</span>
          </a>
        </div>
      </div>
    </section>
  </main>
  <Footer />
</BaseLayout>

<style is:global>
.maintenance-page {
  position: relative;
  min-height: 100vh;
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 120px 20px 80px;
  background: var(--background);
  overflow: hidden;
}

/* ── Orbs ── */
.mt-bg {
  position: absolute;
  inset: 0;
  pointer-events: none;
}
.mt-orb {
  position: absolute;
  border-radius: 50%;
  filter: blur(80px);
  opacity: 0.15;
}
.mt-orb-1 {
  width: 500px; height: 500px;
  background: var(--primary);
  top: -200px; right: -200px;
  animation: mt-float 8s ease-in-out infinite;
}
.mt-orb-2 {
  width: 400px; height: 400px;
  background: var(--teal);
  bottom: -150px; left: -150px;
  animation: mt-float 10s ease-in-out infinite reverse;
}
.mt-orb-3 {
  width: 300px; height: 300px;
  background: var(--emerald);
  top: 50%; left: 50%;
  transform: translate(-50%, -50%);
  animation: mt-pulse 6s ease-in-out infinite;
}
@keyframes mt-float {
  0%, 100% { transform: translateY(0) scale(1); }
  50% { transform: translateY(-40px) scale(1.05); }
}
@keyframes mt-pulse {
  0%, 100% { opacity: 0.08; transform: translate(-50%, -50%) scale(1); }
  50% { opacity: 0.18; transform: translate(-50%, -50%) scale(1.15); }
}
.mt-grid {
  position: absolute;
  inset: 0;
  background-image:
    linear-gradient(rgba(255,255,255,0.02) 1px, transparent 1px),
    linear-gradient(90deg, rgba(255,255,255,0.02) 1px, transparent 1px);
  background-size: 60px 60px;
}

/* ── Card ── */
.mt-section {
  position: relative;
  z-index: 1;
  text-align: center;
  max-width: 520px;
  width: 100%;
}
.mt-card {
  background: var(--surface-container);
  border: 1px solid var(--outline-variant);
  border-radius: 24px;
  padding: 56px 40px;
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 16px;
}
.mt-icon-wrap {
  width: 72px;
  height: 72px;
  display: flex;
  align-items: center;
  justify-content: center;
  border-radius: 20px;
  background: rgba(245,158,11,0.08);
  color: var(--primary);
  margin-bottom: 4px;
}
.mt-badge {
  font-size: 11px;
  font-weight: 700;
  letter-spacing: 3px;
  color: var(--primary);
  padding: 6px 16px;
  border-radius: 100px;
  background: rgba(245,158,11,0.08);
  border: 1px solid rgba(245,158,11,0.15);
  text-transform: uppercase;
}
.mt-card h1 {
  font-size: 1.8rem;
  font-weight: 800;
  color: var(--on-surface);
  margin: 0;
  letter-spacing: -0.5px;
}
.mt-card > p {
  font-size: 0.95rem;
  color: var(--on-surface-variant);
  margin: 0;
  line-height: 1.7;
  max-width: 400px;
}

/* ── Contact ── */
.mt-contact {
  display: flex;
  flex-direction: column;
  gap: 12px;
  width: 100%;
  margin-top: 12px;
}
.mt-wa, .mt-email {
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 12px;
  padding: 16px 24px;
  border-radius: 14px;
  font-size: 1rem;
  font-weight: 700;
  text-decoration: none;
  transition: transform 0.2s, box-shadow 0.2s;
}
.mt-wa {
  background: #25D366;
  color: #fff;
}
.mt-wa:hover {
  transform: translateY(-2px);
  box-shadow: 0 8px 30px rgba(37, 211, 102, 0.3);
}
.mt-email {
  background: transparent;
  color: var(--on-surface-variant);
  border: 1px solid var(--outline);
  font-weight: 500;
  font-size: 0.9rem;
}
.mt-email:hover {
  border-color: var(--primary);
  color: var(--primary);
  transform: translateY(-1px);
}

@media (max-width: 600px) {
  .mt-card { padding: 40px 24px; }
  .mt-card h1 { font-size: 1.4rem; }
}
</style>
