    </section>
  </main>
  <Footer />
</BaseLayout>

<script is:inline>
(function() {
  var canvas = document.getElementById('mnt-canvas');
  if (!canvas) return;
  var ctx = canvas.getContext('2d');
  var w, h, particles = [], MAX = 80;

  function resize() {
    w = canvas.width = window.innerWidth;
    h = canvas.height = window.innerHeight;
  }
  resize();
  window.addEventListener('resize', resize);

  for (var i = 0; i < MAX; i++) {
    particles.push({
      x: Math.random() * w,
      y: Math.random() * h,
      vx: (Math.random() - 0.5) * 0.6,
      vy: -Math.random() * 0.8 - 0.2,
      r: Math.random() * 1.8 + 0.5,
      a: Math.random() * 0.5 + 0.2
    });
  }

  function draw() {
    ctx.clearRect(0, 0, w, h);
    for (var i = 0; i < particles.length; i++) {
      var p = particles[i];
      p.x += p.vx;
      p.y += p.vy;
      if (p.y < -5) { p.y = h + 5; p.x = Math.random() * w; }
      if (p.x < -5 || p.x > w + 5) { p.x = Math.random() * w; }
      ctx.beginPath();
      ctx.arc(p.x, p.y, p.r, 0, Math.PI * 2);
      ctx.fillStyle = 'rgba(245, 158, 11, ' + p.a + ')';
      ctx.fill();
    }
    requestAnimationFrame(draw);
  }
  draw();
})();
</script>

<style is:global>
@import url('https://fonts.googleapis.com/css2?family=JetBrains+Mono:wght@400;500;600;700;800&display=swap');

/* ── Canvas particles ── */
#mnt-canvas {
  position: fixed;
  inset: 0;
  z-index: 0;
  pointer-events: none;
}

/* ── Page ── */
.mnt-page {
  position: relative;
  min-height: 100vh;
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 120px 20px 80px;
  background: var(--background);
  overflow: hidden;
  font-family: 'JetBrains Mono', monospace;
}

/* ── Background ── */
.mnt-bg {
  position: absolute;
  inset: 0;
  pointer-events: none;
  z-index: 0;
}
.mnt-orb {
  position: absolute;
  border-radius: 50%;
  filter: blur(100px);
  opacity: 0.1;
}
.mnt-orb-1 {
  width: 600px; height: 600px;
  background: var(--primary);
  top: -250px; right: -200px;
  animation: mnt-float 10s ease-in-out infinite;
}
.mnt-orb-2 {
  width: 500px; height: 500px;
  background: var(--teal);
  bottom: -200px; left: -200px;
  animation: mnt-float 12s ease-in-out infinite reverse;
}
.mnt-orb-3 {
  width: 350px; height: 350px;
  background: var(--emerald);
  top: 50%; left: 50%;
  transform: translate(-50%, -50%);
  animation: mnt-pulse 8s ease-in-out infinite;
}
@keyframes mnt-float {
  0%, 100% { transform: translateY(0) scale(1); }
  50% { transform: translateY(-50px) scale(1.05); }
}
@keyframes mnt-pulse {
  0%, 100% { opacity: 0.05; transform: translate(-50%, -50%) scale(1); }
  50% { opacity: 0.15; transform: translate(-50%, -50%) scale(1.2); }
}
.mnt-grid {
  position: absolute;
  inset: 0;
  background-image:
    linear-gradient(rgba(255,255,255,0.025) 1px, transparent 1px),
    linear-gradient(90deg, rgba(255,255,255,0.025) 1px, transparent 1px);
  background-size: 50px 50px;
}
.mnt-scanline {
  position: absolute;
  left: 0;
  right: 0;
  height: 2px;
  background: linear-gradient(90deg, transparent, rgba(245,158,11,0.3), transparent);
  animation: scan 4s linear infinite;
  opacity: 0.5;
}
@keyframes scan {
  0% { top: -2px; }
  100% { top: 100%; }
}

/* ── Section ── */
.mnt-section {
  position: relative;
  z-index: 2;
  text-align: center;
  max-width: 480px;
  width: 100%;
}

/* ── Card ── */
.mnt-card {
  position: relative;
  border-radius: 20px;
  padding: 1px;
  overflow: hidden;
}
.mnt-glow-border {
  position: absolute;
  inset: -1px;
  border-radius: 20px;
  background: conic-gradient(
    from 0deg,
    transparent,
    rgba(245,158,11,0.4),
    rgba(6,182,212,0.4),
    rgba(16,185,129,0.4),
    transparent
  );
  animation: mnt-rotate 4s linear infinite;
  mask: linear-gradient(#fff 0 0) content-box, linear-gradient(#fff 0 0);
  -webkit-mask: linear-gradient(#fff 0 0) content-box, linear-gradient(#fff 0 0);
  mask-composite: exclude;
  -webkit-mask-composite: xor;
  padding: 1px;
}
@keyframes mnt-rotate {
  to { transform: rotate(360deg); }
}
.mnt-card-inner {
  position: relative;
  background: rgba(10,10,14,0.92);
  backdrop-filter: blur(40px);
  border-radius: 19px;
  padding: 48px 36px;
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 12px;
  border: 1px solid rgba(255,255,255,0.04);
}

/* ── Status ── */
.mnt-status {
  display: flex;
  align-items: center;
  gap: 8px;
  margin-bottom: 4px;
}
.mnt-dot {
  width: 8px;
  height: 8px;
  border-radius: 50%;
  background: #f59e0b;
  box-shadow: 0 0 12px rgba(245,158,11,0.6);
  animation: mnt-blink 1.4s ease-in-out infinite;
}
@keyframes mnt-blink {
  0%, 100% { opacity: 1; }
  50% { opacity: 0.3; }
}
.mnt-status-text {
  font-size: 10px;
  font-weight: 600;
  letter-spacing: 3px;
  color: var(--primary);
}

/* ── Icon ── */
.mnt-icon-wrap {
  width: 64px;
  height: 64px;
  display: flex;
  align-items: center;
  justify-content: center;
  border-radius: 16px;
  background: rgba(245,158,11,0.06);
  color: var(--primary);
  border: 1px solid rgba(245,158,11,0.12);
}

/* ── Typography ── */
.mnt-card-inner h1 {
  font-size: 1.5rem;
  font-weight: 700;
  color: var(--on-surface);
  margin: 0;
  letter-spacing: -0.3px;
}
.mnt-card-inner > p {
  font-size: 0.82rem;
  color: var(--on-surface-variant);
  margin: 0 0 4px;
  line-height: 1.7;
  max-width: 360px;
  font-family: var(--font-family);
}

/* ── Progress ── */
.mnt-progress {
  width: 100%;
  max-width: 260px;
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 6px;
  margin: 4px 0 16px;
}
.mnt-progress-bar {
  width: 100%;
  height: 3px;
  background: rgba(255,255,255,0.06);
  border-radius: 3px;
  overflow: hidden;
  position: relative;
}
.mnt-progress-bar::after {
  content: '';
  position: absolute;
  top: 0; left: -40%;
  width: 40%;
  height: 100%;
  background: linear-gradient(90deg, transparent, var(--primary), transparent);
  border-radius: 3px;
  animation: mnt-loading 1.8s ease-in-out infinite;
}
@keyframes mnt-loading {
  0% { left: -40%; }
  100% { left: 100%; }
}
.mnt-progress-text {
  font-size: 10px;
  color: var(--on-surface-variant);
  letter-spacing: 1px;
  opacity: 0.6;
}

/* ── System info ── */
.mnt-sysinfo {
  width: 100%;
  border: 1px solid rgba(255,255,255,0.04);
  border-radius: 10px;
  padding: 12px 16px;
  display: flex;
  flex-direction: column;
  gap: 6px;
  background: rgba(0,0,0,0.2);
}
.mnt-sysrow {
  display: flex;
  justify-content: space-between;
  align-items: center;
}
.mnt-syslabel {
  font-size: 9px;
  letter-spacing: 1.5px;
  color: rgba(255,255,255,0.25);
  font-weight: 500;
}
.mnt-sysvalue {
  font-size: 10px;
  color: rgba(255,255,255,0.45);
  font-weight: 500;
}
.mnt-sysvalue--warn {
  color: var(--primary);
}

/* ── Contact ── */
.mnt-contact {
  display: flex;
  flex-direction: column;
  gap: 8px;
  width: 100%;
  margin-top: 4px;
}
.mnt-wa {
  display: flex;
  align-items: center;
  gap: 14px;
  padding: 14px 20px;
  border-radius: 12px;
  background: rgba(37,211,102,0.1);
  border: 1px solid rgba(37,211,102,0.2);
  text-decoration: none;
  transition: all 0.3s;
}
.mnt-wa:hover {
  background: rgba(37,211,102,0.18);
  border-color: rgba(37,211,102,0.4);
  transform: translateY(-1px);
}
.mnt-wa svg { color: #25D366; flex-shrink: 0; }
.mnt-wa-num {
  font-size: 0.95rem;
  font-weight: 700;
  color: var(--on-surface);
  font-family: 'JetBrains Mono', monospace;
}
.mnt-wa-label {
  font-size: 10px;
  color: var(--on-surface-variant);
  margin-left: auto;
  opacity: 0.6;
  font-family: var(--font-family);
}
.mnt-email {
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 8px;
  padding: 10px 20px;
  border-radius: 10px;
  text-decoration: none;
  color: var(--on-surface-variant);
  font-size: 0.78rem;
  transition: all 0.3s;
  border: 1px solid transparent;
}
.mnt-email svg { color: var(--primary); flex-shrink: 0; }
.mnt-email:hover {
  color: var(--primary);
  border-color: rgba(245,158,11,0.15);
  background: rgba(245,158,11,0.04);
}

/* ── Footer ── */
.mnt-footer-text {
  display: flex;
  align-items: center;
  gap: 6px;
  margin-top: 8px;
  font-size: 9px;
  color: rgba(255,255,255,0.15);
  letter-spacing: 0.5px;
  font-family: var(--font-family);
}
.mnt-footer-text svg { color: rgba(255,255,255,0.1); }

@media (max-width: 600px) {
  .mnt-card-inner { padding: 36px 20px; }
  .mnt-card-inner h1 { font-size: 1.2rem; }
  .mnt-wa { flex-wrap: wrap; gap: 8px; }
  .mnt-wa-label { margin-left: 0; width: 100%; text-align: center; }
}
</style>
