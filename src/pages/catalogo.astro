---
import BaseLayout from "../layouts/BaseLayout.astro";
import Navbar from "../components/Navbar.astro";
import CatalogoSection from "../components/CatalogoSection.astro";
import Footer from "../components/Footer.astro";

const catalogoImgs = [
  "/catalogo/1.png",
  "/catalogo/2.jpg",
  "/catalogo/3.jpg",
  "/catalogo/4.jpg",
  "/catalogo/5.jpg",
  "/catalogo/6.png",
];
---

<BaseLayout title="Catálogo de productos - MKDIGITAL Nicaragua" description="Licencias originales de Office, Windows, Antivirus, Adobe y más. Precios en Nicaragua con entrega inmediata." ogImage="https://mkdigitalnic.com/soporte.jpg">
  <Navbar />

  <section class="section catalogo-gallery">
    <div class="container">
      <div class="gallery-grid">
        {catalogoImgs.map((src, i) => (
          <div class="gallery-item reveal reveal-up stagger-{Math.min(i + 1, 6)}">
            <img src={src} alt={`Catálogo ${i + 1}`} loading="lazy" />
          </div>
        ))}
      </div>
    </div>
  </section>

  <CatalogoSection />

  <Footer />
</BaseLayout>

<style>
  .catalogo-gallery {
    padding-top: 120px;
    padding-bottom: 0;
    background: var(--background);
  }
  .gallery-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 16px;
  }
  .gallery-item {
    border-radius: 14px;
    overflow: hidden;
    background: var(--surface-container);
    border: 1px solid var(--outline-variant);
    transition: border-color 0.3s, transform 0.3s;
  }
  .gallery-item:hover {
    border-color: var(--primary);
    transform: translateY(-3px);
  }
  .gallery-item img {
    width: 100%;
    height: auto;
    display: block;
  }
  @media (max-width: 768px) {
    .gallery-grid { grid-template-columns: repeat(2, 1fr); }
  }
  @media (max-width: 480px) {
    .gallery-grid { grid-template-columns: 1fr; }
  }
</style>
