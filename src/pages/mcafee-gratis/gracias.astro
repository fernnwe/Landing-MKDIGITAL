---
import BaseLayout from "../../layouts/BaseLayout.astro";
import Navbar from "../../components/Navbar.astro";
import Footer from "../../components/Footer.astro";
---

<BaseLayout title="Licencia reclamada - McAfee GRATIS MKDIGITAL" description="Gracias por reclamar tu licencia McAfee AntiVirus gratis. Aquí tienes tu código de activación.">
  <Navbar />
  <main class="gracias-page">
    <section class="gracias-hero">
      <div class="gracias-container">
        <div class="success-icon">
          <svg viewBox="0 0 24 24" width="56" height="56" fill="none" stroke="#00c853" stroke-width="1.5"><circle cx="12" cy="12" r="10"/><path d="M8 12l2 2 4-4"/></svg>
        </div>
        <h1>Licencia reclamada con éxito</h1>
        <p>Tu código de activación de McAfee AntiVirus está listo. Utilízalo antes de que expire.</p>
      </div>
    </section>

    <section class="key-section">
      <div class="key-container">
        <div class="key-card">
          <div class="key-label">Código de activación</div>
          <div class="key-value" id="licenseKey">29PVK-DXC72-7F3EJ-GRRN4-A222H</div>
          <button class="btn-copy" onclick="navigator.clipboard.writeText('29PVK-DXC72-7F3EJ-GRRN4-A222H');this.textContent='Copiado';const t=this;setTimeout(()=>t.textContent='Copiar código',2000)">
            Copiar código
          </button>
        </div>
      </div>
    </section>

    <section class="activate-section">
      <div class="activate-container">
        <h2>Instrucciones de activación</h2>
        <div class="activate-steps">
          <div class="activate-step">
            <span class="activate-num">1</span>
            <div>
              <h3>Ingresa al sitio de activación</h3>
              <p>Abre <a href="https://www.mcafee.com/es-es/consumer-support/activate-product-key.html" target="_blank" rel="noopener">mcafee.com/activate</a> en tu navegador.</p>
            </div>
          </div>
          <div class="activate-step">
            <span class="activate-num">2</span>
            <div>
              <h3>Ingresa tu código</h3>
              <p>Copia el código <strong>29PVK-DXC72-7F3EJ-GGRN4-A222H</strong> en el campo correspondiente.</p>
            </div>
          </div>
          <div class="activate-step">
            <span class="activate-num">3</span>
            <div>
              <h3>Completa el registro</h3>
              <p>Deja el país que aparezca por defecto, ingresa tu correo electrónico y crea tu cuenta.</p>
            </div>
          </div>
          <div class="activate-step">
            <span class="activate-num">4</span>
            <div>
              <h3>Descarga e instala</h3>
              <p>McAfee se descargará automáticamente. Sigue las instrucciones en pantalla para completar la instalación.</p>
            </div>
          </div>
        </div>
        <div class="activate-notice">
          <svg viewBox="0 0 24 24" width="20" height="20" fill="none" stroke="#f59e0b" stroke-width="2"><circle cx="12" cy="12" r="10"/><path d="M12 16v-4"/><path d="M12 8h.01"/></svg>
          <span>Licencia válida para 1 PC con Windows por 1 año. No compartas este código, solo funciona para una activación.</span>
        </div>
      </div>
    </section>

    <section class="support-section">
      <div class="support-container">
        <h2>¿Necesitas ayuda?</h2>
        <p>Si tienes algún problema con la activación, nuestro equipo de soporte está listo para ayudarte.</p>
        <a href="https://wa.me/50581088124?text=Hola%2C+recib%C3%AD+mi+c%C3%B3digo+de+McAfee+y+necesito+ayuda+con+la+activaci%C3%B3n" target="_blank" rel="noopener" class="btn-support">
          <svg viewBox="0 0 24 24" width="22" height="22" fill="currentColor"><path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/></svg>
          Contactar por WhatsApp
        </a>
      </div>
    </section>

    <div class="back-link">
      <a href="/">← Volver a MKDIGITAL</a>
    </div>
  </main>
  <Footer />
</BaseLayout>

<style is:global>
.gracias-page {
  padding-top: 80px;
  font-family: system-ui, -apple-system, sans-serif;
  background: #0a0a12;
  min-height: 100vh;
}
.gracias-hero {
  padding: 64px 20px 0;
}
.gracias-container {
  max-width: 600px;
  margin: 0 auto;
  text-align: center;
}
.success-icon { margin-bottom: 20px; }
.gracias-container h1 {
  font-size: 2rem;
  font-weight: 700;
  color: #fff;
  margin: 0 0 10px;
}
.gracias-container p {
  color: #888;
  font-size: 1.05rem;
  margin: 0;
  line-height: 1.5;
}

/* Key */
.key-section { padding: 40px 20px; }
.key-container { max-width: 600px; margin: 0 auto; }
.key-card {
  background: #11111e;
  border: 1px solid #1e1e32;
  border-radius: 16px;
  padding: 32px;
  text-align: center;
}
.key-label {
  font-size: 0.8rem;
  text-transform: uppercase;
  letter-spacing: 1px;
  color: #666;
  margin-bottom: 12px;
}
.key-value {
  font-family: 'SF Mono', 'Fira Code', 'Courier New', monospace;
  font-size: 1.15rem;
  font-weight: 600;
  color: #00c853;
  background: #0a0a14;
  border: 1px dashed rgba(0,200,83,0.3);
  border-radius: 10px;
  padding: 16px 20px;
  word-break: break-all;
  letter-spacing: 1.5px;
  user-select: all;
  margin-bottom: 20px;
}
.btn-copy {
  background: transparent;
  color: #00c853;
  border: 1px solid #00c853;
  padding: 10px 28px;
  border-radius: 8px;
  font-weight: 600;
  font-size: 0.9rem;
  cursor: pointer;
  transition: background 0.2s;
}
.btn-copy:hover {
  background: rgba(0,200,83,0.1);
}

/* Activate */
.activate-section { padding: 0 20px 40px; }
.activate-container {
  max-width: 600px;
  margin: 0 auto;
  background: #11111e;
  border: 1px solid #1e1e32;
  border-radius: 16px;
  padding: 36px;
}
.activate-container h2 {
  font-size: 1.2rem;
  font-weight: 700;
  color: #fff;
  margin: 0 0 28px;
  text-align: center;
}
.activate-steps {
  display: flex;
  flex-direction: column;
  gap: 20px;
}
.activate-step {
  display: flex;
  gap: 16px;
  align-items: flex-start;
}
.activate-num {
  flex-shrink: 0;
  width: 32px;
  height: 32px;
  border-radius: 8px;
  background: rgba(207,10,44,0.1);
  color: #CF0A2C;
  display: flex;
  align-items: center;
  justify-content: center;
  font-weight: 700;
  font-size: 0.85rem;
}
.activate-step h3 {
  font-size: 0.95rem;
  font-weight: 700;
  color: #fff;
  margin: 0 0 4px;
}
.activate-step p {
  font-size: 0.85rem;
  color: #888;
  margin: 0;
  line-height: 1.5;
}
.activate-step a {
  color: #CF0A2C;
  text-decoration: underline;
}
.activate-notice {
  display: flex;
  align-items: flex-start;
  gap: 8px;
  margin-top: 24px;
  padding: 12px 16px;
  background: rgba(245,158,11,0.06);
  border: 1px solid rgba(245,158,11,0.15);
  border-radius: 10px;
}
.activate-notice span {
  font-size: 0.82rem;
  color: #a88;
  line-height: 1.4;
}

/* Support */
.support-section { padding: 0 20px 40px; }
.support-container {
  max-width: 600px;
  margin: 0 auto;
  text-align: center;
}
.support-container h2 {
  font-size: 1.2rem;
  font-weight: 700;
  color: #fff;
  margin: 0 0 8px;
}
.support-container > p {
  color: #888;
  font-size: 0.9rem;
  margin: 0 0 24px;
}
.btn-support {
  display: inline-flex;
  align-items: center;
  gap: 10px;
  background: #25D366;
  color: #fff;
  padding: 14px 32px;
  border-radius: 10px;
  font-weight: 700;
  font-size: 1rem;
  text-decoration: none;
  transition: background 0.2s, transform 0.15s;
}
.btn-support:hover {
  background: #1ebe5b;
  transform: translateY(-1px);
}

/* Back */
.back-link {
  text-align: center;
  padding: 0 20px 80px;
}
.back-link a {
  color: #555;
  text-decoration: none;
  font-size: 0.9rem;
  transition: color 0.2s;
}
.back-link a:hover { color: #CF0A2C; }

@media (max-width: 640px) {
  .gracias-container h1 { font-size: 1.5rem; }
  .key-value { font-size: 1rem; padding: 14px; }
  .activate-container { padding: 24px; }
}
</style>
