---
import BaseLayout from "../layouts/BaseLayout.astro";
import Navbar from "../components/Navbar.astro";
import Footer from "../components/Footer.astro";
const title = "McAfee AntiVirus GRATIS - MKDIGITAL Nicaragua";
const desc = "Reclama tu licencia McAfee AntiVirus completamente gratis. Promoción válida por tiempo limitado en Nicaragua.";
---

<BaseLayout title={title} description={desc}>
  <Navbar />
  <main class="mcafee-page">
    <section class="hero-mcafee">
      <div class="hero-badge">🎁 Promoción Especial</div>
      <h1>McAfee AntiVirus <span class="highlight">GRATIS</span></h1>
      <p class="hero-sub">Licencia original de McAfee AntiVirus por 1 año — <strong>completamente gratis</strong>. Promoción válida para nuevos clientes en Nicaragua.</p>
      <div class="hero-stats">
        <div class="stat"><span class="stat-icon">🔒</span> Protección completa</div>
        <div class="stat"><span class="stat-icon">📅</span> 1 año de suscripción</div>
        <div class="stat"><span class="stat-icon">💻</span> 1 dispositivo</div>
      </div>
    </section>

    <section class="form-section" id="form-section">
      <div class="form-card">
        <h2>Reclama tu licencia</h2>
        <p>Completa tus datos para recibir el código de activación. <strong>Solo 1 licencia disponible por persona.</strong></p>
        <form name="mcafee-claim" method="POST" action="/mcafee-gratis/gracias" data-netlify="true">
          <input type="hidden" name="form-name" value="mcafee-claim" />
          <div class="form-group">
            <label for="nombre">Nombre completo *</label>
            <input type="text" id="nombre" name="nombre" required placeholder="Ej: Juan Pérez" />
          </div>
          <div class="form-group">
            <label for="email">Correo electrónico *</label>
            <input type="email" id="email" name="email" required placeholder="ejemplo@correo.com" />
          </div>
          <div class="form-group">
            <label for="telefono">Teléfono / WhatsApp *</label>
            <input type="tel" id="telefono" name="telefono" required placeholder="Ej: 505 8888 8888" />
          </div>
          <button type="submit" class="btn-submit">Reclamar mi licencia gratis</button>
          <p class="form-notice">🔐 Tus datos solo se usarán para enviarte el código de activación.</p>
        </form>
      </div>
    </section>

    <section class="info-section">
      <h2>¿Por qué McAfee AntiVirus?</h2>
      <div class="info-grid">
        <div class="info-card">
          <span class="info-icon">🛡️</span>
          <h3>Protección en tiempo real</h3>
          <p>Bloquea virus, malware, ransomware y amenazas en línea automáticamente.</p>
        </div>
        <div class="info-card">
          <span class="info-icon">🌐</span>
          <h3>Navegación segura</h3>
          <p>Protege tu privacidad mientras navegas, compras y haces transacciones bancarias.</p>
        </div>
        <div class="info-card">
          <span class="info-icon">⚡</span>
          <h3>Ligero y eficiente</h3>
          <p>No ralentiza tu PC. Funciona en segundo plano sin interrumpir tu trabajo.</p>
        </div>
      </div>
    </section>

    <section class="steps-section">
      <h2>¿Cómo funciona?</h2>
      <div class="steps">
        <div class="step">
          <span class="step-num">1</span>
          <p>Completa el formulario con tus datos</p>
        </div>
        <div class="step-arrow">→</div>
        <div class="step">
          <span class="step-num">2</span>
          <p>Recibe el código de activación en la siguiente pantalla</p>
        </div>
        <div class="step-arrow">→</div>
        <div class="step">
          <span class="step-num">3</span>
          <p>Ingresa a mcafee.com/activate y disfruta</p>
        </div>
      </div>
    </section>
  </main>
  <Footer />
</BaseLayout>

<style is:global>
.mcafee-page {
  padding-top: 80px;
  font-family: system-ui, -apple-system, sans-serif;
}
.hero-mcafee {
  text-align: center;
  padding: 60px 20px 40px;
  background: linear-gradient(135deg, #1a1a2e 0%, #16213e 50%, #0f3460 100%);
}
.hero-badge {
  display: inline-block;
  background: #ff6b35;
  color: #fff;
  padding: 8px 24px;
  border-radius: 20px;
  font-weight: 700;
  font-size: 0.9rem;
  margin-bottom: 20px;
  text-transform: uppercase;
  letter-spacing: 1px;
}
.hero-mcafee h1 {
  font-size: 2.8rem;
  color: #fff;
  margin: 0 0 16px;
}
.hero-mcafee .highlight {
  color: #00c853;
}
.hero-sub {
  color: #b0b0c0;
  font-size: 1.15rem;
  max-width: 600px;
  margin: 0 auto 30px;
  line-height: 1.6;
}
.hero-stats {
  display: flex;
  justify-content: center;
  gap: 30px;
  flex-wrap: wrap;
}
.stat {
  color: #fff;
  font-size: 1rem;
  display: flex;
  align-items: center;
  gap: 8px;
}
.stat-icon {
  font-size: 1.3rem;
}
.form-section {
  padding: 60px 20px;
  display: flex;
  justify-content: center;
}
.form-card {
  background: #1e1e2f;
  border-radius: 16px;
  padding: 40px;
  max-width: 500px;
  width: 100%;
  border: 1px solid #2a2a40;
}
.form-card h2 {
  color: #fff;
  margin: 0 0 8px;
  font-size: 1.5rem;
}
.form-card > p {
  color: #999;
  font-size: 0.9rem;
  margin: 0 0 24px;
}
.form-group {
  margin-bottom: 20px;
}
.form-group label {
  display: block;
  color: #ccc;
  font-size: 0.9rem;
  margin-bottom: 6px;
  font-weight: 600;
}
.form-group input {
  width: 100%;
  padding: 12px 16px;
  border: 1px solid #333;
  border-radius: 10px;
  background: #13131f;
  color: #fff;
  font-size: 1rem;
  box-sizing: border-box;
  transition: border-color 0.2s;
}
.form-group input:focus {
  outline: none;
  border-color: #00c853;
}
.btn-submit {
  width: 100%;
  padding: 14px;
  background: linear-gradient(135deg, #00c853, #00a844);
  color: #fff;
  border: none;
  border-radius: 10px;
  font-size: 1.05rem;
  font-weight: 700;
  cursor: pointer;
  transition: transform 0.2s, box-shadow 0.2s;
}
.btn-submit:hover {
  transform: translateY(-2px);
  box-shadow: 0 6px 20px rgba(0, 200, 83, 0.3);
}
.form-notice {
  color: #777;
  font-size: 0.8rem;
  text-align: center;
  margin: 16px 0 0;
}
.info-section {
  padding: 60px 20px;
  text-align: center;
}
.info-section h2 {
  color: #fff;
  font-size: 1.8rem;
  margin: 0 0 40px;
}
.info-grid {
  display: grid;
  grid-template-columns: repeat(auto-fit, minmax(250px, 1fr));
  gap: 24px;
  max-width: 900px;
  margin: 0 auto;
}
.info-card {
  background: #1e1e2f;
  border-radius: 12px;
  padding: 30px 20px;
  border: 1px solid #2a2a40;
  transition: transform 0.2s, border-color 0.2s;
}
.info-card:hover {
  transform: translateY(-4px);
  border-color: #00c853;
}
.info-icon {
  font-size: 2.5rem;
  display: block;
  margin-bottom: 16px;
}
.info-card h3 {
  color: #fff;
  margin: 0 0 10px;
  font-size: 1.15rem;
}
.info-card p {
  color: #999;
  font-size: 0.9rem;
  line-height: 1.5;
  margin: 0;
}
.steps-section {
  padding: 60px 20px 80px;
  text-align: center;
}
.steps-section h2 {
  color: #fff;
  font-size: 1.8rem;
  margin: 0 0 40px;
}
.steps {
  display: flex;
  justify-content: center;
  align-items: center;
  gap: 16px;
  flex-wrap: wrap;
  max-width: 800px;
  margin: 0 auto;
}
.step {
  background: #1e1e2f;
  border: 1px solid #2a2a40;
  border-radius: 12px;
  padding: 20px;
  min-width: 180px;
  flex: 1;
}
.step-num {
  display: inline-flex;
  width: 36px;
  height: 36px;
  background: #00c853;
  color: #fff;
  border-radius: 50%;
  align-items: center;
  justify-content: center;
  font-weight: 700;
  font-size: 1.1rem;
  margin-bottom: 10px;
}
.step p {
  color: #ccc;
  font-size: 0.9rem;
  margin: 0;
  line-height: 1.4;
}
.step-arrow {
  color: #00c853;
  font-size: 1.5rem;
  font-weight: 700;
}
@media (max-width: 640px) {
  .hero-mcafee h1 { font-size: 1.8rem; }
  .hero-stats { flex-direction: column; align-items: center; gap: 12px; }
  .form-card { padding: 24px; }
  .steps { flex-direction: column; }
  .step-arrow { transform: rotate(90deg); }
}
</style>
