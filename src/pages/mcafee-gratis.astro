---
import BaseLayout from "../layouts/BaseLayout.astro";
import Navbar from "../components/Navbar.astro";
import Footer from "../components/Footer.astro";
const title = "McAfee AntiVirus GRATIS - MKDIGITAL Nicaragua";
const desc = "Obtén tu licencia McAfee AntiVirus completamente gratis. Promoción exclusiva por tiempo limitado en Nicaragua.";
---

<BaseLayout title={title} description={desc}>
  <Navbar />
  <main class="mcafee-page">
    <section class="mcafee-hero">
      <div class="hero-container">
        <div class="hero-brand">
          <div class="brand-shield">
            <svg viewBox="0 0 24 24" width="48" height="48" fill="none" stroke="#CF0A2C" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
              <path d="M12 2L3 7v6c0 5.25 3.83 10.15 9 11 5.17-.85 9-5.75 9-11V7l-9-5z"/>
              <path d="M9 12l2 2 4-4" stroke="#fff" stroke-width="2"/>
            </svg>
          </div>
          <h1>McAfee AntiVirus</h1>
          <p class="hero-subtitle">Licencia original por 1 año para Windows — completamente gratis</p>
        </div>
        <div class="hero-badges">
          <div class="badge">
            <svg viewBox="0 0 24 24" width="20" height="20" fill="none" stroke="currentColor" stroke-width="2"><circle cx="12" cy="12" r="10"/><path d="M12 6v6l4 2"/></svg>
            <span>1 año de protección</span>
          </div>
          <div class="badge">
            <svg viewBox="0 0 24 24" width="20" height="20" fill="none" stroke="currentColor" stroke-width="2"><rect x="2" y="3" width="20" height="14" rx="2"/><path d="M8 21h8"/><path d="M12 17v4"/></svg>
            <span>1 PC con Windows</span>
          </div>
          <div class="badge">
            <svg viewBox="0 0 24 24" width="20" height="20" fill="none" stroke="currentColor" stroke-width="2"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/></svg>
            <span>Protección en tiempo real</span>
          </div>
        </div>
      </div>
    </section>

    <section class="mcafee-form">
      <div class="form-layout">
        <div class="form-card">
          <div class="form-header">
            <h2>Reclama tu licencia</h2>
            <p>Completa el formulario y recibe tu código de activación al instante.</p>
          </div>
          <form name="mcafee-claim" method="POST" action="/mcafee-gratis/gracias/" data-netlify="true">
            <input type="hidden" name="form-name" value="mcafee-claim" />
            <div class="field">
              <label for="nombre">Nombre completo</label>
              <input type="text" id="nombre" name="nombre" required placeholder="Tu nombre" />
            </div>
            <div class="field">
              <label for="email">Correo electrónico</label>
              <input type="email" id="email" name="email" required placeholder="correo@ejemplo.com" />
            </div>
            <div class="field">
              <label for="telefono">WhatsApp <span class="opt">opcional</span></label>
              <input type="tel" id="telefono" name="telefono" placeholder="505 8888 8888" />
            </div>
            <button type="submit" class="btn-primary">
              Obtener licencia gratis
              <svg viewBox="0 0 24 24" width="18" height="18" fill="none" stroke="currentColor" stroke-width="2.5"><path d="M5 12h14"/><path d="M12 5l7 7-7 7"/></svg>
            </button>
            <p class="form-footnote">Tus datos están seguros. Solo los usaremos para enviarte tu código.</p>
          </form>
        </div>
        <aside class="form-sidebar">
          <div class="sidebar-block highlight-block">
            <div class="block-icon">
              <svg viewBox="0 0 24 24" width="28" height="28" fill="none" stroke="#CF0A2C" stroke-width="2"><circle cx="12" cy="12" r="10"/><path d="M12 16v-4"/><path d="M12 8h.01"/></svg>
            </div>
            <h3>Promoción exclusiva</h3>
            <p>Esta licencia para <strong>1 PC con Windows</strong> tiene un valor de <strong>C$740</strong> en nuestro catálogo. Válida para los primeros solicitantes.</p>
          </div>
          <div class="sidebar-block">
            <div class="block-icon">
              <svg viewBox="0 0 24 24" width="28" height="28" fill="none" stroke="#666" stroke-width="2"><path d="M4 4h16c1.1 0 2 .9 2 2v12c0 1.1-.9 2-2 2H4c-1.1 0-2-.9-2-2V6c0-1.1.9-2 2-2z"/><polyline points="22,6 12,13 2,6"/></svg>
            </div>
            <h3>Recibes</h3>
            <ul>
              <li>Código de activación original</li>
              <li>Instrucciones paso a paso</li>
              <li>Soporte por WhatsApp si lo necesitas</li>
            </ul>
          </div>
          <div class="sidebar-block">
            <div class="block-icon">
              <svg viewBox="0 0 24 24" width="28" height="28" fill="none" stroke="#666" stroke-width="2"><circle cx="12" cy="12" r="10"/><path d="M8 14s1.5 2 4 2 4-2 4-2"/><line x1="9" y1="9" x2="9.01" y2="9"/><line x1="15" y1="9" x2="15.01" y2="9"/></svg>
            </div>
            <h3>¿Dudas?</h3>
            <p>Escríbenos por <a href="https://wa.me/50581088124" target="_blank" rel="noopener">WhatsApp</a> y te ayudamos.</p>
          </div>
        </aside>
      </div>
    </section>

    <section class="mcafee-details">
      <div class="details-container">
        <h2>Protección completa para tu PC con Windows</h2>
        <div class="details-grid">
          <div class="detail-card">
            <div class="detail-icon">
              <svg viewBox="0 0 24 24" width="32" height="32" fill="none" stroke="#CF0A2C" stroke-width="1.5"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/></svg>
            </div>
            <h3>Anti-malware avanzado</h3>
            <p>Detección y eliminación de virus, spyware, ransomware y otras amenazas en tiempo real.</p>
          </div>
          <div class="detail-card">
            <div class="detail-icon">
              <svg viewBox="0 0 24 24" width="32" height="32" fill="none" stroke="#CF0A2C" stroke-width="1.5"><circle cx="12" cy="12" r="3"/><path d="M19.4 15a1.65 1.65 0 0 0 .33 1.82l.06.06a2 2 0 0 1 0 2.83 2 2 0 0 1-2.83 0l-.06-.06a1.65 1.65 0 0 0-1.82-.33 1.65 1.65 0 0 0-1 1.51V21a2 2 0 0 1-2 2 2 2 0 0 1-2-2v-.09A1.65 1.65 0 0 0 9 19.4a1.65 1.65 0 0 0-1.82.33l-.06.06a2 2 0 0 1-2.83 0 2 2 0 0 1 0-2.83l.06-.06A1.65 1.65 0 0 0 4.68 15a1.65 1.65 0 0 0-1.51-1H3a2 2 0 0 1-2-2 2 2 0 0 1 2-2h.09A1.65 1.65 0 0 0 4.6 9a1.65 1.65 0 0 0-.33-1.82l-.06-.06a2 2 0 0 1 0-2.83 2 2 0 0 1 2.83 0l.06.06A1.65 1.65 0 0 0 9 4.68a1.65 1.65 0 0 0 1-1.51V3a2 2 0 0 1 2-2 2 2 0 0 1 2 2v.09a1.65 1.65 0 0 0 1 1.51 1.65 1.65 0 0 0 1.82-.33l.06-.06a2 2 0 0 1 2.83 0 2 2 0 0 1 0 2.83l-.06.06a1.65 1.65 0 0 0-.33 1.82V9a1.65 1.65 0 0 0 1.51 1H21a2 2 0 0 1 2 2 2 2 0 0 1-2 2h-.09a1.65 1.65 0 0 0-1.51 1z"/></svg>
            </div>
            <h3>Navegación segura</h3>
            <p>Protege tus datos mientras navegas, compras en línea y realizas transacciones bancarias.</p>
          </div>
          <div class="detail-card">
            <div class="detail-icon">
              <svg viewBox="0 0 24 24" width="32" height="32" fill="none" stroke="#CF0A2C" stroke-width="1.5"><rect x="3" y="11" width="18" height="11" rx="2"/><path d="M7 11V7a5 5 0 0 1 10 0v4"/></svg>
            </div>
            <h3>Firewall inteligente</h3>
            <p>Monitorea el tráfico de red y bloquea accesos no autorizados a tu equipo.</p>
          </div>
          <div class="detail-card">
            <div class="detail-icon">
              <svg viewBox="0 0 24 24" width="32" height="32" fill="none" stroke="#CF0A2C" stroke-width="1.5"><path d="M12 2L2 7l10 5 10-5-10-5z"/><path d="M2 17l10 5 10-5"/><path d="M2 12l10 5 10-5"/></svg>
            </div>
            <h3>Actualizaciones automáticas</h3>
            <p>McAfee se actualiza solo para estar siempre protegido contra las últimas amenazas.</p>
          </div>
        </div>
      </div>
    </section>

    <section class="mcafee-steps">
      <div class="steps-container">
        <h2>Cómo obtener tu licencia</h2>
        <div class="steps-track">
          <div class="step-item">
            <div class="step-number">01</div>
            <h3>Completa tus datos</h3>
            <p>Llena el formulario con tu nombre y correo electrónico.</p>
          </div>
          <div class="step-connector"></div>
          <div class="step-item">
            <div class="step-number">02</div>
            <h3>Recibe tu código</h3>
            <p>En la siguiente pantalla verás tu código de activación.</p>
          </div>
          <div class="step-connector"></div>
          <div class="step-item">
            <div class="step-number">03</div>
            <h3>Actívalo</h3>
            <p>Ingresa a <strong>mcafee.com/activate</strong> e introduce el código.</p>
          </div>
        </div>
      </div>
    </section>
  </main>
  <Footer />
</BaseLayout>

<style is:global>
.mcafee-page {
  padding-top: 80px;
  font-family: system-ui, -apple-system, sans-serif;
  background: #0a0a12;
}

/* ── Hero ── */
.mcafee-hero {
  background: linear-gradient(135deg, #0d0d1a 0%, #1a0a0e 40%, #0d0d1a 100%);
  border-bottom: 1px solid #1a1a2e;
  padding: 64px 20px 56px;
}
.hero-container {
  max-width: 760px;
  margin: 0 auto;
  text-align: center;
}
.brand-shield {
  margin-bottom: 16px;
  display: inline-flex;
  background: rgba(207,10,44,0.08);
  padding: 14px;
  border-radius: 20px;
}
.hero-container h1 {
  font-size: 2.6rem;
  font-weight: 700;
  color: #fff;
  letter-spacing: -0.5px;
  margin: 0 0 8px;
}
.hero-subtitle {
  font-size: 1.15rem;
  color: #888;
  margin: 0 0 36px;
}
.hero-badges {
  display: flex;
  justify-content: center;
  gap: 24px;
  flex-wrap: wrap;
}
.badge {
  display: flex;
  align-items: center;
  gap: 8px;
  color: #bbb;
  font-size: 0.9rem;
}
.badge svg { color: #CF0A2C; flex-shrink: 0; }

/* ── Form ── */
.mcafee-form {
  padding: 56px 20px;
}
.form-layout {
  max-width: 860px;
  margin: 0 auto;
  display: grid;
  grid-template-columns: 1fr 300px;
  gap: 32px;
  align-items: start;
}
.form-card {
  background: #11111e;
  border: 1px solid #1e1e32;
  border-radius: 16px;
  padding: 36px;
}
.form-header { margin-bottom: 28px; }
.form-header h2 {
  font-size: 1.4rem;
  font-weight: 700;
  color: #fff;
  margin: 0 0 6px;
}
.form-header p {
  color: #777;
  font-size: 0.92rem;
  margin: 0;
}
.field {
  margin-bottom: 20px;
}
.field label {
  display: block;
  font-size: 0.85rem;
  font-weight: 600;
  color: #bbb;
  margin-bottom: 6px;
  text-transform: uppercase;
  letter-spacing: 0.5px;
}
.field .opt {
  font-weight: 400;
  text-transform: none;
  letter-spacing: 0;
  color: #555;
  font-size: 0.78rem;
}
.field input {
  width: 100%;
  box-sizing: border-box;
  padding: 12px 14px;
  border: 1px solid #222;
  border-radius: 10px;
  background: #0a0a14;
  color: #fff;
  font-size: 1rem;
  transition: border-color 0.2s;
}
.field input:focus {
  outline: none;
  border-color: #CF0A2C;
}
.btn-primary {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  gap: 10px;
  width: 100%;
  padding: 14px;
  background: #CF0A2C;
  color: #fff;
  border: none;
  border-radius: 10px;
  font-size: 1.05rem;
  font-weight: 700;
  cursor: pointer;
  transition: background 0.2s, transform 0.15s;
}
.btn-primary:hover {
  background: #b00926;
  transform: translateY(-1px);
}
.btn-primary:active {
  transform: translateY(0);
}
.form-footnote {
  color: #555;
  font-size: 0.78rem;
  text-align: center;
  margin: 16px 0 0;
}

/* ── Sidebar ── */
.form-sidebar {
  display: flex;
  flex-direction: column;
  gap: 20px;
}
.sidebar-block {
  background: #11111e;
  border: 1px solid #1e1e32;
  border-radius: 14px;
  padding: 24px;
}
.sidebar-block.highlight-block {
  border-color: rgba(207,10,44,0.25);
  background: linear-gradient(135deg, rgba(207,10,44,0.06), rgba(207,10,44,0.02));
}
.block-icon { margin-bottom: 12px; }
.sidebar-block h3 {
  font-size: 0.95rem;
  font-weight: 700;
  color: #fff;
  margin: 0 0 8px;
}
.sidebar-block p {
  font-size: 0.85rem;
  color: #888;
  line-height: 1.5;
  margin: 0;
}
.sidebar-block ul {
  margin: 0;
  padding: 0 0 0 16px;
  font-size: 0.85rem;
  color: #888;
  line-height: 1.8;
}
.sidebar-block a {
  color: #CF0A2C;
  text-decoration: none;
  font-weight: 600;
}
.sidebar-block a:hover { text-decoration: underline; }

/* ── Details ── */
.mcafee-details {
  padding: 64px 20px;
  border-top: 1px solid #14141e;
}
.details-container {
  max-width: 860px;
  margin: 0 auto;
}
.details-container h2 {
  font-size: 1.6rem;
  font-weight: 700;
  color: #fff;
  text-align: center;
  margin: 0 0 44px;
}
.details-grid {
  display: grid;
  grid-template-columns: repeat(2, 1fr);
  gap: 20px;
}
.detail-card {
  background: #11111e;
  border: 1px solid #1a1a2a;
  border-radius: 14px;
  padding: 28px 24px;
  transition: border-color 0.2s, transform 0.2s;
}
.detail-card:hover {
  border-color: #CF0A2C;
  transform: translateY(-2px);
}
.detail-icon { margin-bottom: 16px; }
.detail-card h3 {
  font-size: 1.05rem;
  font-weight: 700;
  color: #fff;
  margin: 0 0 10px;
}
.detail-card p {
  font-size: 0.88rem;
  color: #888;
  line-height: 1.6;
  margin: 0;
}

/* ── Steps ── */
.mcafee-steps {
  padding: 56px 20px 80px;
  border-top: 1px solid #14141e;
}
.steps-container {
  max-width: 720px;
  margin: 0 auto;
  text-align: center;
}
.steps-container h2 {
  font-size: 1.6rem;
  font-weight: 700;
  color: #fff;
  margin: 0 0 44px;
}
.steps-track {
  display: flex;
  align-items: flex-start;
  gap: 0;
}
.step-item {
  flex: 1;
  padding: 0 16px;
}
.step-number {
  font-size: 2.2rem;
  font-weight: 800;
  color: rgba(207,10,44,0.15);
  line-height: 1;
  margin-bottom: 8px;
}
.step-item h3 {
  font-size: 1rem;
  font-weight: 700;
  color: #fff;
  margin: 0 0 6px;
}
.step-item p {
  font-size: 0.85rem;
  color: #888;
  line-height: 1.5;
  margin: 0;
}
.step-connector {
  flex-shrink: 0;
  width: 40px;
  height: 2px;
  background: linear-gradient(90deg, #CF0A2C, transparent);
  margin-top: 28px;
}
.step-connector:last-child { display: none; }

/* ── Responsive ── */
@media (max-width: 768px) {
  .form-layout {
    grid-template-columns: 1fr;
  }
  .details-grid {
    grid-template-columns: 1fr;
  }
  .steps-track {
    flex-direction: column;
    align-items: center;
    gap: 24px;
  }
  .step-connector {
    width: 2px;
    height: 24px;
    background: linear-gradient(180deg, #CF0A2C, transparent);
    margin: 0;
  }
  .hero-container h1 { font-size: 1.8rem; }
  .form-card { padding: 24px; }
}
</style>
