---
const disqusShortname = "mkdigital-1";
const pageIdentifier = Astro.url.pathname;
const pageUrl = Astro.url.href;
---

<section class="comments">
  <div class="container">
    <h2>Comentarios de clientes</h2>
    <p class="subtitle">
      Lee experiencias reales de personas que han confiado en nuestro soporte remoto.
    </p>

    <div id="disqus_thread"></div>
  </div>
</section>

<script is:inline define:vars={{ disqusShortname, pageIdentifier, pageUrl }}>
  var disqus_config = function () {
    this.page.url = pageUrl;
    this.page.identifier = pageIdentifier;
  };

  (function () {
    var d = document, s = d.createElement("script");
    s.src = "https://" + disqusShortname + ".disqus.com/embed.js";
    s.setAttribute("data-timestamp", +new Date());
    s.async = true;
    (d.head || d.body).appendChild(s);
  })();
</script>

<style>
.comments{
  padding:120px 0;
  background:#0b0b0b;
  border-top:1px solid rgba(255,255,255,0.05);
}

.comments h2{
  text-align:center;
  font-size:40px;
  margin-bottom:10px;
}

.subtitle{
  text-align:center;
  color:var(--muted);
  margin-bottom:50px;
  max-width:600px;
  margin-left:auto;
  margin-right:auto;
}
</style>