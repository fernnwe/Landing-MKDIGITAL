---
const disqusShortname = "mkdigital-1";
const pageIdentifier = Astro.url.pathname; 
const pageUrl = Astro.url.href;
---

<section class="comments-section">
  <div class="container">
    <div class="section-header">
      <h2>Comentarios de clientes</h2>
      <p>
        Escribe tu comentario en base a la experiencia con nosotros.
      </p>
    </div>

    <div id="disqus_thread" class="disqus-container"></div>
  </div>
</section>

<script is:inline define:vars={{ pageUrl, pageIdentifier }}>
  var disqus_config = function () {
    this.page.url = pageUrl;
    this.page.identifier = pageIdentifier;
  };

  (function() {
    var d = document, s = d.createElement('script');
    s.src = 'https://mkdigital-1.disqus.com/embed.js';
    s.setAttribute('data-timestamp', +new Date());
    s.async = true;
    (d.head || d.body).appendChild(s);
  })();
</script>

<style>
.comments-section {
  padding: 96px 0;
  background: var(--background, #0F1115);
  border-top: 1px solid rgba(255,255,255,0.06);
}

.section-header {
  text-align: center;
  margin-bottom: 40px;
}
.section-header h2 {
  font-size: 28px;
  font-weight: 600;
  margin-bottom: 8px;
}
.section-header p {
  font-size: 14px;
  color: var(--on-surface-variant);
  max-width: 480px;
  margin: 0 auto;
}

.disqus-container {
  max-width: 720px;
  margin: 0 auto;
}
</style>
