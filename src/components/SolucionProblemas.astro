---
import { Icon } from "astro-icon/components";
---

<section class="soluciones">
  <div class="container">

    <div class="header">
      <span class="badge">CENTRO DE AYUDA</span>
      <h2>Videos, descargas y soluciones paso a paso</h2>
      <p>
        Accede a demostraciones, guías y recursos para instalar,
        solucionar errores y conectar tu equipo con soporte remoto.
      </p>
    </div>

    <div class="grid">

      <!-- ⭐ VIPER POS DESTACADO -->
      <div class="card featured">
        <div class="featured-badge">⭐ DEMO DESTACADA</div>

        <div class="icon-box viper">
          <Icon name="mdi:monitor-dashboard" />
        </div>

        <span class="pill">Demo Online</span>
        <h3>Probar ViperPOS</h3>
        <p>Explora el sistema completo sin instalar nada. Acceso inmediato desde el navegador.</p>

        <a href="https://www.viperpos.net/login/" target="_blank" class="video-btn">
          Acceder a la demo <Icon name="mdi:open-in-new"/>
        </a>

        <div class="demo-cred">
          Usuario: <b>demo</b><br/>
          Contraseña: <b>demo1234</b>
        </div>
      </div>

      <!-- FACTURACION -->
      <div class="card">
        <div class="icon-box facturacion">
          <Icon name="mdi:cash-register" />
        </div>

        <span class="pill">+34 videos</span>
        <h3>Sistema de Facturación</h3>
        <p>Capacitación completa del software, módulos y flujo de trabajo real.</p>

        <a href="https://drive.google.com/drive/folders/1184xu1s4eirYN83QzL4Wfpsu_K3-Hqqs?usp=sharing" target="_blank" class="video-btn">
          Ver tutoriales <Icon name="mdi:play-circle"/>
        </a>
      </div>

      <!-- SERVIDOR AUTOCAD -->
      <div class="card">
        <div class="icon-box autocad">
          <Icon name="mdi:server-network" />
        </div>

        <span class="pill">Solución oficial</span>
        <h3>Servidor AutoCAD en Red</h3>
        <p>Guía paso a paso para corregir el error del servidor de licencias.</p>

        <a href="https://drive.google.com/file/d/1jmlTTqccF4oUPupTYNCwNW_qZrrK8CwA/view?usp=sharing" target="_blank" class="video-btn">
          Ver solución <Icon name="mdi:play-circle"/>
        </a>
      </div>

      <!-- SOPORTE REMOTO -->
      <div class="card">
        <div class="icon-box soporte">
          <Icon name="mdi:headset" />
        </div>

        <span class="pill">Soporte remoto</span>
        <h3>Conexión con AnyDesk</h3>
        <p>Aprende a instalar AnyDesk y recibir soporte inmediato.</p>

        <a href="https://drive.google.com/file/d/17cp_besLdN9NnNC1BpB9ox5oZVscdHLS/view?usp=sharing" target="_blank" class="video-btn">
          Ver guía <Icon name="mdi:play-circle"/>
        </a>
      </div>

      <!-- DEMO SOFTWARE -->
      <div class="card">
        <div class="icon-box demo">
          <Icon name="mdi:laptop" />
        </div>

        <span class="pill">Caso real</span>
        <h3>Demo del sistema</h3>
        <p>Mira el software funcionando con clientes reales.</p>

        <a href="https://drive.google.com/file/d/1KjQ6-bD081vYcvX9h4eXr96nqyow17jM/view?usp=sharing" target="_blank" class="video-btn">
          Ver demostración <Icon name="mdi:play-circle"/>
        </a>
      </div>

      <!-- DESCARGA FACTULITE -->
      <div class="card">
        <div class="icon-box descarga">
          <Icon name="mdi:cellphone-arrow-down" />
        </div>

        <span class="pill">Android</span>
        <h3>Descargar FactuLite</h3>
        <p>Instala el demo en tu celular y prueba el sistema gratis.</p>

        <a href="https://factulite.net/downloads/factulite-v1.5.0.apk" target="_blank" class="video-btn">
          Descargar demo <Icon name="mdi:download"/>
        </a>
      </div>

    </div>
  </div>
</section>

<style>
.soluciones{
  padding:130px 0;
  background:radial-gradient(circle at top,#0b141a,#050607 70%);
}

/* HEADER */
.header{
  text-align:center;
  max-width:720px;
  margin:auto;
  margin-bottom:80px;
}
.header h2{
  font-size:38px;
  margin:18px 0;
}
.header p{
  color:#9aa4ad;
  font-size:17px;
  line-height:1.6;
}

.badge{
  padding:8px 18px;
  border-radius:30px;
  background:linear-gradient(90deg,#00ffa620,#00b3c920);
  color:#00ffa6;
  font-size:.75rem;
  letter-spacing:.7px;
}

/* GRID */
.grid{
  display:grid;
  grid-template-columns:repeat(auto-fit,minmax(290px,1fr));
  gap:38px;
}

/* CARDS */
.card{
  background:rgba(255,255,255,0.03);
  border:1px solid rgba(255,255,255,.07);
  padding:40px 32px;
  border-radius:26px;
  text-align:center;
  transition:.45s;
  position:relative;
  backdrop-filter:blur(6px);
}
.card:hover{
  transform:translateY(-14px);
  border-color:#00ffa6;
  box-shadow:0 15px 50px rgba(0,255,166,.15);
}

/* FEATURED */
.featured{
  border:1px solid #00ffa6;
  box-shadow:0 0 45px rgba(0,255,166,.35);
  transform:scale(1.06);
}
.featured:hover{
  transform:scale(1.09) translateY(-10px);
  box-shadow:0 0 70px rgba(0,255,166,.55);
}

.featured-badge{
  position:absolute;
  top:16px;
  right:16px;
  background:linear-gradient(90deg,#00ffa6,#00b3c9);
  color:#000;
  font-weight:700;
  font-size:11px;
  padding:7px 13px;
  border-radius:20px;
}

/* ICON */
.icon-box{
  width:78px;
  height:78px;
  margin:auto;
  margin-bottom:20px;
  border-radius:20px;
  display:flex;
  align-items:center;
  justify-content:center;
  font-size:36px;
  color:#fff;
}

.facturacion{ background:#00c3ff; }
.autocad{ background:#2ecc71; }
.soporte{ background:#9b5cff; }
.demo{ background:#ff7a00; }
.descarga{ background:#00ffa6; }
.viper{ background:#ff4d6d; }

.pill{
  font-size:.72rem;
  background:#ffffff12;
  padding:6px 15px;
  border-radius:20px;
  color:#00ffa6;
}

/* CTA BUTTON */
.video-btn{
  display:inline-flex;
  align-items:center;
  gap:8px;
  margin-top:15px;
  padding:13px 24px;
  border-radius:12px;
  background:linear-gradient(90deg,#00ffa6,#00b3c9);
  color:#000;
  font-weight:800;
  text-decoration:none;
  letter-spacing:.3px;
  transition:.3s;
}
.video-btn:hover{
  transform:scale(1.08);
  box-shadow:0 0 25px rgba(0,255,166,.45);
}

.demo-cred{
  margin-top:16px;
  font-size:13px;
  color:#9aa4ad;
  background:#00000040;
  padding:12px;
  border-radius:12px;
}
</style>