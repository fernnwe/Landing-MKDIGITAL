---
import { Icon } from "astro-icon/components";
---

<section class="soluciones">
  <div class="container">

    <div class="header">
      <span class="badge">CENTRO DE AYUDA</span>
      <h2>Videos demostrativos, descargas y soluciones</h2>
      <p>
        Descarga nuestros software, resuelve problemas comunes
        y conectar tu equipo con nuestro soporte remoto paso a paso.
      </p>
    </div>

    <div class="grid">

      <!-- ⭐ VIPER POS DESTACADO -->
      <div class="card featured">
        <div class="featured-badge">⭐ DEMO DESTACADA</div>

        <div class="icon-box viper">
          <Icon name="mdi:monitor-dashboard" />
        </div>

        <span class="pill">Demo Online</span>
        <h3>Probar ViperPOS</h3>
        <p>Accede al sistema en línea y prueba todas sus funciones sin instalar nada.</p>

        <a href="https://www.viperpos.net/login/" target="_blank" class="video-btn">
          Abrir demo <Icon name="mdi:open-in-new"/>
        </a>

        <div class="demo-cred">
          Usuario: <b>demo</b><br/>
          Contraseña: <b>demo1234</b>
        </div>
      </div>

      <!-- FACTURACION -->
      <div class="card">
        <div class="featured-badge">+34 VIDEOS</div>
        <div class="icon-box facturacion">
          <Icon name="mdi:cash-register" />
        </div>

        <span class="pill">Tutorial</span>
        <h3>Sistema de Facturación</h3>
        <p>Guía completa del funcionamiento del software y sus módulos.</p>

        <a href="https://drive.google.com/drive/folders/1184xu1s4eirYN83QzL4Wfpsu_K3-Hqqs?usp=sharing" target="_blank" class="video-btn">
          Ver video <Icon name="mdi:play-circle"/>
        </a>
      </div>

      <!-- SERVIDOR AUTOCAD -->
      <div class="card">
        <div class="featured-badge">TODOS LOS DE AUTODESK</div>
        <div class="icon-box autocad">
          <Icon name="mdi:server-network" />
        </div>

        <span class="pill">Solución</span>
        <h3>Servidor AutoCAD en Red</h3>
        <p>Cómo resolver el error del servidor de licencias paso a paso.</p>

        <a href="https://drive.google.com/file/d/1jmlTTqccF4oUPupTYNCwNW_qZrrK8CwA/view?usp=sharing" target="_blank" class="video-btn">
          Ver video <Icon name="mdi:play-circle"/>
        </a>
      </div>

      <!-- SOPORTE REMOTO -->
      <div class="card">
        <div class="featured-badge">DESCARGA ANYDESK</div>
        <div class="icon-box soporte">
          <Icon name="mdi:headset" />
        </div>

        <span class="pill">Soporte</span>
        <h3>Conexión Remota</h3>
        <p>Aprende a descargar AnyDesk para recibir soporte inmediato.</p>

        <a href="https://drive.google.com/file/d/17cp_besLdN9NnNC1BpB9ox5oZVscdHLS/view?usp=sharing" target="_blank" class="video-btn">
          Ver video <Icon name="mdi:play-circle"/>
        </a>
      </div>

      <!-- DEMO SOFTWARE -->
      <div class="card">
        <div class="featured-badge">PARA WINDOWS</div>
        <div class="icon-box demo">
          <Icon name="mdi:laptop" />
        </div>

        <span class="pill">Demo</span>
        <h3>Demo del Software de Facturación</h3>
        <p>Mira el sistema funcionando en un caso real con clientes.</p>

        <a href="https://drive.google.com/file/d/1KjQ6-bD081vYcvX9h4eXr96nqyow17jM/view?usp=sharing" target="_blank" class="video-btn">
          Ver video <Icon name="mdi:play-circle"/>
        </a>
      </div>

      <!-- DESCARGA FACTULITE -->
      <div class="card">
        <div class="featured-badge">MÁS DESCARGADO</div>
        <div class="icon-box descarga">
          <Icon name="mdi:cellphone-arrow-down" />
        </div>

        <span class="pill">Descarga</span>
        <h3>Descargar FactuLite</h3>
        <p>Instala el demo de FactuLite en tu dispositivo Android y pruébalo gratis.</p>

        <a href="https://factulite.net/downloads/factulite-v1.5.0.apk" target="_blank" class="video-btn">
          Descargar demo <Icon name="mdi:download"/>
        </a>
      </div>

    </div>
  </div>
</section>

<style>
.soluciones{
  padding:120px 0;
  background:linear-gradient(180deg,#070707,#0a0f14);
}

.header{
  text-align:center;
  max-width:650px;
  margin:auto;
  margin-bottom:70px;
}

.badge{
  display:inline-block;
  padding:7px 18px;
  border-radius:30px;
  background:linear-gradient(90deg,#00ffa620,#00b3c920);
  color:#00ffa6;
  font-size:.75rem;
  letter-spacing:.6px;
  margin-bottom:18px;
}

.grid{
  display:grid;
  grid-template-columns:repeat(auto-fit,minmax(280px,1fr));
  gap:35px;
}

.card{
  background:rgba(255,255,255,0.03);
  border:1px solid rgba(255,255,255,.08);
  padding:35px;
  border-radius:22px;
  text-align:center;
  transition:.4s;
  position:relative;
}

.card:hover{
  transform:translateY(-12px);
  border-color:#00ffa6;
  box-shadow:0 0 35px rgba(0,255,166,.15);
}

/* ⭐ CARD DESTACADA */
.featured{
  border:1px solid #00ffa6;
  box-shadow:0 0 40px rgba(0,255,166,.35);
  transform:scale(1.05);
}

.featured:hover{
  transform:scale(1.08) translateY(-10px);
  box-shadow:0 0 60px rgba(0,255,166,.6);
}

.featured-badge{
  position:absolute;
  top:15px;
  right:15px;
  background:linear-gradient(90deg,#00ffa6,#00b3c9);
  color:#000;
  font-weight:700;
  font-size:12px;
  padding:6px 12px;
  border-radius:20px;
}

.icon-box{
  width:75px;
  height:75px;
  margin:auto;
  margin-bottom:18px;
  border-radius:18px;
  display:flex;
  align-items:center;
  justify-content:center;
  font-size:36px;
  color:#fff;
}

.facturacion{ background:#00c3ff; }
.autocad{ background:#2ecc71; }
.soporte{ background:#9b5cff; }
.demo{ background:#ff7a00; }
.descarga{ background:#00ffa6; }
.viper{ background:#ff4d6d; }

.pill{
  font-size:.7rem;
  background:#ffffff10;
  padding:5px 14px;
  border-radius:20px;
  color:#00ffa6;
}

.video-btn{
  display:inline-flex;
  align-items:center;
  gap:8px;
  padding:11px 20px;
  border-radius:10px;
  background:linear-gradient(90deg,#00ffa6,#00b3c9);
  color:#000;
  font-weight:700;
  text-decoration:none;
  transition:.3s;
}

.video-btn:hover{
  transform:scale(1.07);
  box-shadow:0 0 20px rgba(0,255,166,.4);
}

.demo-cred{
  margin-top:15px;
  font-size:13px;
  color:#bbb;
  background:#00000040;
  padding:10px;
  border-radius:10px;
}
</style>