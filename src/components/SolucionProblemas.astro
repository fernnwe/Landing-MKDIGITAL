---
import { Icon } from "astro-icon/components";
---

<section class="soluciones">
  <div class="container">

    <h2>Videos demostrativos y soluciones</h2>
    <p class="subtitle">
      Resuelve tus dudas con estos videos.
    </p>

    <div class="grid">

      <!-- FACTURACION -->
      <div class="card">
        <div class="icon-box facturacion">
          <Icon name="mdi:cash-register" />
        </div>

        <h3>Sistema de Facturación</h3>
        <p>
          Material de uso sobre el funcionamiento del software.
        </p>

        <!-- AQUI PEGAS EL LINK DEL VIDEO -->
        <a href="https://drive.google.com/drive/folders/1184xu1s4eirYN83QzL4Wfpsu_K3-Hqqs?usp=sharing" target="_blank" class="video-btn">
          Ver video
          <Icon name="mdi:play-circle"/>
        </a>
      </div>

      <!-- SERVIDOR AUTOCAD -->
      <div class="card">
        <div class="icon-box autocad">
          <Icon name="mdi:server-network" />
        </div>

        <h3>Servidor AutoCAD en Red</h3>
        <p>
          Solucición al problema del servidor de autocad
        </p>

        <!-- AQUI PEGAS EL LINK -->
        <a href="https://drive.google.com/file/d/1jmlTTqccF4oUPupTYNCwNW_qZrrK8CwA/view?usp=sharing" target="_blank" class="video-btn">
          Ver video
          <Icon name="mdi:play-circle"/>
        </a>
      </div>

      <!-- SOPORTE REMOTO -->
      <div class="card">
        <div class="icon-box soporte">
          <Icon name="mdi:headset" />
        </div>

        <h3>Soporte remoto empresarial</h3>
        <p>
          Descarga anydesk para conectarnos remotamente
        </p>

        <!-- AQUI PEGAS EL LINK -->
        <a href="https://drive.google.com/file/d/17cp_besLdN9NnNC1BpB9ox5oZVscdHLS/view?usp=sharing" target="_blank" class="video-btn">
          Ver video
          <Icon name="mdi:play-circle"/>
        </a>
      </div>

      <!-- INSTALACIONES MASIVAS -->
      <div class="card">
        <div class="icon-box instalaciones">
          <Icon name="mdi:laptop" />
        </div>

        <h3>Video demostrativo del software de facturación</h3>
        <p>
          Aqui puedes ver el video demostrativo.
        </p>

        <!-- AQUI PEGAS EL LINK -->
        <a href="https://drive.google.com/file/d/1KjQ6-bD081vYcvX9h4eXr96nqyow17jM/view?usp=sharing" target="_blank" class="video-btn">
          Ver video
          <Icon name="mdi:play-circle"/>
        </a>
      </div>

    </div>
  </div>
</section>

<style>
.soluciones{
  padding:120px 0;
  background:#070707;
}

.soluciones h2{
  text-align:center;
  font-size:44px;
  margin-bottom:10px;
}

.subtitle{
  text-align:center;
  color:#aaa;
  margin-bottom:70px;
}

.grid{
  display:grid;
  grid-template-columns:repeat(auto-fit,minmax(280px,1fr));
  gap:35px;
}

/* CARD */
.card{
  background:rgba(255,255,255,0.03);
  border:1px solid rgba(255,255,255,.08);
  padding:35px;
  border-radius:22px;
  text-align:center;
  transition:.35s;
}

.card:hover{
  transform:translateY(-10px);
  border-color:#00ffa6;
  box-shadow:0 0 30px rgba(0,255,166,.18);
}

/* ICON BOX */
.icon-box{
  width:70px;
  height:70px;
  margin:auto;
  margin-bottom:20px;
  border-radius:18px;
  display:flex;
  align-items:center;
  justify-content:center;
  font-size:34px;
  color:#fff;
}

/* COLORES */
.facturacion{ background:#00c3ff; }
.autocad{ background:#2ecc71; }
.soporte{ background:#9b5cff; }
.instalaciones{ background:#ff7a00; }

/* TEXT */
.card h3{
  font-size:22px;
  margin-bottom:12px;
}

.card p{
  color:#aaa;
  font-size:15px;
  margin-bottom:25px;
}

/* VIDEO BUTTON */
.video-btn{
  display:inline-flex;
  align-items:center;
  gap:8px;
  padding:10px 18px;
  border-radius:10px;
  background:#00ffa6;
  color:#000;
  font-weight:700;
  text-decoration:none;
  transition:.3s;
}

.video-btn:hover{
  transform:scale(1.05);
}
</style>