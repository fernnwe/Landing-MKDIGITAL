<section class="section growth-section" id="crecimiento">
  <div class="container">

    <div class="section-header">
      <span class="badge reveal reveal-up">NUESTROS RESULTADOS</span>
      <h2 class="reveal reveal-up stagger-1">Crecimiento constante desde 2023</h2>
      <p class="reveal reveal-up stagger-2">
        Cada mes ayudamos a más clientes en toda Nicaragua con instalaciones
        remotas rápidas y seguras.
      </p>
    </div>

    <div class="growth-stats-grid">
      <div class="card glow-card growth-stat-card reveal reveal-up stagger-3">
        <h3 data-target="520">0</h3>
        <span>Instalaciones realizadas</span>
      </div>

      <div class="card glow-card growth-stat-card reveal reveal-up stagger-4">
        <h3 data-target="340">0</h3>
        <span>Clientes atendidos</span>
      </div>

      <div class="card glow-card growth-stat-card reveal reveal-up stagger-5">
        <h3 data-target="4.9">0</h3>
        <span>Calificación promedio</span>
      </div>

      <div class="card glow-card growth-stat-card reveal reveal-up stagger-6">
        <h3 data-target="18">0</h3>
        <span>Meses creciendo</span>
      </div>
    </div>

    <div class="card chart-container reveal reveal-up stagger-7">
      <h3>Crecimiento mensual de servicios</h3>

      <div class="chart" id="chart">
        <div class="bar-group">
          <div class="bar" data-value="15"></div>
          <span>2023</span>
        </div>
        <div class="bar-group">
          <div class="bar" data-value="25"></div>
          <span>Mar 23</span>
        </div>
        <div class="bar-group">
          <div class="bar" data-value="40"></div>
          <span>Jun 23</span>
        </div>
        <div class="bar-group">
          <div class="bar" data-value="60"></div>
          <span>Sep 23</span>
        </div>
        <div class="bar-group">
          <div class="bar" data-value="80"></div>
          <span>Dic 23</span>
        </div>
        <div class="bar-group">
          <div class="bar" data-value="100"></div>
          <span>Mar 24</span>
        </div>
        <div class="bar-group">
          <div class="bar" data-value="120"></div>
          <span>Jun 24</span>
        </div>
        <div class="bar-group">
          <div class="bar" data-value="140"></div>
          <span>Sep 24</span>
        </div>
