  display: grid;
  grid-template-columns: repeat(auto-fit, minmax(200px, 1fr));
  gap: 24px;
}

.stat-card {
  background: var(--surface-container-high, #1C1D22);
  border-radius: var(--shape-lg);
  padding: 40px 24px;
  box-shadow: var(--elevation-1);
