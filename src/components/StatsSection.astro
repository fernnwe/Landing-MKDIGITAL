}
.stat-card:hover {
  box-shadow: var(--elevation-2);
  transform: translateY(-2px);
}

.stat-number {
  font-size: 48px;
  font-weight: 700;
  color: var(--primary);
  line-height: 1.1;
  margin-bottom: 8px;
}

.stat-label {
  font-size: 14px;
  color: var(--on-surface-variant);
  font-weight: 500;
}

@media (max-width: 600px) {
  .stats-section { padding: 72px 0; }
