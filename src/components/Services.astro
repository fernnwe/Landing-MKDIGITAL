---
import { Icon } from "astro-icon/components";
---

<section id="servicios" class="section services-section">
  <div class="container">

    <div class="section-header">
      <span class="badge">SERVICIOS TECNOLÓGICOS</span>
      <h2>Nuestros Servicios</h2>
      <p>Soluciones digitales, software y soporte técnico para impulsar tu negocio.</p>
    </div>

    <div class="grid">

      <!-- WINDOWS -->
      <div class="card service-card">
        <div class="icon-wrap">
          <Icon name="mdi:microsoft-windows" />
        </div>
        <h3>Licencias Windows</h3>
        <p>Windows 10 y 11 Home & Pro • Licencias OEM originales</p>
      </div>

      <!-- OFFICE -->
      <div class="card service-card">
        <div class="icon-wrap">
          <Icon name="mdi:microsoft-office" />
        </div>
        <h3>Microsoft Office</h3>
        <p>Office 2019, 2021 y 2024 con instalación remota</p>
      </div>

      <!-- ADOBE -->
      <div class="card service-card">
        <div class="icon-wrap">
          <Icon name="mdi:adobe" />
        </div>
        <h3>Programas de Adobe</h3>
        <p>Photoshop, Illustrator, Premiere y más</p>
      </div>

      <!-- AUTODESK -->
      <div class="card service-card">
        <div class="icon-wrap">
          <Icon name="mdi:cube-scan" />
        </div>
        <h3>Programas de Autodesk</h3>
        <p>AutoCAD, Revit y Civil 3D</p>
      </div>

      <!-- ANTIVIRUS -->
      <div class="card service-card">
        <div class="icon-wrap">
          <Icon name="mdi:shield-check" />
        </div>
        <h3>Avast Premium</h3>
        <p>Licencia de 1 año</p>
      </div>

      <!-- WEB -->
      <div class="card service-card">
        <div class="icon-wrap">
          <Icon name="mdi:web" />
        </div>
        <h3>Desarrollo Web</h3>
        <p>Sitios modernos, rápidos y optimizados hechos a medida</p>
      </div>

      <!-- FACTURACION -->
      <div class="card service-card">
        <div class="icon-wrap">
          <Icon name="mdi:cash-register" />
        </div>
        <h3>Software de Facturación</h3>
        <p>FactuLite & ViperPOS de Alpha Tech Nicaragua</p>
      </div>

      <!-- OPTIMIZACION -->
      <div class="card service-card">
        <div class="icon-wrap">
          <Icon name="mdi:rocket-launch" />
        </div>
        <h3>Optimización de PC</h3>
        <p>Drivers, limpieza y mejora de rendimiento</p>
      </div>

    </div>

  </div>
</section>

<style>

/* Fondo suave */
.services-section{
  background: radial-gradient(circle at 10% 20%, #00B3C910 0%, transparent 40%),
              radial-gradient(circle at 90% 80%, #1ED6E610 0%, transparent 40%);
}

.section-header{
  text-align:center;
  max-width:700px;
  margin:0 auto 70px;
}

.section-header h2{
  font-size:2.2rem;
  margin-bottom:15px;
}

.section-header p{
  color:var(--muted);
}

.badge{
  display:inline-block;
  background:linear-gradient(90deg,#00B3C920,#1ED6E620);
  color:var(--accent);
  padding:7px 18px;
  border-radius:30px;
  font-size:.75rem;
  letter-spacing:.5px;
  margin-bottom:18px;
}

.grid{
  display:grid;
  grid-template-columns:repeat(auto-fit,minmax(260px,1fr));
  gap:30px;
}

.service-card{
  background:rgba(255,255,255,0.03);
  backdrop-filter: blur(12px);
  padding:40px 30px;
  border-radius:20px;
  text-align:center;
  border:1px solid rgba(255,255,255,0.06);
  transition:.35s;
  position:relative;
  overflow:hidden;
}

.service-card::before{
  content:"";
  position:absolute;
  inset:0;
  background:linear-gradient(120deg,transparent,#00B3C920,transparent);
  opacity:0;
  transition:.4s;
}

.service-card:hover{
  transform:translateY(-10px);
  border:1px solid rgba(0,179,201,.35);
  box-shadow:0 20px 40px rgba(0,0,0,.35);
}

.service-card:hover::before{
  opacity:1;
}

.icon-wrap{
  width:75px;
  height:75px;
  border-radius:50%;
  background:linear-gradient(135deg,#00B3C930,#1ED6E630);
  display:flex;
  align-items:center;
  justify-content:center;
  margin:0 auto 22px;
  box-shadow:0 0 25px #00b3c930;
}

.icon-wrap svg{
  width:38px;
  height:38px;
  color:var(--accent);
}

.service-card h3{
  margin-bottom:10px;
  font-size:1.35rem;
}

.service-card p{
  color:var(--muted);
  line-height:1.6;
  font-size:.95rem;
}

</style>