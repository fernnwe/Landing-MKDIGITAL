---
import { Icon } from "astro-icon/components";
---

<section id="servicios" class="section services-section">
  <div class="container">

    <div class="section-header reveal reveal-up">
      <span class="badge">SERVICIOS TECNOLÓGICOS</span>
      <h2>Soluciones completas para tu computadora y negocio</h2>
      <p>
        Instalación de software, optimización y desarrollo web profesional
        con soporte remoto en toda Nicaragua.
      </p>
    </div>

    <div class="os-bar reveal reveal-up stagger-2">
      <div class="os-chip">
        <Icon name="mdi:microsoft-windows" />
        <span>Windows</span>
      </div>
      <div class="os-divider"></div>
      <div class="os-chip soon">
        <Icon name="mdi:apple" />
        <span>macOS • Próximamente</span>
      </div>
    </div>

    <div class="services-grid">

      <div class="service-card reveal reveal-up stagger-1">
        <div class="service-icon"><Icon name="mdi:microsoft-windows" /></div>
        <h3>Licencias Windows</h3>
        <p>Windows 10 y 11 Home & Pro. Licencias originales y genericas</p>
      </div>

      <div class="service-card reveal reveal-up stagger-2">
        <div class="service-icon"><Icon name="mdi:microsoft-office" /></div>
        <h3>Microsoft Office</h3>
        <p>Office 2019, 2021 y 2024. Licencias originales y genericas</p>
      </div>

      <div class="service-card reveal reveal-up stagger-3">
        <div class="service-icon"><Icon name="mdi:adobe" /></div>
        <h3>Programas de Adobe</h3>
        <p>Photoshop, Illustrator, Premiere, After Effects y más.</p>
      </div>

      <div class="service-card reveal reveal-up stagger-4">
        <div class="service-icon"><Icon name="mdi:cube-scan" /></div>
        <h3>Software Autodesk</h3>
        <p>AutoCAD, Revit y Civil 3D instalados.</p>
      </div>

      <div class="service-card reveal reveal-up stagger-5">
        <div class="service-icon"><Icon name="mdi:shield-check" /></div>
        <h3>Antivirus Premium</h3>
        <p>Protección completa contra virus y malware.</p>
      </div>

      <div class="service-card reveal reveal-up stagger-6">
        <div class="service-icon"><Icon name="mdi:web" /></div>
        <h3>Desarrollo Web</h3>
        <p>Páginas modernas, rápidas y optimizadas para tu negocio.</p>
      </div>

      <div class="service-card reveal reveal-up stagger-7">
        <div class="service-icon"><Icon name="mdi:cash-register" /></div>
        <h3>Software de Facturación</h3>
        <p>FactuLite & ViperPOS desarrollados por AlphaTech.</p>
      </div>

      <div class="service-card reveal reveal-up stagger-8">
        <div class="service-icon"><Icon name="mdi:rocket-launch" /></div>
        <h3>Optimización de PC</h3>
        <p>Limpieza, drivers y mejora de rendimiento.</p>
      </div>

    </div>

  </div>
</section>

<style>
.services-section {
  position: relative;
  background: var(--surface-container);
}

.os-bar {
  display: flex;
  justify-content: center;
  align-items: center;
  gap: 16px;
  margin-bottom: 48px;
}

.os-chip {
  display: flex;
  align-items: center;
  gap: 8px;
  padding: 8px 16px;
  border-radius: var(--shape-full);
  background: var(--surface-container-high);
  border: 1px solid var(--outline-variant);
  font-size: 13px;
  font-weight: 500;
  color: var(--on-surface);
}
.os-chip svg { width: 18px; height: 18px; color: var(--primary); }
.os-chip.soon { opacity: 0.5; }

.os-divider {
  width: 1px;
  height: 24px;
  background: linear-gradient(180deg, transparent, var(--outline-variant), transparent);
}

.services-grid {
  display: grid;
  grid-template-columns: repeat(auto-fit, minmax(250px, 1fr));
  gap: 20px;
}

.service-card {
  background: var(--surface-container-high);
  border-radius: var(--shape-lg);
  padding: 32px 24px;
  box-shadow: var(--elevation-0);
  border: 1px solid transparent;
  transition: box-shadow 0.3s cubic-bezier(0.2, 0, 0, 1),
              transform 0.3s cubic-bezier(0.2, 0, 0, 1),
              border-color 0.3s ease;
  text-align: center;
}
.service-card:hover {
  box-shadow: var(--elevation-3);
  transform: translateY(-4px);
  border-color: rgba(129, 140, 248, 0.15);
}

.service-icon {
  width: 52px;
  height: 52px;
  border-radius: var(--shape-md);
  background: rgba(129, 140, 248, 0.1);
  display: flex;
  align-items: center;
  justify-content: center;
  margin: 0 auto 16px;
}
.service-icon svg { width: 26px; height: 26px; color: var(--primary); }

.service-card h3 { font-size: 16px; font-weight: 600; margin-bottom: 8px; }
.service-card p { font-size: 13px; line-height: 1.6; }

@media (max-width: 768px) {
  .services-grid { grid-template-columns: 1fr 1fr; }
}
@media (max-width: 600px) {
  .services-grid { grid-template-columns: 1fr; }
}
</style>
