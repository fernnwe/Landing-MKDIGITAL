---
import { Icon } from "astro-icon/components";
---

<section id="servicios" class="section services-section">
  <div class="container">

    <div class="section-header">
      <span class="badge">SERVICIOS TECNOLÓGICOS</span>
      <h2>Soluciones completas para tu computadora y negocio</h2>
      <p>
        Instalación de software, optimización y desarrollo web profesional
        con soporte remoto en toda Nicaragua.
      </p>
    </div>

    <div class="os-bar">
      <div class="os-chip">
        <Icon name="mdi:microsoft-windows" />
        <span>Windows</span>
      </div>
      <div class="os-divider"></div>
      <div class="os-chip soon">
        <Icon name="mdi:apple" />
        <span>macOS • Próximamente</span>
      </div>
    </div>

    <div class="services-grid">

      <div class="service-card">
        <div class="service-icon"><Icon name="mdi:microsoft-windows" /></div>
        <h3>Licencias Windows</h3>
        <p>Windows 10 y 11 Home & Pro. Licencias originales y genericas</p>
      </div>

      <div class="service-card">
        <div class="service-icon"><Icon name="mdi:microsoft-office" /></div>
        <h3>Microsoft Office</h3>
        <p>Office 2019, 2021 y 2024. Licencias originales y genericas</p>
      </div>

      <div class="service-card">
        <div class="service-icon"><Icon name="mdi:adobe" /></div>
        <h3>Programas de Adobe</h3>
        <p>Photoshop, Illustrator, Premiere, After Effects y más.</p>
      </div>

      <div class="service-card">
        <div class="service-icon"><Icon name="mdi:cube-scan" /></div>
        <h3>Software Autodesk</h3>
        <p>AutoCAD, Revit y Civil 3D instalados.</p>
      </div>

      <div class="service-card">
        <div class="service-icon"><Icon name="mdi:shield-check" /></div>
        <h3>Antivirus Premium</h3>
        <p>Protección completa contra virus y malware.</p>
      </div>

      <div class="service-card">
        <div class="service-icon"><Icon name="mdi:web" /></div>
        <h3>Desarrollo Web</h3>
        <p>Páginas modernas, rápidas y optimizadas para tu negocio.</p>
      </div>

      <div class="service-card">
        <div class="service-icon"><Icon name="mdi:cash-register" /></div>
        <h3>Software de Facturación</h3>
        <p>FactuLite & ViperPOS desarrollados por AlphaTech.</p>
      </div>

      <div class="service-card">
        <div class="service-icon"><Icon name="mdi:rocket-launch" /></div>
        <h3>Optimización de PC</h3>
        <p>Limpieza, drivers y mejora de rendimiento.</p>
      </div>

    </div>

  </div>
</section>

<style>
/* MD3 Services */
.services-section {
  position: relative;
  background: var(--surface-container, #17191E);
}

.os-bar {
  display: flex;
  justify-content: center;
  align-items: center;
  gap: 16px;
  margin-bottom: 48px;
}

.os-chip {
  display: flex;
  align-items: center;
  gap: 8px;
  padding: 8px 16px;
  border-radius: var(--shape-full);
  background: var(--surface-container-high);
  border: 1px solid var(--outline-variant);
  font-size: 13px;
  font-weight: 500;
  color: var(--on-surface);
}
.os-chip svg { width: 18px; height: 18px; color: var(--primary); }

.os-chip.soon { opacity: 0.5; }

.os-divider {
  width: 1px;
  height: 24px;
  background: var(--outline-variant);
}

.services-grid {
  display: grid;
  grid-template-columns: repeat(auto-fit, minmax(250px, 1fr));
  gap: 20px;
}

.service-card {
  background: var(--surface-container-high, #1C1D22);
  border-radius: var(--shape-lg);
  padding: 28px 24px;
  box-shadow: var(--elevation-0);
  transition: box-shadow 0.2s ease, transform 0.2s ease;
  text-align: center;
}
.service-card:hover {
  box-shadow: var(--elevation-2);
  transform: translateY(-2px);
}

.service-icon {
  width: 48px;
  height: 48px;
  border-radius: var(--shape-md);
  background: var(--primary-container);
  display: flex;
  align-items: center;
  justify-content: center;
  margin: 0 auto 16px;
}
.service-icon svg {
  width: 24px;
  height: 24px;
  color: var(--primary);
}

.service-card h3 {
  font-size: 16px;
  font-weight: 600;
  margin-bottom: 8px;
}

.service-card p {
  font-size: 13px;
  line-height: 1.5;
}

@media (max-width: 768px) {
  .services-grid { grid-template-columns: 1fr 1fr; }
}

@media (max-width: 600px) {
  .services-grid { grid-template-columns: 1fr; }
}
</style>
