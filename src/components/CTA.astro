---
import { Icon } from "astro-icon/components";
---

<section id="cta-section" class="cta-section">
  <div class="container">

    <div class="cta-grid">

      <!-- LEFT -->
      <div class="cta-content">

        <div class="badge pulse">
          <Icon name="mdi:headset" />
          SOPORTE DISPONIBLE AHORA
        </div>

        <h2>
          Tu computadora lista  
          <span>hoy mismo</span>
        </h2>

        <p class="cta-desc">
          Instalamos programas, optimizamos tu PC y solucionamos errores en minutos.
          Atención remota inmediata en toda Nicaragua.
        </p>

        <div class="cta-benefits">

          <div class="cta-benefit">
            <div class="benefit-icon"><Icon name="mdi:bolt" /></div>
            <div>
              <strong>Respuesta rápida</strong>
              <span>Promedio de 15 minutos</span>
            </div>
          </div>

          <div class="cta-benefit">
            <div class="benefit-icon"><Icon name="mdi:shield-half-full" /></div>
            <div>
              <strong>Conexión segura</strong>
              <span>Sesión supervisada en todo momento</span>
            </div>
          </div>

          <div class="cta-benefit">
            <div class="benefit-icon"><Icon name="mdi:star" /></div>
            <div>
              <strong>Clientes satisfechos</strong>
              <span>Calificación promedio 4.9</span>
            </div>
          </div>

        </div>

        <a href="https://wa.me/50581088124" target="_blank" class="btn-primary">
          <Icon name="simple-icons:whatsapp" />
          Solicitar soporte ahora
          <span class="cta-arrow"><Icon name="mdi:arrow-right" /></span>
        </a>

        <div class="cta-trust">
          <Icon name="mdi:check-circle-outline" />
          Más de <strong>500 instalaciones remotas</strong> completadas con éxito
        </div>

      </div>

      <!-- RIGHT -->
      <div class="cta-card-wrapper">
        <div class="cta-card">

          <h3><Icon name="mdi:credit-card" /> Métodos de pago</h3>

          <div class="banks">
            <span class="bank-chip"><Icon name="mdi:bank" /> BANPRO</span>
            <span class="bank-chip"><Icon name="mdi:bank" /> BAC</span>
            <span class="bank-chip"><Icon name="mdi:bank" /> LAFISE</span>
          </div>

          <div class="secure-note">
            <Icon name="mdi:lock" />
            Transferencias y depósitos verificados
          </div>

        </div>
      </div>

    </div>
  </div>
</section>

<style>
/* MD3 CTA Section */
.cta-section {
  padding: 96px 0;
  position: relative;
  overflow: hidden;
  background: linear-gradient(180deg, var(--background) 0%, var(--surface-container-low) 100%);
}

.cta-grid {
  display: grid;
  grid-template-columns: 1.1fr 0.9fr;
  gap: 64px;
  align-items: center;
}

.cta-content .badge { margin-bottom: 16px; }

.pulse { animation: pulse 2s infinite ease; }
@keyframes pulse {
  0% { box-shadow: 0 0 0 0 rgba(0, 179, 201, 0.3); }
  70% { box-shadow: 0 0 0 12px rgba(0, 179, 201, 0); }
  100% { box-shadow: 0 0 0 0 rgba(0, 179, 201, 0); }
}

.cta-content h2 {
  font-size: clamp(28px, 3.5vw, 42px);
  font-weight: 700;
  line-height: 1.1;
  margin-bottom: 20px;
}
.cta-content h2 span { color: var(--primary); }

.cta-desc {
  font-size: 15px;
  max-width: 480px;
  margin-bottom: 32px;
  line-height: 1.6;
}

.cta-benefits {
  display: flex;
  flex-direction: column;
  gap: 12px;
  margin-bottom: 32px;
}

.cta-benefit {
  display: flex;
  align-items: center;
  gap: 12px;
}

.benefit-icon {
  width: 36px;
  height: 36px;
  min-width: 36px;
  border-radius: var(--shape-sm);
  background: var(--primary-container);
  display: flex;
  align-items: center;
  justify-content: center;
  color: var(--primary);
}

.benefit-icon svg { width: 14px; height: 14px; }

.cta-benefit strong {
  display: block;
  font-size: 14px;
  font-weight: 600;
  color: var(--on-surface);
}
.cta-benefit span {
  font-size: 12px;
  color: var(--on-surface-variant);
}

.cta-arrow { transition: transform 0.2s ease; }
.cta-section .btn-primary:hover .cta-arrow { transform: translateX(4px); }
.cta-section .btn-primary { gap: 12px; padding: 14px 32px; font-size: 15px; font-weight: 600; }

.cta-trust {
  margin-top: 24px;
  font-size: 13px;
  color: var(--on-surface-variant);
}
.cta-trust svg { color: var(--primary); margin-right: 6px; }
.cta-trust strong { color: var(--on-surface); }

/* Right card */
.cta-card-wrapper { position: relative; }

.cta-card {
  background: var(--surface-container-high, #1C1D22);
  border-radius: var(--shape-xl);
  padding: 32px;
  box-shadow: var(--elevation-3);
  border: 1px solid rgba(255,255,255,0.06);
}

.cta-card h3 {
  font-size: 18px;
  font-weight: 600;
  margin-bottom: 20px;
  display: flex;
  align-items: center;
  gap: 10px;
}
.cta-card h3 svg { color: var(--primary); }

.banks {
  display: flex;
  flex-wrap: wrap;
  gap: 10px;
  margin-bottom: 24px;
}

.bank-chip {
  display: inline-flex;
  align-items: center;
  gap: 8px;
  padding: 8px 16px;
  border-radius: var(--shape-full);
  background: var(--surface-container, #17191E);
  border: 1px solid var(--outline-variant);
  font-size: 13px;
  font-weight: 500;
  color: var(--on-surface);
}
.bank-chip svg { color: var(--primary); }

.secure-note {
  font-size: 13px;
  color: var(--on-surface-variant);
  display: flex;
  align-items: center;
  gap: 8px;
}
.secure-note svg { color: var(--primary); }

@media (max-width: 900px) {
  .cta-grid {
    grid-template-columns: 1fr;
    gap: 48px;
    text-align: center;
  }
  .cta-desc { margin: 0 auto 32px; }
  .cta-benefits { align-items: center; }
  .cta-section .btn-primary { width: 100%; justify-content: center; }
  .banks { justify-content: center; }
  .secure-note { justify-content: center; }
}
</style>
