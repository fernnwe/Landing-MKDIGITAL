---
import { Icon } from "astro-icon/components";
---

<section class="works">
  <div class="container">

    <h2 class="section-title">Trabajos realizados recientemente</h2>
    <p class="section-subtitle">
      Instalaciones reales hechas a clientes en toda Nicaragua
    </p>

    <div class="works-grid">

      <!-- TRABAJO 1 -->
      <div class="work-card">
        <div class="image-wrapper">
          <img src="/trabajos/trabajo1.jpg" alt="Office instalado">
          <div class="overlay">
            <Icon name="mdi:check-decagram" />
            <span>Instalación completada</span>
          </div>
        </div>

        <div class="work-info">
          <h3>Microsoft Office 2021</h3>
          <div class="meta">
            <span><Icon name="mdi:map-marker" /> León</span>
            <span><Icon name="mdi:clock-outline" /> 20 min</span>
          </div>
        </div>
      </div>

      <!-- TRABAJO 2 -->
      <div class="work-card">
        <div class="image-wrapper">
          <img src="/trabajos/trabajo2.jpg" alt="AutoCAD instalado">
          <div class="overlay">
            <Icon name="mdi:check-decagram" />
            <span>AutoCAD funcionando</span>
          </div>
        </div>

        <div class="work-info">
          <h3>Instalación AutoCAD 2026</h3>
          <div class="meta">
            <span><Icon name="mdi:map-marker" /> Managua</span>
            <span><Icon name="mdi:clock-outline" /> 35 min</span>
          </div>
        </div>
      </div>

      <!-- TRABAJO 3 -->
      <div class="work-card">
        <div class="image-wrapper">
          <img src="/trabajos/trabajo3.jpg" alt="Photoshop instalado">
          <div class="overlay">
            <Icon name="mdi:check-decagram" />
            <span>Adobe listo para usar</span>
          </div>
        </div>

        <div class="work-info">
          <h3>Adobe Photoshop 2023</h3>
          <div class="meta">
            <span><Icon name="mdi:map-marker" /> Estelí</span>
            <span><Icon name="mdi:clock-outline" /> 25 min</span>
          </div>
        </div>
      </div>

      <!-- TRABAJO 4 -->
      <div class="work-card">
        <div class="image-wrapper">
          <img src="/trabajos/antivirus.jpeg" alt="McAfee instalado">
          <div class="overlay">
            <Icon name="mdi:check-decagram" />
            <span>Antivirus instalado correctamente</span>
          </div>
        </div>

        <div class="work-info">
          <h3>Instalación Antivirus McAfee</h3>
          <div class="meta">
            <span><Icon name="mdi:map-marker" /> Managua</span>
            <span><Icon name="mdi:clock-outline" /> 15 min</span>
          </div>
        </div>
      </div>

    </div>
  </div>
</section>

<style>
.works{
  padding:80px 0;
  background:#0f172a;
}

/* TITULOS */
.section-title{
  text-align:center;
  font-size:34px;
  font-weight:800;
  color:#ffffff;
}

.section-subtitle{
  text-align:center;
  color:#94a3b8;
  margin-top:10px;
  margin-bottom:50px;
}

/* GRID */
.works-grid{
  display:grid;
  grid-template-columns:repeat(auto-fit,minmax(260px,1fr));
  gap:30px;
}

/* CARD */
.work-card{
  background:#111827;
  border-radius:18px;
  overflow:hidden;
  border:1px solid rgba(255,255,255,.05);
  transition:all .35s ease;
  position:relative;
}

.work-card:hover{
  transform:translateY(-10px);
  box-shadow:0 25px 50px rgba(0,0,0,.45);
  border:1px solid rgba(0,255,166,.2);
}

/* IMAGEN */
.image-wrapper{
  position:relative;
  height:180px;
  overflow:hidden;
}

.image-wrapper img{
  width:100%;
  height:100%;
  object-fit:cover;
  transition:transform .5s ease;
}

.work-card:hover img{
  transform:scale(1.08);
}

/* OVERLAY HOVER */
.overlay{
  position:absolute;
  inset:0;
  background:rgba(0,0,0,.70);
  backdrop-filter:blur(2px);
  display:flex;
  flex-direction:column;
  align-items:center;
  justify-content:center;
  color:#00ffa6;
  font-weight:700;
  opacity:0;
  transition:.35s;
}

.overlay svg{
  font-size:42px;
  margin-bottom:8px;
}

.image-wrapper:hover .overlay{
  opacity:1;
}

/* INFO */
.work-info{
  padding:20px;
}

.work-info h3{
  color:#ffffff;
  margin-bottom:12px;
  font-size:18px;
}

/* META */
.meta{
  display:flex;
  justify-content:space-between;
  font-size:14px;
  color:#94a3b8;
}

.meta span{
  display:flex;
  align-items:center;
  gap:6px;
}
</style>