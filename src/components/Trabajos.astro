---
import { Icon } from "astro-icon/components";

const trabajos = [
  {
    img: "/trabajos/trabajo1.jpg",
    titulo: "Instalación AutoCAD 2026",
    ciudad: "Jinotega",
    tiempo: "30 min",
    badge: "Autodesk instalado correctamente"
  },
  {
    img: "/trabajos/trabajo2.jpg",
    titulo: "Instalación Office 2024",
    ciudad: "Managua",
    tiempo: "20 min",
    badge: "Office listo para usar"
  },
  {
    img: "/trabajos/trabajo3.jpg",
    titulo: "Instalación Adobe Illustrator",
    ciudad: "Managua",
    tiempo: "25 min",
    badge: "Adobe activado"
  },
  {
    img: "/trabajos/antivirus.jpeg",
    titulo: "Instalación Antivirus McAfee",
    ciudad: "Managua",
    tiempo: "15 min",
    badge: "Equipo protegido"
  }
];
---

<section class="works">
  <div class="container">

    <h2 class="title">Instalaciones reales realizadas</h2>
    <p class="subtitle">
      Clientes satisfechos en toda Nicaragua • Resultados verificados
    </p>

    <div class="grid">
      {trabajos.map(t => (
        <article class="card">

          <div class="imgBox">
            <img src={t.img} alt={t.titulo} loading="lazy">

            <div class="status">
              <Icon name="mdi:check-decagram" />
              Instalación completada
            </div>

            <div class="overlay">
              <Icon name="mdi:shield-check" />
              <span>{t.badge}</span>
            </div>
          </div>

          <div class="content">
            <h3>{t.titulo}</h3>

            <div class="meta">
              <span>
                <Icon name="mdi:map-marker" /> {t.ciudad}
              </span>

              <span>
                <Icon name="mdi:clock-outline" /> {t.tiempo}
              </span>
            </div>

          </div>

        </article>
      ))}
    </div>

  </div>
</section>

<style>
.works{
  padding:120px 0;
  background:linear-gradient(180deg,#0b1220,#020617);
}

/* TITULOS */
.title{
  text-align:center;
  font-size:42px;
  font-weight:800;
  color:#fff;
}

.subtitle{
  text-align:center;
  color:#94a3b8;
  margin-top:10px;
  margin-bottom:70px;
}

/* GRID */
.grid{
  display:grid;
  grid-template-columns:repeat(auto-fit,minmax(280px,1fr));
  gap:35px;
}

/* CARD */
.card{
  background:#0f172a;
  border-radius:20px;
  overflow:hidden;
  border:1px solid rgba(255,255,255,.05);
  transition:.35s;
  box-shadow:0 10px 35px rgba(0,0,0,.35);
}

.card:hover{
  transform:translateY(-12px);
  box-shadow:0 35px 80px rgba(0,0,0,.6);
  border:1px solid rgba(0,255,166,.25);
}

/* IMAGEN */
.imgBox{
  position:relative;
  height:200px;
  overflow:hidden;
}

.imgBox img{
  width:100%;
  height:100%;
  object-fit:cover;
  transition:transform .6s ease;
}

.card:hover img{
  transform:scale(1.1);
}

/* BADGE SUPERIOR */
.status{
  position:absolute;
  top:12px;
  left:12px;
  background:#00ffa6;
  color:#022c22;
  padding:6px 12px;
  font-size:12px;
  font-weight:700;
  border-radius:30px;
  display:flex;
  align-items:center;
  gap:6px;
}

/* OVERLAY */
.overlay{
  position:absolute;
  inset:0;
  background:rgba(2,6,23,.85);
  backdrop-filter:blur(3px);
  display:flex;
  flex-direction:column;
  align-items:center;
  justify-content:center;
  gap:10px;
  color:#00ffa6;
  font-weight:700;
  opacity:0;
  transition:.35s;
}

.overlay svg{
  font-size:40px;
}

.imgBox:hover .overlay{
  opacity:1;
}

/* CONTENIDO */
.content{
  padding:22px;
}

.content h3{
  color:#fff;
  font-size:19px;
  margin-bottom:14px;
}

/* META */
.meta{
  display:flex;
  justify-content:space-between;
  color:#94a3b8;
  font-size:14px;
}

.meta span{
  display:flex;
  align-items:center;
  gap:6px;
}

/* RESPONSIVE */
@media(max-width:768px){
  .title{font-size:30px}
  .works{padding:90px 0}
}
</style>