---
import { Icon } from "astro-icon/components";

const trabajos = [
  {
    img: "/trabajos/trabajo1.jpg",
    titulo: "Instalación AutoCAD 2026",
    ciudad: "Jinotega",
    tiempo: "30 min",
    badge: "Autodesk instalado correctamente"
  },
  {
    img: "/trabajos/trabajo2.jpg",
    titulo: "Instalación Office 2024",
    ciudad: "Managua",
    tiempo: "20 min",
    badge: "Office listo para usar"
  },
  {
    img: "/trabajos/trabajo3.jpg",
    titulo: "Instalación Adobe Illustrator",
    ciudad: "Managua",
    tiempo: "25 min",
    badge: "Adobe activado"
  },
  {
    img: "/trabajos/antivirus.jpeg",
    titulo: "Instalación Antivirus McAfee",
    ciudad: "Managua",
    tiempo: "15 min",
    badge: "Equipo protegido"
  }
];
---

<section class="works-section">
  <div class="container">

    <div class="section-header">
      <h2>Instalaciones reales realizadas</h2>
      <p>Clientes satisfechos en toda Nicaragua • Resultados verificados</p>
    </div>

    <div class="works-grid">
      {trabajos.map((t) => (
        <article class="work-card">

          <div class="work-image">
            <img src={t.img} alt={t.titulo} loading="lazy" />

            <div class="work-status">
              <Icon name="mdi:check-decagram" />
              Instalación completada
            </div>

            <div class="work-overlay">
              <Icon name="mdi:shield-check" />
              <span>{t.badge}</span>
            </div>
          </div>

          <div class="work-content">
            <h3>{t.titulo}</h3>

            <div class="work-meta">
              <span>
                <Icon name="mdi:map-marker" /> {t.ciudad}
              </span>
              <span>
                <Icon name="mdi:clock-outline" /> {t.tiempo}
              </span>
            </div>
          </div>

        </article>
      ))}
    </div>

  </div>
</section>

<style>
.works-section {
  padding: 96px 0;
  background: var(--surface-container, #17191E);
}

.section-header {
  text-align: center;
  margin-bottom: 48px;
}
.section-header h2 {
  font-size: 28px;
  font-weight: 600;
  margin-bottom: 8px;
}
.section-header p {
  font-size: 14px;
  color: var(--on-surface-variant);
}

.works-grid {
  display: grid;
  grid-template-columns: repeat(auto-fit, minmax(260px, 1fr));
  gap: 24px;
}

.work-card {
  background: var(--surface-container-high, #1C1D22);
  border-radius: var(--shape-lg);
  overflow: hidden;
  box-shadow: var(--elevation-1);
  transition: box-shadow 0.2s ease, transform 0.2s ease;
}
.work-card:hover {
  box-shadow: var(--elevation-3);
  transform: translateY(-2px);
}

.work-image {
  position: relative;
  height: 200px;
  overflow: hidden;
}
.work-image img {
  width: 100%;
  height: 100%;
  object-fit: cover;
  transition: transform 0.4s ease;
}
.work-card:hover .work-image img { transform: scale(1.05); }

.work-status {
  position: absolute;
  top: 12px;
  left: 12px;
  padding: 4px 12px;
  border-radius: var(--shape-full);
  background: var(--primary);
  color: var(--on-primary);
  font-size: 11px;
  font-weight: 600;
  display: flex;
  align-items: center;
  gap: 4px;
}
.work-status svg { width: 14px; height: 14px; }

.work-overlay {
  position: absolute;
  inset: 0;
  background: rgba(15, 17, 21, 0.85);
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  gap: 8px;
  color: var(--primary);
  font-weight: 600;
  font-size: 13px;
  opacity: 0;
  transition: opacity 0.25s ease;
}
.work-overlay svg { width: 36px; height: 36px; }
.work-image:hover .work-overlay { opacity: 1; }

.work-content {
  padding: 20px;
}

.work-content h3 {
  font-size: 16px;
  font-weight: 600;
  margin-bottom: 12px;
}

.work-meta {
  display: flex;
  justify-content: space-between;
  font-size: 13px;
  color: var(--on-surface-variant);
}
.work-meta span {
  display: flex;
  align-items: center;
  gap: 4px;
}
.work-meta svg { width: 14px; height: 14px; }

@media (max-width: 768px) {
  .works-section { padding: 72px 0; }
}
</style>
