---
import { Icon } from "astro-icon/components";
---

<section id="trabajos" class="section trabajos">
  <div class="container">

    <div class="section-header">
      <span class="badge">CASOS REALES</span>
      <h2>Soportes realizados a clientes</h2>
      <p>
        Capturas reales durante sesiones remotas.
        Resultados visibles en minutos.
      </p>
    </div>

    <div class="works-grid">

      <!-- CARD -->
      <div class="work-card">
        <div class="image-wrapper">
          <img src="/trabajos/trabajo1.jpg" alt="Autocad instalado">
          <div class="overlay">
            <Icon name="mdi:check-decagram" />
            <span>Instalación completada</span>
          </div>
        </div>

        <div class="work-info">
          <h3>Instalación AutoCAD + activación</h3>
          <div class="meta">
            <span><Icon name="mdi:map-marker" /> Managua</span>
            <span><Icon name="mdi:clock-outline" /> 20 min</span>
          </div>
        </div>
      </div>

      <div class="work-card">
        <div class="image-wrapper">
          <img src="/trabajos/trabajo2.jpg" alt="Office instalado">
          <div class="overlay">
            <Icon name="mdi:check-decagram" />
            <span>Optimización completa</span>
          </div>
        </div>

        <div class="work-info">
          <h3>Instalación Office + optimización</h3>
          <div class="meta">
            <span><Icon name="mdi:map-marker" /> Managua</span>
            <span><Icon name="mdi:clock-outline" /> 18 min</span>
          </div>
        </div>
      </div>

      <div class="work-card">
        <div class="image-wrapper">
          <img src="/trabajos/trabajo3.jpg" alt="Adobe instalado">
          <div class="overlay">
            <Icon name="mdi:check-decagram" />
            <span>Instalación de adobe lista</span>
          </div>
        </div>

        <div class="work-info">
          <h3>Instalación paquete Adobe</h3>
          <div class="meta">
            <span><Icon name="mdi:map-marker" /> Managua</span>
            <span><Icon name="mdi:clock-outline" /> 20 min</span>
          </div>
        </div>
      </div>

    </div>

  </div>
</section>

<style>

.trabajos{
  padding:140px 0;
  background:#070b10;
}

/* HEADER */
.section-header{
  text-align:center;
  max-width:680px;
  margin:0 auto 70px;
}

.badge{
  display:inline-block;
  padding:7px 18px;
  border-radius:30px;
  background:#00e0ff15;
  color:var(--primary);
  font-size:.75rem;
  margin-bottom:18px;
}

.section-header h2{
  font-size:46px;
  margin-bottom:15px;
}

.section-header p{
  opacity:.7;
}

/* GRID */
.works-grid{
  display:grid;
  grid-template-columns:repeat(auto-fit,minmax(340px,1fr));
  gap:45px;
}

/* CARD */
.work-card{
  background:rgba(255,255,255,0.03);
  border:1px solid rgba(255,255,255,0.07);
  border-radius:26px;
  overflow:hidden;
  backdrop-filter:blur(10px);
  transition:.4s;
}

.work-card:hover{
  transform:translateY(-12px);
  border-color:var(--primary);
  box-shadow:0 0 50px #00e0ff22;
}

/* IMAGE */
.image-wrapper{
  position:relative;
  overflow:hidden;
}

.image-wrapper img{
  width:100%;
  display:block;
  transition:.6s;
}

.work-card:hover img{
  transform:scale(1.08);
}

/* OVERLAY */
.overlay{
  position:absolute;
  inset:0;
  background:linear-gradient(to top,#000,#00000010);
  display:flex;
  flex-direction:column;
  justify-content:flex-end;
  padding:18px;
  opacity:0;
  transition:.4s;
}

.work-card:hover .overlay{
  opacity:1;
}

.overlay svg{
  font-size:28px;
  color:#00ffae;
  margin-bottom:5px;
}

.overlay span{
  font-weight:600;
}

/* INFO */
.work-info{
  padding:24px;
}

.work-info h3{
  margin-bottom:14px;
}

.meta{
  display:flex;
  gap:18px;
  font-size:.85rem;
  opacity:.7;
}

.meta span{
  display:flex;
  align-items:center;
  gap:6px;
}

</style>