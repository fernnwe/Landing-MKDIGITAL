---
import { Icon } from "astro-icon/components";

const trabajos = [
  {
    img: "/trabajos/trabajo1.jpg",
    titulo: "Instalación AutoCAD 2026",
    ciudad: "Jinotega",
    tiempo: "30 min",
    badge: "Autodesk instalado correctamente"
  },
  {
    img: "/trabajos/trabajo2.jpg",
    titulo: "Instalación Office 2024",
    ciudad: "Managua",
    tiempo: "20 min",
    badge: "Office listo para usar"
  },
  {
    img: "/trabajos/trabajo3.jpg",
    titulo: "Instalación Adobe Illustrator",
    ciudad: "Managua",
    tiempo: "25 min",
    badge: "Adobe activado"
  },
  {
    img: "/trabajos/antivirus.jpeg",
    titulo: "Instalación Antivirus McAfee",
    ciudad: "Managua",
    tiempo: "15 min",
    badge: "Equipo protegido"
  }
];
---

<section class="works-section">
  <div class="container">

    <div class="section-header reveal reveal-up">
      <span class="badge">
        <i class="fa-solid fa-check-circle"></i>
        INSTALACIONES RECIENTES
      </span>
      <h2>Instalaciones reales realizadas</h2>
      <p>Clientes satisfechos en toda Nicaragua — Resultados verificados</p>
    </div>

    <div class="works-grid">
      {trabajos.map((t, i) => (
        <article class="work-card reveal reveal-up stagger-{i + 1}">
          <div class="work-image">
            <img src={t.img} alt={t.titulo} loading="lazy" />

            <div class="work-status">
              <Icon name="mdi:check-decagram" />
              Instalación completada
            </div>

            <div class="work-overlay">
              <Icon name="mdi:shield-check" />
              <span>{t.badge}</span>
            </div>
          </div>

          <div class="work-content">
            <h3>{t.titulo}</h3>

            <div class="work-meta">
              <span>
                <Icon name="mdi:map-marker" /> {t.ciudad}
              </span>
              <span>
                <Icon name="mdi:clock-outline" /> {t.tiempo}
              </span>
            </div>
          </div>

        </article>
      ))}
    </div>

  </div>
</section>

<style>
.works-section {
  padding: 96px 0;
  background: var(--surface-container);
}

.works-grid {
  display: grid;
  grid-template-columns: repeat(auto-fit, minmax(280px, 1fr));
  gap: 24px;
}

.work-card {
  background: var(--surface-container-high);
  border-radius: var(--shape-lg);
  overflow: hidden;
  border: 1px solid rgba(129, 140, 248, 0.06);
  transition: transform 0.4s cubic-bezier(0.2, 0, 0, 1),
              box-shadow 0.4s cubic-bezier(0.2, 0, 0, 1),
              border-color 0.3s ease;
}
.work-card:hover {
  transform: translateY(-6px);
  box-shadow: 0 12px 40px rgba(129, 140, 248, 0.12);
  border-color: rgba(129, 140, 248, 0.2);
}

.work-image {
  position: relative;
  height: 220px;
  overflow: hidden;
}
.work-image img {
  width: 100%;
  height: 100%;
  object-fit: cover;
  transition: transform 0.5s cubic-bezier(0.2, 0, 0, 1);
}
.work-card:hover .work-image img { transform: scale(1.08); }

.work-status {
  position: absolute;
  top: 12px;
  left: 12px;
  padding: 4px 12px;
  border-radius: var(--shape-full);
  background: linear-gradient(135deg, var(--primary), #6366F1);
  color: #FFFFFF;
  font-size: 11px;
  font-weight: 600;
  display: flex;
  align-items: center;
  gap: 4px;
  box-shadow: 0 2px 8px rgba(129, 140, 248, 0.3);
}
.work-status svg { width: 14px; height: 14px; }

.work-overlay {
  position: absolute;
  inset: 0;
  background: rgba(7, 8, 20, 0.85);
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  gap: 8px;
  color: var(--primary);
  font-weight: 600;
  font-size: 13px;
  opacity: 0;
  transition: opacity 0.3s ease;
  backdrop-filter: blur(4px);
}
.work-overlay svg { width: 36px; height: 36px; }
.work-image:hover .work-overlay { opacity: 1; }

.work-content {
  padding: 20px;
}

.work-content h3 {
  font-size: 16px;
  font-weight: 600;
  margin-bottom: 12px;
  color: var(--on-surface);
}

.work-meta {
  display: flex;
  justify-content: space-between;
  font-size: 13px;
  color: var(--on-surface-variant);
}
.work-meta span {
  display: flex;
  align-items: center;
  gap: 4px;
}
.work-meta svg { width: 14px; height: 14px; }

@media (max-width: 768px) {
  .works-section { padding: 72px 0; }
}
</style>
