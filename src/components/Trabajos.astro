---
import { Icon } from "astro-icon/components";
---

<section id="trabajos" class="section trabajos">
  <div class="container">

    <div class="section-header">
      <span class="badge">CASOS REALES</span>
      <h2>Trabajos realizados a clientes</h2>
      <p>
        Estos son algunos equipos atendidos mediante soporte remoto.
        Capturas reales tomadas durante la sesión con el cliente.
      </p>
    </div>

    <div class="works-grid">

      <!-- TRABAJO 1 -->
      <div class="work-card">
        <div class="laptop">
          <img src="/trabajos/trabajo1.jpg" alt="Instalación de programas">
        </div>

        <div class="work-info">
          <h3>Instalación de Autocad</h3>
          <span class="tag">Cliente en Managua</span>
        </div>
      </div>

      <!-- TRABAJO 2 -->
      <div class="work-card">
        <div class="laptop">
          <img src="/trabajos/trabajo2.jpg" alt="Optimización PC">
        </div>

        <div class="work-info">
          <h3>Instalación de office</h3>
          <span class="tag">Cliente en Managua</span>
        </div>
      </div>

      <!-- TRABAJO 3 -->
      <div class="work-card">
        <div class="laptop">
          <img src="/trabajos/trabajo3.jpg" alt="Autodesk instalado">
        </div>

        <div class="work-info">
          <h3>Instalación de programas de adobe</h3>
          <span class="tag">Cliente en Managua</span>
        </div>
      </div>

    </div>

  </div>
</section>

<style>

/* HEADER reutilizable */
.section-header{
  text-align:center;
  max-width:650px;
  margin:0 auto 60px;
}

.badge{
  display:inline-block;
  padding:7px 18px;
  border-radius:30px;
  background:linear-gradient(90deg,#00B3C920,#1ED6E620);
  color:var(--primary);
  font-size:.75rem;
  letter-spacing:.6px;
  margin-bottom:18px;
}

/* GRID */
.works-grid{
  display:grid;
  grid-template-columns:repeat(auto-fit,minmax(320px,1fr));
  gap:40px;
}

/* CARD */
.work-card{
  background:var(--glass);
  border:1px solid var(--border);
  border-radius:25px;
  overflow:hidden;
  transition:.35s;
  box-shadow:0 15px 40px rgba(0,0,0,.4);
}

.work-card:hover{
  transform:translateY(-12px);
  border-color:var(--primary);
}

/* LAPTOP MOCKUP */
.laptop{
  background:#0b0f14;
  padding:18px;
  border-bottom:1px solid rgba(255,255,255,0.05);
}

.laptop img{
  width:100%;
  border-radius:12px;
  display:block;
  box-shadow:0 10px 30px rgba(0,0,0,.6);
}

/* INFO */
.work-info{
  padding:22px;
}

.work-info h3{
  margin-bottom:8px;
}

.tag{
  font-size:.8rem;
  color:var(--primary);
  background:#00b3c915;
  padding:5px 12px;
  border-radius:20px;
}

</style>