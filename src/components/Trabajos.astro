---
import { Icon } from "astro-icon/components";

const trabajos = [
  {
    img: "/trabajos/trabajo1.jpg",
    titulo: "Instalación AutoCAD 2026",
    ciudad: "Jinotega",
    tiempo: "30 min",
    badge: "Autodesk instalado correctamente"
  },
  {
    img: "/trabajos/trabajo2.jpg",
    titulo: "Instalación Office 2024",
    ciudad: "Managua",
    tiempo: "20 min",
    badge: "Office listo para usar"
  },
  {
    img: "/trabajos/trabajo3.jpg",
    titulo: "Instalación Adobe Illustrator",
    ciudad: "Managua",
    tiempo: "25 min",
    badge: "Adobe activado"
  },
  {
    img: "/trabajos/antivirus.jpeg",
    titulo: "Instalación Antivirus McAfee",
    ciudad: "Managua",
    tiempo: "15 min",
    badge: "Equipo protegido"
  }
];
---

<section class="section" id="trabajos">
  <div class="container">
    <div class="section-header">
      <span class="badge reveal reveal-up">
        <Icon name="mdi:check-circle" />
        INSTALACIONES RECIENTES
      </span>
      <h2 class="reveal reveal-up stagger-1">Instalaciones reales realizadas</h2>
      <p class="reveal reveal-up stagger-2">Clientes satisfechos en toda Nicaragua — Resultados verificados</p>
    </div>

    <div class="works-grid">
      {trabajos.map((t, i) => (
        <article class="card glow-card work-card reveal reveal-up stagger-{Math.min(i + 1, 10)}">
          <div class="work-image">
            <img src={t.img} alt={t.titulo} loading="lazy" />
            <div class="work-status">
              <Icon name="mdi:check-decagram" />
              Instalación completada
            </div>
            <div class="work-overlay">
              <Icon name="mdi:shield-check" />
              <span>{t.badge}</span>
            </div>
          </div>
          <div class="work-content">
            <h3>{t.titulo}</h3>
            <div class="work-meta">
              <span>
                <Icon name="mdi:map-marker" /> {t.ciudad}
              </span>
              <span>
                <Icon name="mdi:clock-outline" /> {t.tiempo}
              </span>
            </div>
          </div>
        </article>
      ))}
    </div>
  </div>
</section>

<style>
.works-grid {
  display: grid;
  grid-template-columns: repeat(auto-fit, minmax(280px, 1fr));
  gap: 24px;
}

.work-card {
  overflow: hidden;
  cursor: default;
}

.work-image {
  position: relative;
  height: 220px;
  overflow: hidden;
}
.work-image img {
  width: 100%;
  height: 100%;
  object-fit: cover;
  transition: transform 0.5s cubic-bezier(0.2, 0, 0, 1);
}
.work-card:hover .work-image img { transform: scale(1.08); }

.work-status {
  position: absolute;
  top: 12px;
  left: 12px;
  padding: 4px 12px;
  border-radius: 9999px;
  background: linear-gradient(135deg, var(--primary), #0891B2);
  color: #FFFFFF;
  font-size: 11px;
  font-weight: 600;
  display: flex;
  align-items: center;
  gap: 4px;
  box-shadow: 0 2px 8px rgba(6, 182, 212, 0.3);
}
.work-status :global(svg) { width: 14px; height: 14px; }

.work-overlay {
  position: absolute;
  inset: 0;
  background: rgba(6, 6, 8, 0.85);
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  gap: 8px;
  color: var(--primary);
  font-weight: 600;
  font-size: 13px;
  opacity: 0;
  transition: opacity 0.3s ease;
  backdrop-filter: blur(4px);
}
.work-overlay :global(svg) { width: 36px; height: 36px; }
.work-card:hover .work-overlay { opacity: 1; }

.work-content {
  padding: 20px;
}

.work-content h3 {
  font-size: 16px;
  font-weight: 600;
  margin-bottom: 12px;
  color: var(--on-surface);
}

.work-meta {
  display: flex;
  justify-content: space-between;
  font-size: 13px;
  color: var(--on-surface-variant);
}
.work-meta span {
  display: flex;
  align-items: center;
  gap: 4px;
}
.work-meta :global(svg) { width: 14px; height: 14px; }
</style>
