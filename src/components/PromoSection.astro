---
import { Icon } from "astro-icon/components";
---

<section class="section" id="promociones">
  <div class="container">
    <div class="promo-card glow-card reveal reveal-up">
      <div class="promo-bg">
        <div class="promo-orb promo-orb-1"></div>
        <div class="promo-orb promo-orb-2"></div>
        <div class="promo-orb promo-orb-3"></div>
        <div class="promo-grid-overlay"></div>
      </div>

      <div class="promo-content">
        <div class="badge reveal reveal-down stagger-1">
          <Icon name="mdi:tag" />
          PROMOCIÓN DEL MES
        </div>

        <h2 class="reveal reveal-up stagger-2">
          Programas para tu PC con
          <span class="text-accent">descuentos exclusivos</span>
        </h2>

        <p class="promo-desc reveal reveal-up stagger-3">
          Promociones solo por este mes en programas para tu PC:
          Office, antivirus, Adobe Creative Cloud y más.
          Aprovecha los mejores precios del año.
        </p>

        <div class="promo-chips reveal reveal-up stagger-4">
          <span class="promo-chip">
            <Icon name="simple-icons:microsoft" color="#00A4EF" />
            Office 2024/2021
          </span>
          <span class="promo-chip">
            <Icon name="mdi:shield-half-full" color="#00C853" />
            Antivirus
          </span>
          <span class="promo-chip">
            <Icon name="simple-icons:adobe" color="#FF0000" />
            Adobe CC
          </span>
          <span class="promo-chip">
            <Icon name="mdi:hexagon-multiple" color="#E51050" />
            Autodesk
          </span>
          <span class="promo-chip">
            <Icon name="simple-icons:windows" color="#00A4EF" />
            Windows
          </span>
          <span class="promo-chip">
            <Icon name="mdi:file-document-outline" color="#818CF8" />
            Facturación
          </span>
        </div>

        <div class="promo-actions reveal reveal-up stagger-5">
          <a href="/catalogo" class="btn-primary">
            Ver ofertas disponibles
            <Icon name="mdi:arrow-right" />
          </a>
          <a href="https://wa.me/50581088124?text=Hola%2C%20quiero%20informaci%C3%B3n%20sobre%20las%20promociones%20de%20este%20mes" target="_blank" class="btn-outline">
            <Icon name="simple-icons:whatsapp" />
            Consultar por WhatsApp
          </a>
        </div>

        <div class="promo-countdown reveal reveal-up stagger-6">
          <Icon name="mdi:clock-outline" />
          <span>Ofertas válidas hasta fin de mes — No dejes pasar esta oportunidad</span>
        </div>
      </div>
    </div>
  </div>
</section>

<style>
.promo-card {
  position: relative;
  overflow: hidden;
  padding: 80px 60px;
  border-radius: 24px;
  background: linear-gradient(135deg, rgba(245,158,11,0.06), rgba(16,185,129,0.03));
  border: 1px solid rgba(245,158,11,0.1);
  text-align: center;
}

.promo-bg {
  position: absolute; inset: 0;
  overflow: hidden;
  pointer-events: none;
}

.promo-orb {
  position: absolute;
  border-radius: 50%;
  filter: blur(100px);
  opacity: 0.4;
  animation: orb-float 20s ease-in-out infinite;
}
.promo-orb-1 {
  width: 500px; height: 500px;
  top: -200px; left: -150px;
  background: radial-gradient(circle, rgba(6, 182, 212, 0.15) 0%, transparent 70%);
}
.promo-orb-2 {
  width: 450px; height: 450px;
  bottom: -200px; right: -100px;
  background: radial-gradient(circle, rgba(129, 140, 248, 0.12) 0%, transparent 70%);
  animation-delay: -7s;
}
.promo-orb-3 {
  width: 350px; height: 350px;
  top: 30%; left: 50%;
  background: radial-gradient(circle, rgba(6, 182, 212, 0.08) 0%, transparent 70%);
  animation-delay: -14s;
}

.promo-grid-overlay {
  position: absolute; inset: 0;
  background-image:
    linear-gradient(rgba(6, 182, 212, 0.03) 1px, transparent 1px),
    linear-gradient(90deg, rgba(6, 182, 212, 0.03) 1px, transparent 1px);
  background-size: 64px 64px;
  opacity: 0.4;
}

.promo-content {
  position: relative;
  z-index: 1;
  max-width: 720px;
  margin: 0 auto;
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 20px;
}

.promo-content .badge {
  animation: promo-pulse 2s ease-in-out infinite;
}

@keyframes promo-pulse {
  0%, 100% { box-shadow: 0 0 0 0 rgba(6, 182, 212, 0.2); }
  50% { box-shadow: 0 0 0 12px rgba(6, 182, 212, 0); }
}

.promo-content h2 {
  font-size: clamp(28px, 3.5vw, 42px);
  font-weight: 700;
  line-height: 1.15;
}

.text-accent {
  background: linear-gradient(135deg, var(--primary), #22D3EE);
  -webkit-background-clip: text;
  -webkit-text-fill-color: transparent;
  background-clip: text;
}

.promo-desc {
  font-size: 16px;
  color: var(--on-surface-variant);
  max-width: 600px;
  margin: 0 auto;
  line-height: 1.6;
}

.promo-chips {
  display: flex;
  flex-wrap: wrap;
  justify-content: center;
  gap: 10px;
}

.promo-chip {
  display: inline-flex;
  align-items: center;
  gap: 8px;
  padding: 10px 18px;
  border-radius: 9999px;
  background: var(--surface-container);
  border: 1px solid rgba(255,255,255,0.06);
  font-size: 13px;
  font-weight: 500;
  color: var(--on-surface);
  transition: all 0.2s ease;
  cursor: default;
}
.promo-chip:hover {
  transform: translateY(-2px);
  border-color: rgba(6, 182, 212, 0.2);
  box-shadow: 0 4px 12px rgba(6, 182, 212, 0.1);
}
.promo-chip :global(svg) { width: 16px; height: 16px; }

.promo-actions {
  display: flex;
  flex-wrap: wrap;
  justify-content: center;
  gap: 12px;
}

.promo-countdown {
  display: flex;
  align-items: center;
  gap: 8px;
  font-size: 13px;
  color: var(--on-surface-variant);
}
.promo-countdown :global(svg) { width: 14px; height: 14px; color: var(--primary); }

@media (max-width: 900px) {
  .promo-card { padding: 60px 28px; border-radius: 20px; }
  .promo-actions { flex-direction: column; align-items: center; }
  .btn-primary, .btn-outline { width: 100%; justify-content: center; }
}

@media (max-width: 600px) {
  .promo-card { padding: 48px 20px; }
}
</style>
