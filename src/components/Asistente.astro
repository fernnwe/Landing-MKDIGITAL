<div id="aiFloat">
  <svg viewBox="0 0 24 24"><path d="M21 15a4 4 0 0 1-4 4H8l-5 3V7a4 4 0 0 1 4-4h10a4 4 0 0 1 4 4z"/></svg>
</div>

<div id="aiChat" class="chat">
  <div class="chat-header">
    <div class="title">
      <div class="avatar"></div>
      <div>
        <strong>MKDIGITAL</strong>
        <span>Asistente virtual</span>
      </div>
    </div>
    <button id="closeAI">✕</button>
  </div>

  <div id="chatMessages" class="messages"></div>

  <div class="chat-input">
    <input id="userMsg" placeholder="Escribe tu mensaje..." />
    <button id="sendMsg">
      <svg viewBox="0 0 24 24"><path d="M2 21l21-9L2 3v7l15 2-15 2z"/></svg>
    </button>
  </div>
</div>

<script is:inline>

// =============================
// BASE DE CONOCIMIENTO
// =============================
const knowledge = [
{
  intent:"precio",
  keywords:["precio","cuesta","costo","vale","valor","cuánto","pagar","tarifa"],
  answer:"Nuestros servicios inician desde C$400 por instalación básica."
},
{
  intent:"office",
  keywords:["office","word","excel","powerpoint","microsoft"],
  answer:"Instalamos Microsoft Office 2024 y 2021 con activación permanente."
},
{
  intent:"windows",
  keywords:["windows","formateo","formatear","pc lenta","computadora lenta","sistema operativo"],
  answer:"Instalamos Windows 10 y 11 optimizados, activados y listos para trabajar."
},
{
  intent:"facturacion",
  keywords:["factura","facturacion","inventario","sistema","negocio","pos","factulite"],
  answer:"Ofrecemos sistemas de facturación para PC y también FactuLite para negocios móviles."
},
{
  intent:"soporte",
  keywords:["soporte","ayuda","remoto","arreglar","reparar","problema"],
  answer:"Brindamos soporte remoto en toda Nicaragua sin que tengas que salir de casa."
},
{
  intent:"tiempo",
  keywords:["tiempo","tardan","demora","cuánto tardan","duración"],
  answer:"El proceso normalmente tarda entre 30 minutos y 2 horas."
},
{
  intent:"garantia",
  keywords:["garantia","seguridad","seguro"],
  answer:"Todas nuestras instalaciones incluyen garantía."
},
{
  intent:"pago",
  keywords:["pago","transferencia","efectivo","deposito","cancelar"],
  answer:"Aceptamos transferencias y pagos en efectivo."
},
{
  intent:"contacto",
  keywords:["contacto","whatsapp","numero","teléfono","hablar"],
  answer:"Puedes escribirnos por WhatsApp: https://wa.me/50581088124"
}
];


// =============================
// SISTEMA INTELIGENTE
// =============================
function normalize(text){
  return text
    .toLowerCase()
    .normalize("NFD")
    .replace(/[\u0300-\u036f]/g,"");
}

function detectarIntencion(msg){

  msg = normalize(msg);
  let mejorIntento = null;
  let mejorScore = 0;

  knowledge.forEach(item=>{
    let score = 0;

    item.keywords.forEach(keyword=>{
      if(msg.includes(keyword)) score++;
    });

    if(score > mejorScore){
      mejorScore = score;
      mejorIntento = item;
    }
  });

  if(mejorScore === 0) return null;
  return mejorIntento.answer;
}

function responder(msg){
  const intento = detectarIntencion(msg);
  if(intento) return intento;

  return "Puedo ayudarte con instalaciones, licencias, facturación, soporte técnico y precios.";
}


// =============================
// UI CHAT (OPTIMIZADO)
// =============================
const chat = document.querySelector("#aiChat");
const float = document.querySelector("#aiFloat");
const closeBtn = document.querySelector("#closeAI");
const sendBtn = document.querySelector("#sendMsg");
const input = document.querySelector("#userMsg");
const messages = document.querySelector("#chatMessages");

float.onclick = () => chat.classList.toggle("open");
closeBtn.onclick = () => chat.classList.remove("open");

function hora(){
  const d=new Date();
  return d.getHours()+":"+String(d.getMinutes()).padStart(2,"0");
}

function addMsg(text,tipo="bot"){
  const msg=document.createElement("div");
  msg.className="msg "+tipo;

  msg.innerHTML=`
  <div class="bubble">
    ${text}
    <span class="time">${hora()}</span>
  </div>`;
  
  messages.appendChild(msg);
  messages.scrollTop = messages.scrollHeight;
}

function enviar(){
  const texto=input.value.trim();
  if(!texto) return;

  addMsg(texto,"user");
  input.value="";

  setTimeout(()=>{
    addMsg(responder(texto),"bot");
  },600);
}

sendBtn.onclick=enviar;
input.addEventListener("keypress",e=>{ if(e.key==="Enter") enviar(); });

addMsg("Bienvenido. ¿Cómo puedo ayudarte?");

</script>

<style>
/* ===== VARIABLES PROFESIONALES ===== */
:root{
  --bg-main:#070b12;
  --bg-chat:#0c121c;
  --bg-input:#0e1623;
  --bot-msg:#1a2433;
  --user-msg:linear-gradient(135deg,#00e0ff,#00ffa6);
  --accent:#00e0ff;
  --shadow-big:0 40px 80px rgba(0,0,0,.65);
  --shadow-soft:0 15px 35px rgba(0,0,0,.35);
  --border:rgba(255,255,255,.06);
  --text-soft:#a9b4c6;
}

/* ===== BOTON FLOTANTE ===== */
#aiFloat{
 position:fixed;
 bottom:25px; left:25px;
 width:68px;height:68px;
 border-radius:50%;
 background:var(--user-msg);
 display:flex;align-items:center;justify-content:center;
 cursor:pointer; z-index:9999;
 box-shadow:var(--shadow-soft);
 transition:.35s cubic-bezier(.2,.8,.2,1);
}
#aiFloat:hover{
 transform:scale(1.08);
 box-shadow:0 20px 45px rgba(0,255,200,.35);
}
#aiFloat svg{width:28px;fill:#000}

/* ===== CONTENEDOR CHAT ===== */
.chat{
 position:fixed;
 bottom:105px; left:25px;
 width:360px; height:560px;
 border-radius:26px;
 display:flex; flex-direction:column;
 overflow:hidden;
 opacity:0; transform:translateY(40px) scale(.95);
 pointer-events:none;
 transition:.45s cubic-bezier(.2,.8,.2,1);

 backdrop-filter:blur(18px);
 background:rgba(10,15,25,.75);
 border:1px solid var(--border);
 box-shadow:var(--shadow-big);
}
.chat.open{
 opacity:1;
 transform:translateY(0) scale(1);
 pointer-events:auto;
}

/* ===== HEADER ===== */
.chat-header{
 padding:16px;
 display:flex;
 justify-content:space-between;
 align-items:center;
 background:linear-gradient(135deg,#0e1623,#111b2b);
 border-bottom:1px solid var(--border);
}

.title{display:flex;gap:12px;align-items:center}
.avatar{
 width:42px;height:42px;
 border-radius:50%;
 background:var(--user-msg);
 box-shadow:0 0 0 3px rgba(0,255,200,.15);
}
.title strong{font-size:15px}
.title span{
 display:block;
 font-size:12px;
 color:var(--text-soft);
}

.chat-header button{
 background:none;border:none;
 color:#8fa3c3;
 font-size:18px;
 cursor:pointer;
 transition:.2s;
}
.chat-header button:hover{color:#fff}

/* ===== AREA MENSAJES ===== */
.messages{
 flex:1;
 padding:18px;
 overflow-y:auto;
 display:flex;
 flex-direction:column;
 gap:14px;
 background:linear-gradient(#080d16,#070b12);
}

/* Scroll elegante */
.messages::-webkit-scrollbar{width:6px}
.messages::-webkit-scrollbar-thumb{
 background:rgba(255,255,255,.08);
 border-radius:10px;
}

/* ===== MENSAJES ===== */
.msg{display:flex; animation:msgIn .35s ease}
@keyframes msgIn{
 from{opacity:0; transform:translateY(10px)}
 to{opacity:1; transform:none}
}

.msg.bot{justify-content:flex-start}
.msg.user{justify-content:flex-end}

/* ===== BURBUJAS PRO ===== */
.bubble{
 position:relative;
 padding:12px 16px 20px;
 border-radius:18px;
 max-width:78%;
 font-size:14px;
 line-height:1.45;
 letter-spacing:.2px;
}

/* BOT */
.bot .bubble{
 background:var(--bot-msg);
 border-bottom-left-radius:6px;
 box-shadow:0 8px 20px rgba(0,0,0,.35);
 color:#d7e2f2;
}

/* USER */
.user .bubble{
 background:var(--user-msg);
 color:#001014;
 border-bottom-right-radius:6px;
 box-shadow:0 8px 25px rgba(0,255,200,.25);
}

/* Colita de burbuja */
.bot .bubble:before,
.user .bubble:before{
 content:"";
 position:absolute;
 bottom:0;
 width:12px;height:12px;
}
.bot .bubble:before{
 left:-5px;
 background:var(--bot-msg);
 clip-path:polygon(0 0,100% 100%,0 100%);
}
.user .bubble:before{
 right:-5px;
 background:#00ffa6;
 clip-path:polygon(100% 0,100% 100%,0 100%);
}

/* Hora */
.time{
 position:absolute;
 bottom:4px; right:10px;
 font-size:10px;
 opacity:.55;
}

/* ===== INPUT AREA ===== */
.chat-input{
 display:flex;
 align-items:center;
 padding:10px;
 gap:10px;
 background:var(--bg-input);
 border-top:1px solid var(--border);
}

.chat-input input{
 flex:1;
 padding:12px 16px;
 border-radius:14px;
 border:1px solid var(--border);
 background:#0b1320;
 color:#fff;
 outline:none;
 transition:.2s;
}
.chat-input input:focus{
 border-color:var(--accent);
 box-shadow:0 0 0 2px rgba(0,224,255,.15);
}

.chat-input button{
 width:48px;height:48px;
 border-radius:14px;
 border:none;
 background:var(--user-msg);
 display:flex;align-items:center;justify-content:center;
 cursor:pointer;
 transition:.25s;
}
.chat-input button:hover{
 transform:scale(1.05);
 box-shadow:0 10px 25px rgba(0,255,200,.35);
}
.chat-input svg{width:22px;fill:#001014}
</style>