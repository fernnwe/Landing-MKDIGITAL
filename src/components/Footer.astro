<style>
  .footer { position: relative; background: var(--surface-container-low); border-top: 1px solid var(--outline-variant); padding-top: 60px; }
  .footer-wave { position: absolute; top: -1px; left: 0; right: 0; width: 100%; line-height: 0; }
  .footer-wave svg { display: block; width: 100%; height: 40px; }
  .footer-content { padding-bottom: 32px; }
  .footer-main { display: grid; grid-template-columns: 1.5fr 2fr; gap: 60px; padding-bottom: 40px; }
  .footer-brand { display: flex; flex-direction: column; gap: 16px; }
  .footer-logo { font-size: 24px; font-weight: 700; letter-spacing: -0.5px; color: var(--on-surface); }
  .footer-logo-accent { color: var(--primary); font-weight: 800; }
  .footer-about { font-size: 14px; line-height: 1.7; max-width: 360px; }
  .footer-social { display: flex; gap: 8px; }
  .social-link { display: flex; align-items: center; justify-content: center; width: 38px; height: 38px; border-radius: 10px; background: var(--surface-container-highest); color: var(--on-surface-variant); border: 1px solid var(--outline-variant); text-decoration: none; transition: background 0.3s, color 0.3s, border-color 0.3s; }
  .social-link:hover { background: var(--primary); color: var(--on-primary); border-color: var(--primary); }
  .footer-links-group { display: grid; grid-template-columns: repeat(3, 1fr); gap: 32px; }
  .footer-col { display: flex; flex-direction: column; gap: 10px; }
  .footer-col-title { font-size: 14px; font-weight: 600; color: var(--on-surface); margin-bottom: 4px; }
  .footer-link { font-size: 14px; color: var(--on-surface-variant); text-decoration: none; width: fit-content; }
  .footer-link:hover { color: var(--primary); }
  .footer-link-text { cursor: default; }
  .footer-link-text:hover { color: var(--on-surface-variant); }
  .footer-link-cta { font-weight: 500; color: var(--primary); }
  .footer-bottom { display: flex; align-items: center; justify-content: space-between; gap: 16px; padding-top: 24px; font-size: 13px; color: var(--on-surface-variant); }
  .footer-bottom-links { display: flex; gap: 20px; }
  .footer-bottom-links a { color: var(--on-surface-variant); text-decoration: none; }
  .footer-bottom-links a:hover { color: var(--primary); }
  @media (max-width: 900px) { .footer-main { grid-template-columns: 1fr; gap: 40px; } .footer-links-group { grid-template-columns: repeat(3, 1fr); } }
  @media (max-width: 600px) { .footer-links-group { grid-template-columns: 1fr; gap: 24px; } .footer-bottom { flex-direction: column; text-align: center; } .footer-bottom-links { flex-wrap: wrap; justify-content: center; } .footer-wave svg { height: 24px; } }
</style>
