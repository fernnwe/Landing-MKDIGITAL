---
import { Icon } from "astro-icon/components";
---

<footer class="footer">
  <div class="container footer-grid">

    <!-- Marca -->
    <div>
      <h3 class="logo">MKDigital</h3>
      <p class="footer-text">
        Soporte informático remoto profesional, rápido y confiable.
        Instalación de software, optimización y solución de problemas sin salir de casa.
      </p>
    </div>

    <!-- Servicios -->
    <div>
      <h4>Servicios</h4>
      <ul>
        <li>Instalación de Windows</li>
        <li>Instalación de Office</li>
        <li>Optimización de PC</li>
        <li>Eliminación de virus</li>
      </ul>
    </div>

    <!-- Contacto -->
    <div>
      <h4>Contacto</h4>

      <p class="contact">
        <Icon name="mdi:whatsapp" /> +505 8108 8124
      </p>

      <p class="contact">
        <Icon name="mdi:email" /> mkdigitalnic1604@gmail.com
      </p>

      <a href="https://wa.me/50581088124" class="btn-whatsapp">
        Solicitar soporte
      </a>
    </div>

  </div>

  <div class="copy">
    © 2026 MKDigital — Todos los derechos reservados
  </div>
</footer>

<style>

.footer{
  background:#0b0f14;
  color:white;
  padding-top:80px;
}

.footer-grid{
  display:grid;
  grid-template-columns:2fr 1fr 1fr;
  gap:60px;
  padding-bottom:50px;
}

.logo{
  font-size:28px;
  color:var(--primary);
  margin-bottom:15px;
}

.footer-text{
  opacity:.7;
  line-height:1.6;
  max-width:350px;
}

.footer h4{
  margin-bottom:15px;
}

.footer ul{
  list-style:none;
  padding:0;
}

.footer li{
  margin:10px 0;
  opacity:.7;
}

.contact{
  display:flex;
  align-items:center;
  gap:10px;
  margin:10px 0;
  opacity:.8;
}

.contact svg{
  width:20px;
  height:20px;
  color:var(--primary);
}

.btn-whatsapp{
  display:inline-block;
  margin-top:15px;
  padding:12px 20px;
  background:linear-gradient(135deg,var(--primary),#1ed6e6);
  color:white;
  border-radius:10px;
  text-decoration:none;
  font-weight:600;
  transition:.3s;
}

.btn-whatsapp:hover{
  transform:translateY(-3px);
  box-shadow:0 10px 25px #00b3c955;
}

.copy{
  text-align:center;
  padding:20px;
  border-top:1px solid #ffffff20;
  font-size:14px;
  opacity:.6;
}

/* Responsive */
@media(max-width:768px){
  .footer-grid{
    grid-template-columns:1fr;
    text-align:center;
  }

  .footer-text{
    margin:auto;
  }

  .contact{
    justify-content:center;
  }
}

</style>