---
import { Icon } from "astro-icon/components";
---

<footer class="footer">
  <div class="container footer-grid">

    <!-- BRAND -->
    <div class="footer-brand">
      <h3 class="logo">MKDIGITAL</h3>

      <p class="footer-desc">
        Soporte informático remoto profesional para hogares y empresas.
        Instalación de software, optimización y solución de problemas sin salir de casa.
      </p>

      <div class="socials">
        <a href="#"><Icon name="mdi:facebook" /></a>
        <a href="#"><Icon name="mdi:instagram" /></a>
        <a href="#"><Icon name="mdi:whatsapp" /></a>
      </div>
    </div>

    <!-- SERVICIOS -->
    <div>
      <h4 class="footer-title">Servicios</h4>
      <ul class="footer-links">
        <li>Instalación de Windows</li>
        <li>Instalación de Office</li>
        <li>Optimización de PC</li>
        <li>Eliminación de virus</li>
        <li>Instalación de Programas</li>
      </ul>
    </div>

    <!-- ENLACES -->
    <div>
      <h4 class="footer-title">Enlaces rápidos</h4>
      <ul class="footer-links">
        <li><a href="/catalogo">Catálogo</a></li>
        <li><a href="/beneficios">Beneficios</a></li>
        <li><a href="/faq">Preguntas frecuentes</a></li>
        <li><a href="/anydesk">Descargar AnyDesk</a></li>
      </ul>
    </div>

    <!-- CONTACTO -->
    <div class="footer-contact">
      <h4 class="footer-title">Contacto</h4>

      <p>
        <Icon name="mdi:whatsapp" />
        +505 8108 8124
      </p>

      <p>
        <Icon name="mdi:email-outline" />
        mkdigitalnic1604@gmail.com
      </p>

      <a href="https://wa.me/50581088124" class="btn-whatsapp">
        Solicitar soporte ahora
      </a>
    </div>

  </div>

  <!-- LINEA DIVISORIA -->
  <div class="footer-bottom">
    <p>© 2026 MKDigital — Todos los derechos reservados</p>
  </div>
</footer>

<style>
/* ================= FOOTER BASE ================= */

.footer{
  background:linear-gradient(180deg,#0b0f14,#06080c);
  color:white;
  padding-top:90px;
  margin-top:80px;
  border-top:1px solid #ffffff10;
}

/* GRID */
.footer-grid{
  display:grid;
  grid-template-columns:2fr 1fr 1fr 1.3fr;
  gap:60px;
  padding-bottom:60px;
}

/* BRAND */
.logo{
  font-size:30px;
  background:linear-gradient(135deg,var(--primary),#4de4f5);
  -webkit-background-clip:text;
  color:transparent;
  margin-bottom:18px;
}

.footer-desc{
  opacity:.7;
  line-height:1.7;
  max-width:380px;
}

/* SOCIAL ICONS */
.socials{
  display:flex;
  gap:15px;
  margin-top:20px;
}

.socials a{
  width:38px;
  height:38px;
  display:flex;
  align-items:center;
  justify-content:center;
  border-radius:10px;
  background:#ffffff10;
  transition:.3s;
}

.socials svg{
  width:20px;
  height:20px;
}

.socials a:hover{
  background:linear-gradient(135deg,var(--primary),#1ed6e6);
  transform:translateY(-4px);
}

/* TITLES */
.footer-title{
  margin-bottom:18px;
  font-size:18px;
  position:relative;
}

.footer-title::after{
  content:"";
  display:block;
  width:40px;
  height:3px;
  background:var(--primary);
  margin-top:8px;
  border-radius:3px;
}

/* LINKS */
.footer-links{
  list-style:none;
  padding:0;
}

.footer-links li{
  margin:12px 0;
  opacity:.75;
  transition:.3s;
}

.footer-links a{
  color:white;
  text-decoration:none;
}

.footer-links li:hover{
  opacity:1;
  transform:translateX(5px);
}

/* CONTACT */
.footer-contact p{
  display:flex;
  align-items:center;
  gap:10px;
  margin:12px 0;
  opacity:.85;
}

.footer-contact svg{
  width:20px;
  height:20px;
  color:var(--primary);
}

/* BOTON WHATSAPP */
.btn-whatsapp{
  display:inline-block;
  margin-top:18px;
  padding:14px 24px;
  background:linear-gradient(135deg,var(--primary),#1ed6e6);
  color:white;
  border-radius:12px;
  text-decoration:none;
  font-weight:600;
  transition:.3s;
}

.btn-whatsapp:hover{
  transform:translateY(-4px);
  box-shadow:0 12px 30px #00b3c955;
}

/* BOTTOM */
.footer-bottom{
  text-align:center;
  padding:25px;
  border-top:1px solid #ffffff15;
  font-size:14px;
  opacity:.6;
}

/* ================= RESPONSIVE ================= */

@media(max-width:900px){
  .footer-grid{
    grid-template-columns:1fr 1fr;
    gap:40px;
  }
}

@media(max-width:600px){
  .footer-grid{
    grid-template-columns:1fr;
    text-align:center;
  }

  .footer-desc{
    margin:auto;
  }

  .socials{
    justify-content:center;
  }

  .footer-contact p{
    justify-content:center;
  }
}
</style>