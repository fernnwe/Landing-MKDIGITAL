---
import { Icon } from "astro-icon/components";
---

<section class="section software-section">
  <div class="container">

    <div class="section-header reveal reveal-up">
      <span class="badge">SOFTWARE DE FACTURACIÓN</span>
      <h2>Sistemas de venta listos para implementar</h2>
      <p>
        Instalamos, configuramos y dejamos funcionando sistemas de facturación
        profesional desarrollados por aliados tecnológicos.
      </p>
    </div>

    <div class="software-grid">

      <div class="software-card reveal reveal-left stagger-1">
        <div class="software-top">
          <div class="sw-icon">
            <Icon name="mdi:cellphone" />
          </div>
          <span class="software-badge">APP ANDROID</span>
        </div>

        <h3>FactuLite</h3>

        <p class="software-desc">
          Facturación rápida para emprendedores y pequeños negocios.
          Vende directamente desde tu teléfono de forma simple.
        </p>

        <ul class="feature-list">
          <li><Icon name="mdi:bolt" /> Facturación inmediata</li>
          <li><Icon name="mdi:chart-line" /> Control de ventas</li>
          <li><Icon name="mdi:receipt" /> Emisión de vouchers</li>
          <li><Icon name="mdi:headset" /> Actualizaciones</li>
        </ul>

        <a href="https://factulite.net" target="_blank" class="software-btn">
          Conocer FactuLite
        </a>
      </div>

      <div class="software-card featured reveal reveal-up stagger-2">
        <div class="popular-badge">RECOMENDADO</div>

        <div class="software-top">
          <div class="sw-icon">
            <Icon name="mdi:desktop-classic" />
          </div>
          <span class="software-badge">Punto de venta web</span>
        </div>

        <h3>ViperPOS</h3>

        <p class="software-desc">
          Sistema profesional de facturación e inventario accesible desde
          cualquier computadora o navegador.
        </p>

        <ul class="feature-list">
          <li><Icon name="mdi:package-variant-closed" /> Inventario en tiempo real</li>
          <li><Icon name="mdi:chart-pie" /> Reportes y estadísticas</li>
          <li><Icon name="mdi:users" /> Multiusuario y Multisucursal</li>
          <li><Icon name="mdi:screwdriver" />Soporte técnico incluido</li>
        </ul>

        <a href="https://www.viperpos.net/login" target="_blank" class="software-btn">
          Conocer ViperPOS
        </a>
      </div>

      
    </div>
  </div>
</section>

<style>
.software-section {
  padding: 96px 0;
  background: var(--background);
}

.software-grid {
  display: grid;
  grid-template-columns: repeat(auto-fit, minmax(320px, 1fr));
  gap: 24px;
}

.software-card {
  position: relative;
  background: var(--surface-container-high);
  border-radius: var(--shape-xl);
  padding: 32px;
  box-shadow: var(--elevation-1);
  border: 1px solid transparent;
  transition: box-shadow 0.3s cubic-bezier(0.2, 0, 0, 1),
              transform 0.3s cubic-bezier(0.2, 0, 0, 1),
              border-color 0.3s ease;
}
.software-card:hover {
  box-shadow: var(--elevation-4);
  transform: translateY(-4px);
  border-color: rgba(129, 140, 248, 0.15);
}

.featured {
  border: 1px solid rgba(129, 140, 248, 0.2);
  box-shadow: 0 0 30px rgba(129, 140, 248, 0.05);
}

.popular-badge {
  position: absolute;
  top: -10px;
  right: 24px;
  background: linear-gradient(135deg, var(--primary), #6366F1);
  color: #FFFFFF;
  padding: 4px 14px;
  border-radius: var(--shape-full);
  font-size: 11px;
  font-weight: 600;
  letter-spacing: 0.5px;
  box-shadow: 0 0 20px rgba(129, 140, 248, 0.3);
}

.software-top {
  display: flex;
  align-items: center;
  gap: 14px;
  margin-bottom: 20px;
}

.sw-icon {
  width: 48px;
  height: 48px;
  border-radius: var(--shape-md);
  background: rgba(129, 140, 248, 0.1);
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 20px;
  color: var(--primary);
}

.software-badge {
  font-size: 12px;
  font-weight: 500;
  color: var(--secondary);
  padding: 4px 10px;
  border-radius: var(--shape-full);
  background: rgba(34, 211, 238, 0.1);
  border: 1px solid rgba(34, 211, 238, 0.15);
}

.software-card h3 { font-size: 24px; font-weight: 600; margin-bottom: 12px; }

.software-desc {
  font-size: 14px;
  line-height: 1.6;
  margin-bottom: 24px;
  color: var(--on-surface-variant);
}

.feature-list {
  list-style: none;
  padding: 0;
  margin-bottom: 28px;
}
.feature-list li {
  display: flex;
  align-items: center;
  gap: 10px;
  padding: 8px 0;
  font-size: 14px;
  color: var(--on-surface-variant);
}
.feature-list li svg { color: var(--primary); width: 16px; height: 16px; }

.software-btn {
  display: inline-flex;
  align-items: center;
  gap: 8px;
  padding: 12px 24px;
  border-radius: var(--shape-full);
  color: #FFFFFF;
  font-size: 14px;
  font-weight: 500;
  text-decoration: none;
  background: linear-gradient(135deg, var(--primary), #6366F1);
  box-shadow: 0 0 20px rgba(129, 140, 248, 0.2);
  transition: box-shadow 0.2s ease, transform 0.15s ease;
}
.software-btn:hover {
  box-shadow: 0 0 30px rgba(129, 140, 248, 0.35);
  transform: scale(1.03);
}

@media (max-width: 600px) {
  .software-card { padding: 24px; }
}
</style>
