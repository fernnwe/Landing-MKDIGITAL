---
import { Icon } from "astro-icon/components";
---

<section class="section anydesk-section" id="anydesk">
  <div class="container anydesk-grid">

    <div class="anydesk-text">
      <span class="badge reveal reveal-up">CONEXIÓN REMOTA SEGURA</span>
      <h2 class="reveal reveal-up stagger-1">Descarga el programa para soporte remoto</h2>

      <p class="anydesk-desc reveal reveal-up stagger-2">
        Para comenzar el soporte remoto solo necesitas descargar uno de estos
        programas. No requieren instalación y tardan menos de 1 minuto.
      </p>

      <div class="tab-bar reveal reveal-up stagger-3">
        <button class="tab active" data-target="anydeskSteps">
          <Icon name="simple-icons:anydesk"/> AnyDesk
        </button>
        <button class="tab" data-target="teamviewerSteps">
          <Icon name="simple-icons:teamviewer"/> TeamViewer
        </button>
      </div>

      <div class="steps-panel active reveal reveal-up stagger-4" id="anydeskSteps">
        <div class="steps-list">
          <div class="step">
            <div class="step-num">1</div>
            <div>
              <h4>Descargar</h4>
              <p>Haz clic en el botón y descarga AnyDesk desde la web oficial.</p>
            </div>
          </div>

          <div class="step">
            <div class="step-num">2</div>
            <div>
              <h4>Abrir el archivo</h4>
              <p>Abre el programa descargado. No necesitas instalar nada.</p>
            </div>
          </div>

          <div class="step">
            <div class="step-num">3</div>
            <div>
              <h4>Enviar tu ID</h4>
              <p>Envíanos el número que aparece y comenzamos el soporte.</p>
            </div>
          </div>
        </div>

        <a href="https://anydesk.com/es/downloads/thank-you?dv=win_exe" target="_blank" class="btn-primary">
          <Icon name="mdi:download"/> Descargar AnyDesk
        </a>
      </div>

      <div class="steps-panel" id="teamviewerSteps">
        <div class="steps-list">
          <div class="step">
            <div class="step-num">1</div>
            <div>
              <h4>Descargar TeamViewer</h4>
              <p>Descarga TeamViewer QuickSupport desde el sitio oficial.</p>
            </div>
          </div>

          <div class="step">
            <div class="step-num">2</div>
            <div>
              <h4>Abrir el programa</h4>
              <p>Ejecuta el archivo descargado (no requiere instalación).</p>
            </div>
          </div>

          <div class="step">
            <div class="step-num">3</div>
            <div>
              <h4>Compartir ID y contraseña</h4>
              <p>Envíanos los datos que aparecen para iniciar el soporte.</p>
            </div>
          </div>
        </div>

        <a href="https://download.teamviewer.com/download/TeamViewer_Setup_x64.exe" target="_blank" class="btn-primary">
          <Icon name="mdi:download"/> Descargar TeamViewer
        </a>
      </div>

      <div class="help-card reveal reveal-up stagger-5">
        <div class="help-card-inner">
          <Icon name="mdi:play-circle-outline" />
          <div>
            <p>¿Tienes problemas descargando el programa?</p>
            <a href="https://drive.google.com/file/d/17cp_besLdN9NnNC1BpB9ox5oZVscdHLS/view?usp=sharing" target="_blank">
              Ver video tutorial paso a paso
            </a>
          </div>
        </div>
      </div>

    </div>

    <div class="anydesk-visual reveal reveal-up stagger-3">
      <div class="card glow-card anydesk-card">
        <Icon name="mdi:shield-lock-outline" class="shield-icon" />
        <h3>Conexión 100% segura</h3>
        <p>Conexión cifrada y control total del proceso en tiempo real.</p>

        <div class="trust-list">
          <span><Icon name="mdi:check" /> No requiere instalación</span>
          <span><Icon name="mdi:check" /> Conexión cifrada</span>
          <span><Icon name="mdi:check" /> Soporte inmediato</span>
        </div>
      </div>
    </div>

  </div>
</section>

<script is:inline>
document.addEventListener("DOMContentLoaded", () => {

  const tabs = document.querySelectorAll(".tab");
  const panels = document.querySelectorAll(".steps-panel");

  tabs.forEach(tab => {
    tab.addEventListener("click", () => {
      tabs.forEach(t => t.classList.remove("active"));
      panels.forEach(p => p.classList.remove("active"));
      tab.classList.add("active");
      const target = document.getElementById(tab.dataset.target);
      if(target) target.classList.add("active");
    });
  });

});
</script>

<style>
.anydesk-section {
  padding: 100px 0;
  background: var(--background);
}

.anydesk-grid {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 64px;
  align-items: center;
}

.anydesk-text .badge { margin-bottom: 16px; }

.anydesk-text h2 {
  font-size: clamp(24px, 3vw, 32px);
  font-weight: 700;
  margin-bottom: 16px;
}

.anydesk-desc {
  font-size: 15px;
  line-height: 1.6;
  margin-bottom: 28px;
  color: var(--on-surface-variant);
}

.tab-bar {
  display: flex;
  gap: 8px;
  margin-bottom: 28px;
  background: var(--surface-container);
  padding: 4px;
  border-radius: 12px;
  width: fit-content;
}

.tab {
  display: flex;
  align-items: center;
  gap: 8px;
  padding: 8px 20px;
  border-radius: 8px;
  border: none;
  background: transparent;
  color: var(--on-surface-variant);
  font-size: 13px;
  font-weight: 500;
  cursor: pointer;
  transition: background 0.2s, color 0.2s;
  font-family: var(--font-family);
}
.tab:hover { background: rgba(255,255,255,0.06); }
.tab.active {
  background: var(--surface-container-high);
  color: var(--on-surface);
}
.tab svg { width: 18px; height: 18px; }

.steps-panel { display: none; }
.steps-panel.active { display: block; }

.steps-list {
  display: flex;
  flex-direction: column;
  gap: 16px;
  margin-bottom: 28px;
}

.step {
  display: flex;
  gap: 16px;
  align-items: flex-start;
}

.step-num {
  width: 32px;
  height: 32px;
  min-width: 32px;
  border-radius: 50%;
  background: rgba(245,158,11,0.15);
  color: var(--primary);
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 14px;
  font-weight: 600;
}

.step h4 {
  font-size: 15px;
  font-weight: 600;
  margin-bottom: 2px;
}
.step p {
  font-size: 13px;
  line-height: 1.5;
  color: var(--on-surface-variant);
}

.help-card {
  margin-top: 20px;
}

.help-card-inner {
  display: flex;
  align-items: center;
  gap: 14px;
  padding: 16px 20px;
  border-radius: 12px;
  background: var(--surface-container);
  border: 1px solid var(--outline-variant);
}
.help-card-inner svg {
  width: 28px;
  height: 28px;
  color: var(--tertiary);
  min-width: 28px;
}
.help-card-inner p {
  font-size: 13px;
  color: var(--on-surface-variant);
  margin-bottom: 2px;
}
.help-card-inner a {
  font-size: 13px;
  font-weight: 600;
  color: var(--primary);
  text-decoration: none;
}
.help-card-inner a:hover { text-decoration: underline; }
.help-card-inner div { min-width: 0; }

.anydesk-visual { position: relative; }

.anydesk-card {
  padding: 40px 32px;
  text-align: center;
}

.shield-icon {
  width: 56px;
  height: 56px;
  color: var(--tertiary);
  margin-bottom: 16px;
}

.anydesk-card h3 {
  font-size: 20px;
  font-weight: 600;
  margin-bottom: 8px;
}
.anydesk-card p {
  font-size: 14px;
  line-height: 1.6;
  margin-bottom: 24px;
  color: var(--on-surface-variant);
}

.trust-list {
  display: flex;
  flex-direction: column;
  gap: 8px;
}
.trust-list span {
  display: flex;
  align-items: center;
  gap: 8px;
  font-size: 13px;
  color: var(--on-surface-variant);
}
.trust-list :global(svg) { color: var(--primary); width: 12px; height: 12px; }

@media (max-width: 900px) {
  .anydesk-grid {
    grid-template-columns: 1fr;
    gap: 48px;
    text-align: center;
  }
  .tab-bar { margin: 0 auto 28px; }
  .steps-list { align-items: center; }
  .step { text-align: left; max-width: 400px; }
  .help-card-inner { text-align: left; }
}
</style>
