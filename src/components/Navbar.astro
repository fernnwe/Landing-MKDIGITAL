---
import { Icon } from "astro-icon/components";
---

<nav class="top-app-bar">
  <div class="container top-app-bar-content">
    
    <div class="logo">
      MK<span>DIGITAL</span>
    </div>

    <div class="spacer"></div>

    <div class="nav-links" id="menu">
      <a href="/#inicio">Inicio</a>
      <a href="/#servicios">Servicios</a>
      <a href="/beneficios">Beneficios</a>
      <a href="/catalogo">Catalogo</a>
      <a href="/comentarios">Comentarios</a>
      <a href="/#equipo">Equipo</a>
      <a href="/faq">FAQ</a>
      <a href="/soluciones">Soluciones</a>
      <a href="/anydesk">AnyDesk</a>
      <a href="https://wa.me/50581088124" target="_blank" class="btn-primary">
        <Icon name="mdi:whatsapp" /> WhatsApp
      </a>
    </div>

    <button class="theme-btn" id="themeToggle" onclick="toggleTheme()" aria-label="Cambiar tema">
      <svg class="icon-sun" viewBox="0 0 24 24" fill="currentColor" width="20" height="20">
        <path d="M12 7c-2.76 0-5 2.24-5 5s2.24 5 5 5 5-2.24 5-5-2.24-5-5-5zM2 13h2c.55 0 1-.45 1-1s-.45-1-1-1H2c-.55 0-1 .45-1 1s.45 1 1 1zm18 0h2c.55 0 1-.45 1-1s-.45-1-1-1h-2c-.55 0-1 .45-1 1s.45 1 1 1zM11 2v2c0 .55.45 1 1 1s1-.45 1-1V2c0-.55-.45-1-1-1s-1 .45-1 1zm0 18v2c0 .55.45 1 1 1s1-.45 1-1v-2c0-.55-.45-1-1-1s-1 .45-1 1zM5.99 4.58a.996.996 0 0 0-1.41 0 .996.996 0 0 0 0 1.41l1.06 1.06c.39.39 1.03.39 1.41 0s.39-1.03 0-1.41L5.99 4.58zm12.37 12.37a.996.996 0 0 0-1.41 0 .996.996 0 0 0 0 1.41l1.06 1.06c.39.39 1.03.39 1.41 0a.996.996 0 0 0 0-1.41l-1.06-1.06zm1.06-10.96a.996.996 0 0 0 0-1.41.996.996 0 0 0-1.41 0l-1.06 1.06c-.39.39-.39 1.03 0 1.41s1.03.39 1.41 0l1.06-1.06zM7.05 18.36a.996.996 0 0 0 0-1.41.996.996 0 0 0-1.41 0l-1.06 1.06c-.39.39-.39 1.03 0 1.41s1.03.39 1.41 0l1.06-1.06z"/>
      </svg>
      <svg class="icon-moon" viewBox="0 0 24 24" fill="currentColor" width="20" height="20">
        <path d="M12 3a9 9 0 1 0 9 9c0-.46-.04-.92-.1-1.36a5.389 5.389 0 0 1-4.4 2.26 5.403 5.403 0 0 1-3.14-9.8c-.44-.06-.9-.1-1.36-.1z"/>
      </svg>
    </button>

    <button class="menu-btn" onclick="toggleMenu()" aria-label="Menu">
      <svg viewBox="0 0 24 24" fill="currentColor" width="24" height="24">
        <path d="M3 6h18v2H3V6zm0 5h18v2H3v-2zm0 5h18v2H3v-2z"/>
      </svg>
    </button>
  </div>
</nav>

<div id="mobile-overlay" class="mobile-overlay"></div>

<div class="mobile-menu" id="mobile-menu">
  <button class="mobile-close" onclick="closeMenu()" aria-label="Close">
    <svg viewBox="0 0 24 24" fill="currentColor" width="24" height="24">
      <path d="M19 6.41L17.59 5 12 10.59 6.41 5 5 6.41 10.59 12 5 17.59 6.41 19 12 13.41 17.59 19 19 17.59 13.41 12z"/>
    </svg>
  </button>
  <div class="mobile-menu-content">
    <a href="/#inicio">Inicio</a>
    <a href="/#servicios">Servicios</a>
    <a href="/beneficios">Beneficios</a>
    <a href="/catalogo">Catalogo</a>
    <a href="/comentarios">Comentarios</a>
    <a href="/#equipo">Equipo</a>
    <a href="/faq">FAQ</a>
    <a href="/soluciones">Soluciones</a>
    <a href="/anydesk">AnyDesk</a>
    <a href="https://wa.me/50581088124" target="_blank" class="btn-primary">
      <Icon name="mdi:whatsapp" /> WhatsApp
    </a>
    <button class="theme-btn mobile-theme-btn" onclick="toggleTheme()" aria-label="Cambiar tema">
      <svg class="icon-sun" viewBox="0 0 24 24" fill="currentColor" width="20" height="20">
        <path d="M12 7c-2.76 0-5 2.24-5 5s2.24 5 5 5 5-2.24 5-5-2.24-5-5-5zM2 13h2c.55 0 1-.45 1-1s-.45-1-1-1H2c-.55 0-1 .45-1 1s.45 1 1 1zm18 0h2c.55 0 1-.45 1-1s-.45-1-1-1h-2c-.55 0-1 .45-1 1s.45 1 1 1zM11 2v2c0 .55.45 1 1 1s1-.45 1-1V2c0-.55-.45-1-1-1s-1 .45-1 1zm0 18v2c0 .55.45 1 1 1s1-.45 1-1v-2c0-.55-.45-1-1-1s-1 .45-1 1zM5.99 4.58a.996.996 0 0 0-1.41 0 .996.996 0 0 0 0 1.41l1.06 1.06c.39.39 1.03.39 1.41 0s.39-1.03 0-1.41L5.99 4.58zm12.37 12.37a.996.996 0 0 0-1.41 0 .996.996 0 0 0 0 1.41l1.06 1.06c.39.39 1.03.39 1.41 0a.996.996 0 0 0 0-1.41l-1.06-1.06zm1.06-10.96a.996.996 0 0 0 0-1.41.996.996 0 0 0-1.41 0l-1.06 1.06c-.39.39-.39 1.03 0 1.41s1.03.39 1.41 0l1.06-1.06zM7.05 18.36a.996.996 0 0 0 0-1.41.996.996 0 0 0-1.41 0l-1.06 1.06c-.39.39-.39 1.03 0 1.41s1.03.39 1.41 0l1.06-1.06z"/>
      </svg>
      <svg class="icon-moon" viewBox="0 0 24 24" fill="currentColor" width="20" height="20">
        <path d="M12 3a9 9 0 1 0 9 9c0-.46-.04-.92-.1-1.36a5.389 5.389 0 0 1-4.4 2.26 5.403 5.403 0 0 1-3.14-9.8c-.44-.06-.9-.1-1.36-.1z"/>
      </svg>
      <span class="theme-label">Modo claro</span>
    </button>
  </div>
</div>

<script is:inline>
  const mobileMenu = document.getElementById("mobile-menu");
  const overlay = document.getElementById("mobile-overlay");
  const menuBtns = document.querySelectorAll(".menu-btn");

  function toggleMenu() {
    mobileMenu.classList.toggle("open");
    overlay.classList.toggle("visible");
    document.body.classList.toggle("no-scroll");
  }

  function closeMenu() {
    mobileMenu.classList.remove("open");
    overlay.classList.remove("visible");
    document.body.classList.remove("no-scroll");
  }

  overlay.onclick = closeMenu;

  document.querySelectorAll(".mobile-menu-content a").forEach(link => {
    link.addEventListener("click", closeMenu);
  });

  function toggleTheme() {
    const isLight = document.body.classList.toggle("light");
    localStorage.setItem("mkdigital-theme", isLight ? "light" : "dark");
    document.querySelectorAll(".theme-label").forEach(el => {
      el.textContent = isLight ? "Modo oscuro" : "Modo claro";
    });
  }

  const savedTheme = localStorage.getItem("mkdigital-theme");
  if (savedTheme === "light") {
    document.body.classList.add("light");
    document.querySelectorAll(".theme-label").forEach(el => {
      el.textContent = "Modo oscuro";
    });
  }

  window.toggleMenu = toggleMenu;
  window.closeMenu = closeMenu;
  window.toggleTheme = toggleTheme;
</script>

<style>
.top-app-bar {
  position: fixed;
  top: 0;
  width: 100%;
  background: rgba(12, 14, 26, 0.85);
  backdrop-filter: blur(20px);
  -webkit-backdrop-filter: blur(20px);
  border-bottom: 1px solid rgba(129, 140, 248, 0.08);
  z-index: 999;
  padding: 0;
  height: 64px;
  display: flex;
  align-items: center;
}

.top-app-bar-content {
  display: flex;
  align-items: center;
  width: 100%;
  gap: 8px;
}

.logo {
  font-size: 22px;
  font-weight: 700;
  color: var(--on-surface);
  white-space: nowrap;
  letter-spacing: -0.02em;
}
.logo span { color: var(--primary); }

.spacer { flex: 1; }

.nav-links {
  display: flex;
  gap: 4px;
  align-items: center;
}

.nav-links a {
  text-decoration: none;
  color: var(--on-surface-variant);
  font-size: 14px;
  font-weight: 500;
  padding: 8px 12px;
  border-radius: var(--shape-full);
  transition: background 0.2s, color 0.2s;
}
.nav-links a:hover {
  background: rgba(129, 140, 248, 0.08);
  color: var(--on-surface);
}

.nav-links .btn-primary {
  padding: 8px 20px;
  font-size: 13px;
  margin-left: 8px;
}

.theme-btn {
  background: none;
  border: none;
  color: var(--on-surface-variant);
  cursor: pointer;
  width: 40px;
  height: 40px;
  display: flex;
  align-items: center;
  justify-content: center;
  border-radius: var(--shape-full);
  transition: background 0.2s, color 0.2s;
  position: relative;
}
.theme-btn:hover {
  background: rgba(129, 140, 248, 0.08);
  color: var(--on-surface);
}

.icon-sun, .icon-moon {
  position: absolute;
  transition: opacity 0.3s ease, transform 0.3s ease;
}
.light .icon-sun { opacity: 0; transform: rotate(90deg) scale(0); }
.light .icon-moon { opacity: 1; transform: rotate(0) scale(1); }
body:not(.light) .icon-sun { opacity: 1; transform: rotate(0) scale(1); }
body:not(.light) .icon-moon { opacity: 0; transform: rotate(-90deg) scale(0); }

.mobile-theme-btn {
  width: 100%;
  height: auto;
  padding: 14px 16px;
  justify-content: flex-start;
  gap: 12px;
  border-radius: var(--shape-md);
  color: var(--on-surface);
  font-size: 16px;
  font-weight: 500;
  font-family: var(--font-family);
  margin-top: 4px;
}
.mobile-theme-btn:hover { background: rgba(129, 140, 248, 0.08); }
.theme-label { font-size: 16px; font-weight: 500; }
.mobile-theme-btn .icon-sun,
.mobile-theme-btn .icon-moon { position: static; }

.menu-btn {
  display: none;
  background: none;
  border: none;
  color: var(--on-surface);
  cursor: pointer;
  padding: 8px;
  border-radius: var(--shape-full);
  transition: background 0.2s;
}
.menu-btn:hover { background: rgba(129, 140, 248, 0.08); }

.mobile-overlay {
  position: fixed;
  inset: 0;
  background: rgba(0,0,0,0.6);
  z-index: 998;
  opacity: 0;
  pointer-events: none;
  transition: opacity 0.3s ease;
}
.mobile-overlay.visible {
  opacity: 1;
  pointer-events: auto;
}

.mobile-menu {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  background: var(--surface-container-high);
  border-radius: var(--shape-xl) var(--shape-xl) 0 0;
  z-index: 1000;
  transform: translateY(100%);
  transition: transform 0.3s cubic-bezier(0.2, 0, 0, 1);
  max-height: 85vh;
  overflow-y: auto;
}
.mobile-menu.open { transform: translateY(0); }

.mobile-close {
  position: absolute;
  top: 12px;
  right: 12px;
  background: none;
  border: none;
  color: var(--on-surface-variant);
  cursor: pointer;
  padding: 8px;
  border-radius: var(--shape-full);
}

.mobile-menu-content {
  display: flex;
  flex-direction: column;
  padding: 24px;
  gap: 4px;
  padding-top: 48px;
}

.mobile-menu-content a {
  text-decoration: none;
  color: var(--on-surface);
  font-size: 16px;
  font-weight: 500;
  padding: 14px 16px;
  border-radius: var(--shape-md);
  transition: background 0.2s;
}
.mobile-menu-content a:hover {
  background: rgba(129, 140, 248, 0.08);
}

.mobile-menu-content .btn-primary {
  margin-top: 8px;
  justify-content: center;
  padding: 14px 24px;
  font-size: 15px;
}

body.no-scroll { overflow: hidden; }

.light .top-app-bar {
  background: rgba(255, 255, 255, 0.85);
  border-bottom-color: rgba(79, 70, 229, 0.08);
}

@media (max-width: 900px) {
  .nav-links { display: none; }
  .menu-btn { display: flex; }
}
</style>
