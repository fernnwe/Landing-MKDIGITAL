---
import { Icon } from "astro-icon/components";
---

<nav class="top-app-bar">
  <div class="container top-app-bar-content">
    
    <div class="logo">
      MK<span>DIGITAL</span>
    </div>

    <div class="spacer"></div>

    <div class="nav-links" id="menu">
      <a href="/#inicio">Inicio</a>
      <a href="/#servicios">Servicios</a>
      <a href="/beneficios">Beneficios</a>
      <a href="/catalogo">Catalogo</a>
      <a href="/comentarios">Comentarios</a>
      <a href="/#equipo">Equipo</a>
      <a href="/faq">FAQ</a>
      <a href="/soluciones">Soluciones</a>
      <a href="/anydesk">AnyDesk</a>
      <a href="https://wa.me/50581088124" target="_blank" class="btn-primary">
        <Icon name="mdi:whatsapp" /> WhatsApp
      </a>
    </div>

    <button class="menu-btn" onclick="toggleMenu()" aria-label="Menu">
      <svg viewBox="0 0 24 24" fill="currentColor" width="24" height="24">
        <path d="M3 6h18v2H3V6zm0 5h18v2H3v-2zm0 5h18v2H3v-2z"/>
      </svg>
    </button>
  </div>
</nav>

<div id="mobile-overlay" class="mobile-overlay"></div>

<div class="mobile-menu" id="mobile-menu">
  <button class="mobile-close" onclick="closeMenu()" aria-label="Close">
    <svg viewBox="0 0 24 24" fill="currentColor" width="24" height="24">
      <path d="M19 6.41L17.59 5 12 10.59 6.41 5 5 6.41 10.59 12 5 17.59 6.41 19 12 13.41 17.59 19 19 17.59 13.41 12z"/>
    </svg>
  </button>
  <div class="mobile-menu-content">
    <a href="/#inicio">Inicio</a>
    <a href="/#servicios">Servicios</a>
    <a href="/beneficios">Beneficios</a>
    <a href="/catalogo">Catalogo</a>
    <a href="/comentarios">Comentarios</a>
    <a href="/#equipo">Equipo</a>
    <a href="/faq">FAQ</a>
    <a href="/soluciones">Soluciones</a>
    <a href="/anydesk">AnyDesk</a>
    <a href="https://wa.me/50581088124" target="_blank" class="btn-primary">
      <Icon name="mdi:whatsapp" /> WhatsApp
    </a>
  </div>
</div>

<script is:inline>
  const mobileMenu = document.getElementById("mobile-menu");
  const overlay = document.getElementById("mobile-overlay");
  const menuBtns = document.querySelectorAll(".menu-btn");

  function toggleMenu() {
    mobileMenu.classList.toggle("open");
    overlay.classList.toggle("visible");
    document.body.classList.toggle("no-scroll");
  }

  function closeMenu() {
    mobileMenu.classList.remove("open");
    overlay.classList.remove("visible");
    document.body.classList.remove("no-scroll");
  }

  overlay.onclick = closeMenu;

  document.querySelectorAll(".mobile-menu-content a").forEach(link => {
    link.addEventListener("click", closeMenu);
  });

  window.toggleMenu = toggleMenu;
  window.closeMenu = closeMenu;
</script>

<style>
/* MD3 Top App Bar */
.top-app-bar {
  position: fixed;
  top: 0;
  width: 100%;
  background: var(--surface-container, #17191E);
  border-bottom: 1px solid rgba(255,255,255,0.06);
  z-index: 999;
  padding: 0;
  height: 64px;
  display: flex;
  align-items: center;
}

.top-app-bar-content {
  display: flex;
  align-items: center;
  width: 100%;
  gap: 8px;
}

.logo {
  font-size: 22px;
  font-weight: 600;
  color: var(--on-surface, #E2E2E6);
  white-space: nowrap;
}
.logo span { color: var(--primary); }

.spacer { flex: 1; }

/* Desktop nav links */
.nav-links {
  display: flex;
  gap: 4px;
  align-items: center;
}

.nav-links a {
  text-decoration: none;
  color: var(--on-surface-variant, #C3C7CF);
  font-size: 14px;
  font-weight: 500;
  padding: 8px 12px;
  border-radius: var(--shape-full);
  transition: background 0.2s, color 0.2s;
}
.nav-links a:hover {
  background: rgba(255,255,255,0.06);
  color: var(--on-surface);
}

.nav-links .btn-primary {
  padding: 8px 20px;
  font-size: 13px;
  border-radius: var(--shape-full);
  background: var(--primary);
  color: var(--on-primary);
  margin-left: 8px;
}
.nav-links .btn-primary:hover {
  background: color-mix(in srgb, var(--primary) 90%, white);
  box-shadow: var(--elevation-2);
}

/* Menu button (hidden on desktop) */
.menu-btn {
  display: none;
  background: none;
  border: none;
  color: var(--on-surface);
  cursor: pointer;
  padding: 8px;
  border-radius: var(--shape-full);
  transition: background 0.2s;
}
.menu-btn:hover { background: rgba(255,255,255,0.06); }

/* Mobile overlay */
.mobile-overlay {
  position: fixed;
  inset: 0;
  background: rgba(0,0,0,0.5);
  z-index: 998;
  opacity: 0;
  pointer-events: none;
  transition: opacity 0.3s ease;
}
.mobile-overlay.visible {
  opacity: 1;
  pointer-events: auto;
}

/* MD3 Bottom sheet mobile menu */
.mobile-menu {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  background: var(--surface-container-high, #1C1D22);
  border-radius: var(--shape-xl) var(--shape-xl) 0 0;
  z-index: 1000;
  transform: translateY(100%);
  transition: transform 0.3s cubic-bezier(0.2, 0, 0, 1);
  max-height: 85vh;
  overflow-y: auto;
}
.mobile-menu.open {
  transform: translateY(0);
}

.mobile-close {
  position: absolute;
  top: 12px;
  right: 12px;
  background: none;
  border: none;
  color: var(--on-surface-variant);
  cursor: pointer;
  padding: 8px;
  border-radius: var(--shape-full);
}

.mobile-menu-content {
  display: flex;
  flex-direction: column;
  padding: 24px;
  gap: 4px;
  padding-top: 48px;
}

.mobile-menu-content a {
  text-decoration: none;
  color: var(--on-surface);
  font-size: 16px;
  font-weight: 500;
  padding: 14px 16px;
  border-radius: var(--shape-md);
  transition: background 0.2s;
}
.mobile-menu-content a:hover {
  background: rgba(255,255,255,0.06);
}

.mobile-menu-content .btn-primary {
  margin-top: 8px;
  justify-content: center;
  padding: 14px 24px;
  font-size: 15px;
}

body.no-scroll { overflow: hidden; }

@media (max-width: 900px) {
  .nav-links { display: none; }
  .menu-btn { display: flex; }
}
</style>
