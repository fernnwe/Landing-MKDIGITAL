---
import { Icon } from "astro-icon/components";
---

<nav class="nav">
  <div class="container nav-content">
    
    <div class="logo">
      MK<span>DIGITAL</span>
    </div>

    <!-- BOTON HAMBURGUESA -->
    <button class="menu-btn" onclick="toggleMenu()">
      <Icon name="mdi:menu" />
    </button>

    <div class="links" id="menu">
  <a href="/#inicio">Inicio</a>
  <a href="/#servicios">Servicios</a>
  <a href="/#beneficios">Beneficios</a>
  <a href="/catalogo">Catalogo</a>
  <a href="/comentarios">Comentarios</a>
  <a href="/#equipo">Equipo</a>
  <a href="/#faq">FAQ</a>
  <a href="/soluciones">Soluciones</a>
  <a href="/anydesk">AnyDesk</a>

  <a href="https://wa.me/50581088124" target="_blank" class="btn-primary">
    <Icon name="mdi:whatsapp" /> WhatsApp
  </a>
</div>
</nav>

<script is:inline>
  const menu = document.getElementById("menu");

  function toggleMenu(){
    menu.classList.toggle("active");
  }

  document.querySelectorAll("#menu a").forEach(link=>{
    link.addEventListener("click", () => {
      menu.classList.remove("active");
    });
  });

  window.toggleMenu = toggleMenu;
</script>

<style>
/* NAVBAR */
.nav{
  position:fixed;
  top:0;
  width:100%;
  background:#000000cc;
  backdrop-filter:blur(12px);
  padding:18px 0;
  z-index:999;
  border-bottom:1px solid rgba(255,255,255,0.08);
}

.nav-content{
  display:flex;
  justify-content:space-between;
  align-items:center;
}

/* LOGO */
.logo{
  font-family:Poppins;
  font-size:26px;
  font-weight:700;
  color:white;
}
.logo span{ color:var(--primary); }

/* LINKS DESKTOP */
.links{
  display:flex;
  gap:28px;
  align-items:center;
}

.links a{
  text-decoration:none;
  color:white;
  font-weight:500;
  font-size:15px;
  opacity:.85;
  transition:.3s;
}

.links a:hover{
  opacity:1;
  color:var(--primary);
}

/* BOTON WHATSAPP */
.btn-primary{
  background:var(--primary);
  padding:10px 18px;
  border-radius:8px;
  display:flex;
  gap:8px;
  align-items:center;
  color:white !important;
  font-weight:600;
}

.btn-primary:hover{
  transform:translateY(-2px);
  box-shadow:0 6px 20px rgba(0,0,0,.3);
}

/* BOTON MENU (OCULTO EN PC) */
.menu-btn{
  display:none;
  background:none;
  border:none;
  color:white;
  font-size:30px;
  cursor:pointer;
}

/* ===== MOBILE ===== */
@media(max-width:900px){

  .menu-btn{
    display:block;
  }

  .links{
    position:absolute;
    top:80px;
    right:20px;
    flex-direction:column;
    background:#0b0b0b;
    padding:25px;
    border-radius:18px;
    gap:18px;
    display:none;
    box-shadow:0 10px 40px rgba(0,0,0,.5);
    animation:fade .3s ease;
  }

  .links.active{
    display:flex;
  }

}

/* animacion */
@keyframes fade{
  from{opacity:0; transform:translateY(-10px);}
  to{opacity:1; transform:translateY(0);}
}

/* ===== BOTON HAMBURGUESA ===== */
.menu-btn{
  display:none;
  font-size:28px;
  cursor:pointer;
}

/* ===== MOBILE MENU ===== */
@media(max-width:900px){

  .menu-btn{
    display:block;
  }

  /* contenedor links */
  .links{
    position:fixed;
    top:0;
    right:-100%;
    width:100%;
    height:100vh;
    background:#050505f2;
    backdrop-filter:blur(20px);
    flex-direction:column;
    justify-content:center;
    align-items:center;
    gap:35px;
    transition:.4s;
  }

  /* cuando se abre */
  .links.active{
    right:0;
  }

  /* links grandes estilo app */
  .links a{
    font-size:22px;
    font-weight:600;
  }

  /* botón whatsapp más grande */
  .btn-primary{
    padding:16px 28px;
    border-radius:40px;
    font-size:18px;
  }
}
</style>