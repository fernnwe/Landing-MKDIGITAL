  <div class="nav-overlay-links">
    <a href="/" class="nav-link overlay-link">Inicio</a>
    <a href="/soluciones" class="nav-link overlay-link">Soluciones</a>
    <a href="/#servicios" class="nav-link overlay-link">Servicios</a>
    <a href="/#software" class="nav-link overlay-link">Software</a>
    <a href="/contacto" class="nav-link overlay-link">Contacto</a>
