---
import { Icon } from "astro-icon/components";
---

<section id="beneficios" class="section benefits-section">
  <div class="container benefits-grid">

    <div class="benefits-image">
      <img
        src="/soporte.jpg"
        sizes="(max-width:900px) 100vw, 50vw"
        width="900"
        height="700"
        alt="Soporte remoto MKDigital"
        loading="lazy"
        decoding="async"
        class="benefits-img"
      >
    </div>

    <div class="benefits-content">

      <span class="badge">POR QUÉ ELEGIRNOS</span>

      <h2>Soporte confiable, rápido y profesional</h2>

      <p class="benefits-desc">
        Brindamos soporte remoto profesional para empresas y usuarios
        que necesitan soluciones inmediatas sin salir de casa.
      </p>

      <div class="benefits-list">

        <div class="benefit-row">
          <div class="benefit-icon">
            <Icon name="mdi:clock-fast"/>
          </div>
          <div>
            <h4>Atención inmediata</h4>
            <p>Comenzamos el soporte en minutos vía WhatsApp.</p>
          </div>
        </div>

        <div class="benefit-row">
          <div class="benefit-icon">
            <Icon name="mdi:laptop"/>
          </div>
          <div>
            <h4>Servicio 100% remoto</h4>
            <p>Sin traslados, sin perder tiempo.</p>
          </div>
        </div>

        <div class="benefit-row">
          <div class="benefit-icon">
            <Icon name="mdi:cash-multiple"/>
          </div>
          <div>
            <h4>Precios accesibles</h4>
            <p>Soluciones profesionales a precios justos.</p>
          </div>
        </div>

        <div class="benefit-row">
          <div class="benefit-icon">
            <Icon name="mdi:account-star"/>
          </div>
          <div>
            <h4>Atención personalizada</h4>
            <p>Te guiamos paso a paso durante todo el proceso.</p>
          </div>
        </div>

      </div>

      <div class="benefits-stats">
        <div><strong>+500</strong><span>Clientes felices</span></div>
        <div><strong>15 min</strong><span>Tiempo de respuesta</span></div>
        <div><strong>100%</strong><span>Remoto</span></div>
      </div>

    </div>
  </div>
</section>

<script is:inline>
const observer = new IntersectionObserver(entries => {
  entries.forEach(entry => {
    if(entry.isIntersecting){
      entry.target.classList.add("benefits-visible");
    }
  });
}, {threshold: 0.15});

observer.observe(document.querySelector(".benefits-section"));
</script>

<style>
.benefits-section {
  padding: 96px 0;
  background: var(--surface-container, #17191E);
  opacity: 0;
  transform: translateY(40px);
  transition: opacity 0.6s ease, transform 0.6s ease;
}
.benefits-visible {
  opacity: 1;
  transform: translateY(0);
}

.benefits-grid {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 64px;
  align-items: center;
}

.benefits-image {
  position: relative;
  border-radius: var(--shape-xl);
  overflow: hidden;
  box-shadow: var(--elevation-3);
}

.benefits-img {
  width: 100%;
  height: auto;
  display: block;
  border-radius: var(--shape-xl);
}

.benefits-content .badge { margin-bottom: 16px; }

.benefits-content h2 {
  font-size: clamp(24px, 3vw, 32px);
  font-weight: 700;
  margin-bottom: 12px;
}

.benefits-desc {
  font-size: 15px;
  line-height: 1.6;
  margin-bottom: 32px;
  color: var(--on-surface-variant);
  max-width: 480px;
}

.benefits-list {
  display: flex;
  flex-direction: column;
  gap: 12px;
}

.benefit-row {
  display: flex;
  gap: 16px;
  align-items: flex-start;
  padding: 16px;
  border-radius: var(--shape-md);
  background: var(--surface-container-high, #1C1D22);
  transition: background 0.2s;
}
.benefit-row:hover {
  background: var(--surface-container-highest, #212227);
}

.benefit-icon {
  width: 40px;
  height: 40px;
  min-width: 40px;
  border-radius: var(--shape-sm);
  background: var(--primary-container);
  display: flex;
  align-items: center;
  justify-content: center;
}
.benefit-icon svg {
  width: 20px;
  height: 20px;
  color: var(--primary);
}

.benefit-row h4 {
  font-size: 15px;
  font-weight: 600;
  margin-bottom: 2px;
}
.benefit-row p {
  font-size: 13px;
  color: var(--on-surface-variant);
}

.benefits-stats {
  display: flex;
  gap: 32px;
  margin-top: 28px;
}
.benefits-stats strong {
  display: block;
  font-size: 24px;
  font-weight: 700;
  color: var(--primary);
}
.benefits-stats span {
  font-size: 12px;
  color: var(--on-surface-variant);
}

@media (max-width: 900px) {
  .benefits-grid { grid-template-columns: 1fr; gap: 40px; }
  .benefits-content { text-align: center; }
  .benefits-desc { margin: 0 auto 32px; }
  .benefit-row { text-align: left; }
  .benefits-stats { justify-content: center; }
}
</style>
