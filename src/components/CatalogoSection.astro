---
const productos = [

{nombre:"Office 2024 Professional Plus", precio:"C$400", old:"C$500", off:"20%", cat:"microsoft", img:"/productos/office2024.png", badge:"top"},
{nombre:"Office 2021 Professional Plus", precio:"C$350", old:"C$450", off:"22%", cat:"microsoft", img:"/productos/office2021.png"},
{nombre:"Windows 10 Pro", precio:"Cotiza", cat:"microsoft", img:"/productos/windows10.png"},
{nombre:"Windows 11 Pro", precio:"Cotiza", cat:"microsoft", img:"/productos/windows11.png"},

{nombre:"Pack Adobe (3 Apps)", precio:"C$1,000", old:"C$1,300", off:"23%", cat:"adobe", img:"/productos/adobe.jpg", badge:"top"},
{nombre:"Pack Adobe (7 Apps)", precio:"C$2,000", old:"C$2,500", off:"20%", cat:"adobe", img:"/productos/adobe.jpg"},
{nombre:"Adobe Acrobat", precio:"C$400", old:"C$550", off:"27%", cat:"adobe", img:"/productos/acrobat.png"},

{nombre:"AutoCAD 2026", precio:"C$500", old:"C$650", off:"23%", cat:"autodesk", img:"/productos/autocad.png", badge:"top"},
{nombre:"Revit 2026", precio:"C$500", old:"C$650", off:"23%", cat:"autodesk", img:"/productos/revit.png"},

{nombre:"Avast Premium", precio:"C$800", old:"C$1,000", off:"20%", cat:"seguridad", img:"/productos/avast.png"},

{nombre:"FactuLite Android", precio:"C$3,700", old:"C$4,500", off:"18%", cat:"servicios", img:"/productos/factulite.png", badge:"own"},
{nombre:"ViperPOS Sistema Web", precio:"Consultar", cat:"servicios", img:"/productos/viperpos.png", badge:"own"},
{nombre:"Sistema Facturación Windows", precio:"C$2,000", old:"C$2,500", off:"20%", cat:"servicios", img:"/productos/facturacion.png", badge:"top"},
];
---

<section class="catalogo">
<div class="container">

<h2>Licencias Digitales</h2>
<p class="subtitle">Activación remota • Entrega inmediata • Garantía incluida</p>

<input id="search" class="search" placeholder="Buscar producto..." />

<div class="filters">
<button class="active" onclick="filtrar('all', this)">Todos</button>
<button onclick="filtrar('microsoft', this)">Microsoft</button>
<button onclick="filtrar('adobe', this)">Adobe</button>
<button onclick="filtrar('autodesk', this)">Autodesk</button>
<button onclick="filtrar('seguridad', this)">Seguridad</button>
<button onclick="filtrar('servicios', this)">Facturación</button>
</div>

<div class="grid" id="grid">
{productos.map(p => (
<div class={`card ${p.cat}`} data-name={p.nombre.toLowerCase()}>

{p.off && <div class="discount-badge">-{p.off}</div>}

<div class="img-box">
<img src={p.img} alt={p.nombre} loading="lazy"/>
</div>

<h3>{p.nombre}</h3>

<div class="price-box">
{p.old && <span class="old">{p.old}</span>}
<div class="price">{p.precio}</div>
</div>

<a href="https://wa.me/50581088124" target="_blank" class="btn">
Comprar ahora
</a>

</div>
))}
</div>

</div>
</section>

<script is:inline>
document.addEventListener("DOMContentLoaded", () => {
const cards = document.querySelectorAll(".card");
const searchInput = document.getElementById("search");
const buttons = document.querySelectorAll(".filters button");
let categoriaActual = "all";

window.filtrar = (cat, btn) => {
categoriaActual = cat;
buttons.forEach(b => b.classList.remove("active"));
btn.classList.add("active");
aplicarFiltros();
}

searchInput.addEventListener("keyup", aplicarFiltros);

function aplicarFiltros(){
const texto = searchInput.value.toLowerCase();
cards.forEach(card => {
const coincideBusqueda = card.dataset.name.includes(texto);
const coincideCategoria =
categoriaActual === "all" || card.classList.contains(categoriaActual);
card.style.display = (coincideBusqueda && coincideCategoria) ? "flex" : "none";
});
}
});
</script>

<style>
.catalogo{
padding:140px 0;
background:#0b0f14;
color:white;
}

.catalogo h2{
text-align:center;
font-size:48px;
font-weight:800;
}

.subtitle{
text-align:center;
opacity:.7;
margin-bottom:50px;
}

.search{
width:100%;
padding:18px;
border-radius:14px;
border:none;
background:#11161c;
color:white;
margin-bottom:30px;
}

.filters{
display:flex;
flex-wrap:wrap;
gap:10px;
justify-content:center;
margin-bottom:50px;
}

.filters button{
background:#11161c;
border:1px solid #1f2730;
color:#aaa;
padding:10px 18px;
border-radius:30px;
cursor:pointer;
}

.filters .active{
background:var(--primary);
color:white;
}

.grid{
display:grid;
grid-template-columns:repeat(auto-fit,minmax(260px,1fr));
gap:30px;
}

.card{
position:relative;
background:rgba(255,255,255,0.03);
border:1px solid rgba(255,255,255,0.08);
border-radius:22px;
padding:30px;
display:flex;
flex-direction:column;
align-items:center;
backdrop-filter:blur(12px);
transition:.4s;
}

.card:hover{
transform:translateY(-10px);
border-color:var(--primary);
box-shadow:0 0 40px #00e0ff22;
}

.discount-badge{
position:absolute;
top:15px;
right:15px;
background:var(--primary);
padding:6px 12px;
border-radius:30px;
font-size:12px;
font-weight:700;
}

.img-box{
height:160px;
display:flex;
align-items:center;
justify-content:center;
margin-bottom:20px;
}

.img-box img{
max-width:100%;
max-height:100%;
}

h3{
text-align:center;
margin-bottom:20px;
}

.price-box{
display:flex;
flex-direction:column;
align-items:center;
margin-bottom:20px;
}

.old{
text-decoration:line-through;
opacity:.4;
}

.price{
font-size:38px;
font-weight:900;
color:var(--primary);
}

.btn{
margin-top:auto;
width:100%;
text-align:center;
padding:14px;
border-radius:12px;
background:linear-gradient(135deg,var(--primary),#00c3ff);
color:white;
font-weight:700;
text-decoration:none;
transition:.3s;
}

.btn:hover{
transform:scale(1.05);
}
</style>