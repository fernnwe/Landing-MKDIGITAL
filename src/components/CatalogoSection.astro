---
const productos = [

{nombre:"Office 2024 Professional Plus", precio:"C$400", old:"C$500", off:"20%", cat:"microsoft", img:"/productos/office2024.png", badge:"top"},
{nombre:"Office 2021 Professional Plus", precio:"C$350", old:"C$450", off:"22%", cat:"microsoft", img:"/productos/office2021.png"},
{nombre:"Windows 10 Pro", precio:"C$470", old:"C$650", off:"20%", cat:"microsoft", img:"/productos/windows10.png"},
{nombre:"Windows 11 Pro", precio:"C$700", old:"C$920", off:"20%",  cat:"microsoft", img:"/productos/windows11.png"},

{nombre:"Pack Adobe (3 Apps)", precio:"C$1,000", old:"C$1,300", off:"23%", cat:"adobe", img:"/productos/adobe.jpg", badge:"top"},
{nombre:"Pack Adobe (7 Apps)", precio:"C$2,000", old:"C$2,500", off:"20%", cat:"adobe", img:"/productos/adobe.jpg"},
{nombre:"Adobe Acrobat", precio:"C$400", old:"C$550", off:"27%", cat:"adobe", img:"/productos/acrobat.png"},

{nombre:"AutoCAD 2026", precio:"C$500", old:"C$650", off:"23%", cat:"autodesk", img:"/productos/autocad.png", badge:"top"},
{nombre:"Revit 2026", precio:"C$500", old:"C$650", off:"23%", cat:"autodesk", img:"/productos/revit.png"},

{nombre:"Avast Premium", precio:"C$800", old:"C$1,000", off:"20%", cat:"seguridad", img:"/productos/avast.png"},

{nombre:"FactuLite Android", precio:"C$3,700", old:"C$4,500", off:"18%", cat:"servicios", img:"/productos/factulite.png", badge:"own"},
{nombre:"ViperPOS Sistema Web", precio:"C$3,000", cat:"servicios", off:"al mes", img:"/productos/viperpos.png", badge:"own"},
{nombre:"Sistema Facturación Windows", precio:"C$2,000", old:"C$2,500", off:"20%", cat:"servicios", img:"/productos/facturacion.png", badge:"top"},
];
---

<section class="catalogo-section">
<div class="container">

<div class="section-header">
  <h2>Configuración e instalación remota</h2>
  <p>Instalación • Soporte inmediato • Garantía incluida</p>
</div>

<div class="search-bar">
  <svg viewBox="0 0 24 24" fill="currentColor" width="20" height="20"><path d="M15.5 14h-.79l-.28-.27A6.471 6.471 0 0 0 16 9.5 6.5 6.5 0 1 0 9.5 16c1.61 0 3.09-.59 4.23-1.57l.27.28v.79l5 4.99L20.49 19l-4.99-5zm-6 0C7.01 14 5 11.99 5 9.5S7.01 5 9.5 5 14 7.01 14 9.5 11.99 14 9.5 14z"/></svg>
  <input id="search" placeholder="Buscar producto..." />
</div>

<div class="filter-chips" id="filterChips">
  <button class="chip active" onclick="filtrar('all', this)">Todos</button>
  <button class="chip" onclick="filtrar('microsoft', this)">Microsoft</button>
  <button class="chip" onclick="filtrar('adobe', this)">Adobe</button>
  <button class="chip" onclick="filtrar('autodesk', this)">Autodesk</button>
  <button class="chip" onclick="filtrar('seguridad', this)">Seguridad</button>
  <button class="chip" onclick="filtrar('servicios', this)">Facturación</button>
</div>

<div class="product-grid" id="grid">
{productos.map(p => (
  <div class="product-card ${p.cat}" data-name={p.nombre.toLowerCase()}>

    {p.off && <span class="discount-chip">-{p.off}</span>}
    {p.badge === "own" && <span class="own-chip">MK</span>}

    <div class="product-img">
      <img src={p.img} alt={p.nombre} loading="lazy"/>
    </div>

    <h3>{p.nombre}</h3>

    <div class="product-price">
      {p.old && <span class="old-price">{p.old}</span>}
      <span class="current-price">{p.precio}</span>
    </div>

    <a href="https://wa.me/50581088124" target="_blank" class="product-btn">
      Comprar ahora
    </a>

  </div>
))}
</div>

</div>
</section>

<script is:inline>
document.addEventListener("DOMContentLoaded", () => {
const cards = document.querySelectorAll(".product-card");
const searchInput = document.getElementById("search");
const chips = document.querySelectorAll(".filter-chips .chip");
let categoriaActual = "all";

window.filtrar = (cat, btn) => {
  categoriaActual = cat;
  chips.forEach(b => b.classList.remove("active"));
  btn.classList.add("active");
  aplicarFiltros();
}

searchInput.addEventListener("keyup", aplicarFiltros);

function aplicarFiltros(){
  const texto = searchInput.value.toLowerCase();
  cards.forEach(card => {
    const coincideBusqueda = card.dataset.name.includes(texto);
    const coincideCategoria =
      categoriaActual === "all" || card.classList.contains(categoriaActual);
    card.style.display = (coincideBusqueda && coincideCategoria) ? "flex" : "none";
  });
}
});
</script>

<style>
.catalogo-section {
  padding: 96px 0;
  background: var(--background, #0F1115);
}

.section-header {
  text-align: center;
  margin-bottom: 40px;
}
.section-header h2 {
  font-size: 28px;
  font-weight: 600;
  margin-bottom: 8px;
}
.section-header p {
  font-size: 14px;
  color: var(--on-surface-variant);
}

/* MD3 Search field */
.search-bar {
  display: flex;
  align-items: center;
  gap: 12px;
  max-width: 480px;
  margin: 0 auto 24px;
  padding: 8px 16px;
  border-radius: var(--shape-full);
  background: var(--surface-container-high, #1C1D22);
  border: 1px solid var(--outline-variant, #42474E);
  transition: border-color 0.2s;
}
.search-bar:focus-within {
  border-color: var(--primary);
}
.search-bar svg {
  color: var(--on-surface-variant);
  min-width: 20px;
}
.search-bar input {
  flex: 1;
  background: none;
  border: none;
  color: var(--on-surface);
  font-size: 14px;
  outline: none;
  font-family: var(--font-family);
}
.search-bar input::placeholder {
  color: var(--on-surface-variant);
}

/* MD3 Filter chips */
.filter-chips {
  display: flex;
  flex-wrap: wrap;
  gap: 8px;
  justify-content: center;
  margin-bottom: 40px;
}

.chip {
  display: inline-flex;
  align-items: center;
  padding: 6px 16px;
  border-radius: var(--shape-full);
  background: var(--surface-container-high, #1C1D22);
  border: 1px solid var(--outline-variant, #42474E);
  color: var(--on-surface-variant);
  font-size: 13px;
  font-weight: 500;
  cursor: pointer;
  transition: background 0.2s, border-color 0.2s, color 0.2s;
  font-family: var(--font-family);
}
.chip:hover {
  background: var(--surface-container-highest);
}
.chip.active {
  background: var(--primary);
  border-color: var(--primary);
  color: var(--on-primary);
}

/* MD3 Product grid */
.product-grid {
  display: grid;
  grid-template-columns: repeat(auto-fit, minmax(240px, 1fr));
  gap: 20px;
}

/* MD3 Elevated Card */
.product-card {
  position: relative;
  display: flex;
  flex-direction: column;
  align-items: center;
  background: var(--surface-container, #17191E);
  border-radius: var(--shape-lg);
  padding: 24px 20px;
  box-shadow: var(--elevation-1);
  transition: box-shadow 0.2s ease, transform 0.2s ease;
}
.product-card:hover {
  box-shadow: var(--elevation-3);
  transform: translateY(-2px);
}

.discount-chip {
  position: absolute;
  top: 12px;
  right: 12px;
  padding: 4px 10px;
  border-radius: var(--shape-full);
  background: var(--primary);
  color: var(--on-primary);
  font-size: 11px;
  font-weight: 600;
  letter-spacing: 0.3px;
}

.own-chip {
  position: absolute;
  top: 12px;
  left: 12px;
  padding: 4px 10px;
  border-radius: var(--shape-full);
  background: var(--tertiary-container, #1F4E5C);
  color: var(--on-tertiary-container, #C5E7F9);
  font-size: 10px;
  font-weight: 700;
  letter-spacing: 0.5px;
}

.product-img {
  height: 140px;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-bottom: 16px;
}
.product-img img {
  max-width: 100%;
  max-height: 100%;
  object-fit: contain;
}

.product-card h3 {
  font-size: 15px;
  font-weight: 600;
  text-align: center;
  margin-bottom: 16px;
  line-height: 1.3;
}

.product-price {
  display: flex;
  flex-direction: column;
  align-items: center;
  margin-bottom: 20px;
}

.old-price {
  font-size: 13px;
  color: var(--on-surface-variant);
  text-decoration: line-through;
  opacity: 0.6;
}

.current-price {
  font-size: 30px;
  font-weight: 700;
  color: var(--primary);
  line-height: 1.1;
}

.product-btn {
  width: 100%;
  text-align: center;
  padding: 12px 24px;
  border-radius: var(--shape-full);
  background: var(--primary);
  color: var(--on-primary);
  font-size: 14px;
  font-weight: 500;
  text-decoration: none;
  transition: box-shadow 0.2s ease;
  box-shadow: var(--elevation-1);
}
.product-btn:hover {
  box-shadow: var(--elevation-2);
}

@media (max-width: 600px) {
  .product-grid { grid-template-columns: 1fr 1fr; gap: 12px; }
  .product-card { padding: 16px; }
  .current-price { font-size: 24px; }
  .product-img { height: 100px; }
}
</style>
