---
import { Icon } from "astro-icon/components";
---

<section id="equipo" class="section team-section">
  <div class="container">

    <div class="section-header">
      <span class="badge">EQUIPO MKDIGITAL</span>
      <h2>Colaboradores</h2>
      <p>
        Profesionales encargados de brindar soporte remoto seguro,
        rápido y confiable a nuestros clientes.
      </p>
    </div>

    <div class="team-grid">

      <!-- CEO -->
      <div class="team-card ceo">
        <span class="team-badge">CEO</span>

        <div class="team-avatar">
          <Icon name="mdi:crown"/>
        </div>

        <h3>Ing. Fernando Aguirre</h3>
        <span class="team-role">Asesor en software y soporte técnico</span>

        <div class="team-skills">
          <span class="skill-chip">Asesor en software</span>
          <span class="skill-chip">Atención al cliente</span>
          <span class="skill-chip">Soporte técnico</span>
        </div>
      </div>

      <!-- ERNESTO -->
      <div class="team-card">
        <span class="team-badge">SOPORTE TÉCNICO</span>

        <div class="team-avatar">
          <Icon name="mdi:account-cog"/>
        </div>

        <h3>Ing. Ernesto Schwartz</h3>
        <span class="team-role">Especialista en soporte técnico</span>

        <div class="team-skills">
          <span class="skill-chip">Instalación de programas</span>
          <span class="skill-chip">Configuración</span>
          <span class="skill-chip">Optimización</span>
        </div>
      </div>

    </div>
  </div>
</section>

<script is:inline>
const teamObserver = new IntersectionObserver(entries=>{
  entries.forEach(entry=>{
    if(entry.isIntersecting){
      entry.target.classList.add("team-visible");
    }
  });
}, {threshold: 0.2});

const teamSection = document.querySelector(".team-section");
if (teamSection) teamObserver.observe(teamSection);
</script>

<style>
/* MD3 Team Section */
.team-section {
  padding: 96px 0;
  background: var(--background, #0F1115);
  opacity: 0;
  transform: translateY(40px);
  transition: opacity 0.6s ease, transform 0.6s ease;
}

.team-visible {
  opacity: 1;
  transform: translateY(0);
}

.team-grid {
  display: grid;
  grid-template-columns: repeat(auto-fit, minmax(280px, 1fr));
  gap: 24px;
  align-items: stretch;
}

.team-card {
  position: relative;
  background: var(--surface-container-high, #1C1D22);
  border-radius: var(--shape-xl);
  padding: 40px 32px;
  text-align: center;
  box-shadow: var(--elevation-1);
  transition: box-shadow 0.2s ease, transform 0.2s ease;
}
.team-card:hover {
  box-shadow: var(--elevation-3);
  transform: translateY(-2px);
}

.ceo {
  border: 1px solid var(--primary);
}

.team-badge {
  position: absolute;
  top: 16px;
  right: 16px;
  padding: 4px 10px;
  border-radius: var(--shape-full);
  background: var(--primary-container);
  color: var(--primary);
  font-size: 10px;
  font-weight: 600;
  letter-spacing: 0.5px;
}

.team-avatar {
  width: 72px;
  height: 72px;
  margin: 0 auto 16px;
  border-radius: 50%;
  background: var(--primary-container);
  display: flex;
  align-items: center;
  justify-content: center;
}
.team-avatar svg {
  width: 32px;
  height: 32px;
  color: var(--primary);
}

.team-card h3 {
  font-size: 18px;
  font-weight: 600;
  margin-bottom: 4px;
}

.team-role {
  display: block;
  font-size: 13px;
  color: var(--on-surface-variant);
  margin-bottom: 20px;
}

.team-skills {
  display: flex;
  gap: 8px;
  flex-wrap: wrap;
  justify-content: center;
}

.skill-chip {
  display: inline-block;
  padding: 4px 12px;
  border-radius: var(--shape-full);
  background: var(--surface-container, #17191E);
  border: 1px solid var(--outline-variant);
  font-size: 11px;
  font-weight: 500;
  color: var(--on-surface-variant);
}

@media (max-width: 600px) {
  .ceo { border-width: 1px; }
}
</style>
