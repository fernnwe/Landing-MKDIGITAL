---
const colaboradores = [
  { name: 'Alvaro Delgado', image: '/colaboradores/alvaro-delgado.jpg' },
  { name: 'Ernesto Schwartz', image: '/colaboradores/ernesto-schwartz.jpg' },
  { name: 'Colaborador 3', image: null },
  { name: 'Colaborador 4', image: null },
  { name: 'Colaborador 5', image: null },
];
---

<section class="section" id="colaboradores">
  <div class="container">
    <div class="section-header">
      <div class="badge reveal reveal-up">Colaboradores</div>
      <h2 class="reveal reveal-up stagger-1">Personas que confían en nosotros</h2>
    </div>
    <div class="colab-grid">
      {colaboradores.map((colab, i) => (
        <div class={`card reveal reveal-up stagger-${Math.min(i + 1, 8)}`}>
          {colab.image ? (
            <img src={colab.image} alt={colab.name} class="colab-img" />
          ) : (
            <div class="colab-placeholder">
              <svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M16 21v-2a4 4 0 00-4-4H6a4 4 0 00-4 4v2"/><circle cx="9" cy="7" r="4"/><path d="M22 21v-2a4 4 0 00-3-3.87M16 3.13a4 4 0 010 7.75"/></svg>
              <span>{colab.name}</span>
            </div>
          )}
        </div>
      ))}
    </div>
  </div>
</section>

<style>
  .colab-grid { display: grid; grid-template-columns: repeat(5, 1fr); gap: 20px; }
  .card { display: flex; align-items: center; justify-content: center; padding: 28px 20px; min-height: 100px; cursor: default; }
  .colab-placeholder { display: flex; flex-direction: column; align-items: center; gap: 8px; color: var(--on-surface-variant); opacity: 0.5; }
  .colab-placeholder span { font-size: 12px; font-weight: 500; }
  @media (max-width: 768px) { .colab-grid { grid-template-columns: repeat(3, 1fr); } }
  @media (max-width: 600px) { .colab-grid { grid-template-columns: repeat(2, 1fr); } .card { min-height: 80px; padding: 20px 16px; } }
</style>
