---
const colaboradores = [
  { name: 'Fernando Aguirre', image: '/ceo.webp', role: 'CEO & Fundador' },
  { name: 'Alvaro Delgado', image: '/colaboradores/alvaro-delgado.jpg', role: 'Colaborador' },
];
---

<section class="section" id="colaboradores">
  <div class="container">
    <div class="section-header">
      <div class="badge reveal reveal-up">Colaboradores</div>
      <h2 class="reveal reveal-up stagger-1">Personas que confían en nosotros</h2>
    </div>
    <div class="colab-grid">
      {colaboradores.map((colab, i) => (
        <div class={`card glow-card reveal reveal-up stagger-${Math.min(i + 1, 8)}`}>
          <img src={colab.image} alt={colab.name} class="colab-img" />
          <span class="colab-name">{colab.name}</span>
          <span class="colab-role">{colab.role}</span>
        </div>
      ))}
    </div>
  </div>
</section>

<style>
  .colab-grid { display: grid; grid-template-columns: repeat(2, 1fr); gap: 24px; max-width: 560px; margin: 48px auto 0; }
  .card { display: flex; flex-direction: column; align-items: center; gap: 12px; padding: 36px 24px; cursor: default; text-align: center; }
  .colab-img { width: 120px; height: 120px; border-radius: 50%; object-fit: cover; border: 3px solid var(--primary); box-shadow: 0 4px 20px rgba(245,158,11,0.15); }
  .colab-name { font-size: 18px; font-weight: 700; color: var(--on-surface); }
  .colab-role { font-size: 13px; color: var(--on-surface-variant); }
  @media (max-width: 600px) { .colab-grid { grid-template-columns: 1fr; max-width: 320px; } .colab-img { width: 100px; height: 100px; } }
</style>
