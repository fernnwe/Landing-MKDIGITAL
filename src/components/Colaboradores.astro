---
import { Icon } from "astro-icon/components";
---

<section id="equipo" class="section team">
  <div class="container">

    <div class="section-header">
      <span class="badge">EQUIPO MKDIGITAL</span>
      <h2>Colaboradores</h2>
      <p>
        Profesionales encargados de brindar soporte remoto seguro,
        rápido y confiable a nuestros clientes.
      </p>
    </div>

    <div class="team-grid">

      <!-- CEO -->
      <div class="team-card ceo">
        <span class="ceo-badge">CEO</span>

        <div class="avatar">
          <Icon name="mdi:crown"/>
        </div>

        <h3>Ing. Fernando Aguirre</h3>
        <span class="role">Asesor en software y soporte técnico</span>

        <div class="skills">
          <span>Asesor en software</span>
          <span>Atención al cliente</span>
          <span>Soporte técnico</span>
        </div>
      </div>

      <!-- ERNESTO -->
      <div class="team-card">
        <span class="ceo-badge">SOPORTE TÉCNICO</span>
        <div class="avatar">
          <Icon name="mdi:account-cog"/>
        </div>

        <h3>Ing. Ernesto Schwartz</h3>
        <span class="role">Especialista en soporte técnico</span>

        <div class="skills">
          <span>Instalación de programas</span>
          <span>Configuración</span>
          <span>Optimización</span>
        </div>
      </div>

    </div>
  </div>
</section>

<script is:inline>
/* Animación solo cuando entra en pantalla */
const teamObserver = new IntersectionObserver(entries=>{
  entries.forEach(entry=>{
    if(entry.isIntersecting){
      entry.target.classList.add("show-team");
    }
  });
},{threshold:.2});

teamObserver.observe(document.querySelector(".team"));
</script>

<style>

/* ===== ANIMACIÓN DE ENTRADA ===== */
.team{
  opacity:0;
  transform:translateY(70px);
  transition:all .9s ease;
  padding:120px 0;
}

.show-team{
  opacity:1;
  transform:translateY(0);
}

/* HEADER */
.section-header{
  text-align:center;
  max-width:650px;
  margin:0 auto 70px;
}

.badge{
  display:inline-block;
  padding:7px 18px;
  border-radius:30px;
  background:linear-gradient(90deg,#00B3C920,#1ED6E620);
  color:var(--primary);
  font-size:.75rem;
  letter-spacing:.6px;
  margin-bottom:18px;
}

/* GRID RESPONSIVE PERFECTO */
.team-grid{
  display:grid;
  grid-template-columns:repeat(auto-fit,minmax(280px,1fr));
  gap:45px;
  align-items:stretch;
}

/* CARD BASE */
.team-card{
  background:var(--glass);
  padding:45px 35px;
  border-radius:26px;
  text-align:center;
  border:1px solid var(--border);
  transition:.35s;
  position:relative;
  backdrop-filter:blur(10px);
  will-change:transform;
}

.team-card:hover{
  transform:translateY(-14px);
  border-color:var(--primary);
  box-shadow:0 20px 50px rgba(0,0,0,.2);
}

/* CEO DESTACADO */
.ceo{
  transform:scale(1.06);
  border:1px solid transparent;
  background:
    linear-gradient(#0a0a0a,#0a0a0a) padding-box,
    linear-gradient(120deg,#00B3C9,#1ED6E6) border-box;
  box-shadow:0 25px 70px rgba(0,179,201,.25);
}

.ceo:hover{
  transform:scale(1.09) translateY(-12px);
}

/* BADGE CEO */
.ceo-badge{
  position:absolute;
  top:18px;
  right:18px;
  font-size:.7rem;
  padding:6px 14px;
  border-radius:20px;
  background:linear-gradient(90deg,#00B3C9,#1ED6E6);
  color:black;
  font-weight:700;
}

/* AVATAR OPTIMIZADO */
.avatar{
  width:90px;
  height:90px;
  margin:auto auto 22px;
  border-radius:50%;
  display:flex;
  align-items:center;
  justify-content:center;
  background:linear-gradient(120deg,#00B3C9,#1ED6E6);
  box-shadow:0 10px 25px rgba(0,0,0,.25);
}

.avatar svg{
  width:42px;
  height:42px;
  color:white;
}

/* TEXTOS */
.team-card h3{
  margin-bottom:6px;
  font-size:22px;
}

.role{
  display:block;
  color:var(--muted);
  font-size:.9rem;
  margin-bottom:22px;
}

/* SKILLS */
.skills{
  display:flex;
  gap:10px;
  flex-wrap:wrap;
  justify-content:center;
}

.skills span{
  background:rgba(255,255,255,0.05);
  border:1px solid rgba(255,255,255,0.08);
  padding:6px 13px;
  border-radius:20px;
  font-size:.75rem;
  transition:.3s;
}

.skills span:hover{
  border-color:var(--primary);
}

/* MOBILE */
@media(max-width:600px){
  .ceo{ transform:none; }
}

</style>