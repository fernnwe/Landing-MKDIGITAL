---
import type { Producto } from "../data/productos";

interface Props {
  producto: Producto;
  index: number;
}

const { producto: p, index } = Astro.props;
---

<div class="product-card" data-categoria={p.categoria} data-nombre={p.nombre.toLowerCase()}>
  {p.off && (
    <span class="badge-discount">-{p.off}</span>
  )}
  {p.badge === "own" && (
    <span class="badge-own">
      <i class="fa-solid fa-star"></i>
      MK
    </span>
  )}

  <div class="card-image">
    <img src={p.img} alt={p.nombre} loading={index < 6 ? "eager" : "lazy"} decoding="async" />
    <div class="card-image-shine"></div>
  </div>

  <div class="card-body">
    <h3 class="card-title">{p.nombre}</h3>
    {p.descripcion && <p class="card-desc">{p.descripcion}</p>}

    <div class="card-pricing">
      {p.old && <span class="price-old">{p.old}</span>}
      <span class="price-current">{p.precio}</span>
    </div>

    <a href="https://wa.me/50581088124?text=Hola%2C%20quiero%20informaci%C3%B3n%20sobre%20${encodeURIComponent(p.nombre)}" target="_blank" class="card-btn">
      <i class="fa-brands fa-whatsapp"></i>
      Consultar
    </a>
  </div>
</div>

<style>
.product-card {
  position: relative;
  background: var(--surface-container-high);
  border-radius: var(--shape-lg);
  overflow: hidden;
  border: 1px solid rgba(129, 140, 248, 0.06);
  transition: transform 0.4s cubic-bezier(0.2, 0, 0, 1),
              box-shadow 0.4s cubic-bezier(0.2, 0, 0, 1),
              border-color 0.3s ease;
}
.product-card:hover {
  transform: translateY(-6px);
  box-shadow: 0 12px 40px rgba(129, 140, 248, 0.15);
  border-color: rgba(129, 140, 248, 0.2);
}

.badge-discount {
  position: absolute;
  top: 12px;
  right: 12px;
  z-index: 2;
  padding: 4px 12px;
  border-radius: var(--shape-full);
  background: linear-gradient(135deg, var(--primary), #6366F1);
  color: #FFFFFF;
  font-size: 11px;
  font-weight: 700;
  letter-spacing: 0.3px;
  box-shadow: 0 2px 8px rgba(129, 140, 248, 0.3);
}

.badge-own {
  position: absolute;
  top: 12px;
  left: 12px;
  z-index: 2;
  display: flex;
  align-items: center;
  gap: 4px;
  padding: 4px 10px;
  border-radius: var(--shape-full);
  background: linear-gradient(135deg, #22D3EE, #06B6D4);
  color: #FFFFFF;
  font-size: 10px;
  font-weight: 700;
  letter-spacing: 0.5px;
}
.badge-own i { font-size: 8px; }

.card-image {
  position: relative;
  height: 180px;
  display: flex;
  align-items: center;
  justify-content: center;
  background: var(--surface-container);
  overflow: hidden;
  padding: 24px;
}
.card-image img {
  max-width: 100%;
  max-height: 100%;
  object-fit: contain;
  transition: transform 0.5s cubic-bezier(0.2, 0, 0, 1);
  filter: drop-shadow(0 4px 8px rgba(0, 0, 0, 0.2));
}
.product-card:hover .card-image img {
  transform: scale(1.08);
}

.card-image-shine {
  position: absolute;
  inset: 0;
  background: linear-gradient(135deg, transparent 40%, rgba(255, 255, 255, 0.03) 50%, transparent 60%);
  transform: translateX(-100%);
  transition: transform 0.6s ease;
}
.product-card:hover .card-image-shine {
  transform: translateX(100%);
}

.card-body {
  padding: 20px;
  display: flex;
  flex-direction: column;
  gap: 8px;
}

.card-title {
  font-size: 15px;
  font-weight: 600;
  line-height: 1.3;
  color: var(--on-surface);
}

.card-desc {
  font-size: 12px;
  color: var(--on-surface-variant);
  line-height: 1.4;
}

.card-pricing {
  display: flex;
  align-items: baseline;
  gap: 8px;
  margin-top: 4px;
}

.price-old {
  font-size: 13px;
  color: var(--on-surface-variant);
  text-decoration: line-through;
  opacity: 0.5;
}

.price-current {
  font-size: 28px;
  font-weight: 800;
  background: linear-gradient(135deg, var(--primary), var(--secondary));
  -webkit-background-clip: text;
  -webkit-text-fill-color: transparent;
  background-clip: text;
  line-height: 1.1;
}

.card-btn {
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 8px;
  margin-top: 8px;
  padding: 12px;
  border-radius: var(--shape-full);
  background: linear-gradient(135deg, #25D366, #128C7E);
  color: #FFFFFF;
  font-size: 14px;
  font-weight: 600;
  text-decoration: none;
  transition: box-shadow 0.3s ease, transform 0.2s ease;
  box-shadow: 0 2px 12px rgba(37, 211, 102, 0.2);
}
.card-btn:hover {
  box-shadow: 0 4px 20px rgba(37, 211, 102, 0.35);
  transform: scale(1.02);
}
.card-btn i { font-size: 16px; }
</style>
