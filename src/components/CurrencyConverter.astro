---
import { Icon } from "astro-icon/components";
---

<div class="converter-card" id="converter">
  <div class="converter-toggle" onclick="toggleConverter()">
    <Icon name="mdi:arrow-left-right" />
    <span>Convertir C$ a $</span>
    <Icon name="mdi:chevron-down" id="converter-chevron" />
  </div>

  <div class="converter-body open" id="converter-body">
    <p class="converter-rate"><Icon name="mdi:information" /> 1 USD = C$37</p>

    <div class="converter-row">
      <div class="converter-field">
        <label>Córdobas (C$)</label>
        <div class="converter-input-wrapper">
          <span class="converter-currency">C$</span>
          <input type="number" id="input-cordoba" value="370" min="0" step="1" />
        </div>
      </div>
      <div class="converter-equal"><Icon name="mdi:equal" /></div>
      <div class="converter-field">
        <label>Dólares ($)</label>
        <div class="converter-input-wrapper">
          <span class="converter-currency">$</span>
          <input type="number" id="input-dolar" value="10" min="0" step="0.01" />
        </div>
      </div>
    </div>

    <div class="converter-quick">
      <button class="quick-btn" data-cordoba="100">C$100</button>
      <button class="quick-btn" data-cordoba="500">C$500</button>
      <button class="quick-btn" data-cordoba="1000">C$1,000</button>
      <button class="quick-btn" data-cordoba="2000">C$2,000</button>
    </div>
  </div>
</div>

<script is:inline>
(function() {
  var tasa = 37;
  var inputC = document.getElementById('input-cordoba');
  var inputD = document.getElementById('input-dolar');

  window.toggleConverter = function() {
    var body = document.getElementById('converter-body');
    var chevron = document.getElementById('converter-chevron');
    if (!body) return;
    var isOpen = body.classList.toggle('open');
    if (chevron) chevron.style.transform = isOpen ? 'rotate(180deg)' : '';
  };

  function updateFromC() {
    var val = parseFloat(inputC.value) || 0;
    inputD.value = (val / tasa).toFixed(2);
  }

  function updateFromD() {
    var val = parseFloat(inputD.value) || 0;
    inputC.value = Math.round(val * tasa);
  }

  if (inputC && inputD) {
    inputC.addEventListener('input', updateFromC);
    inputD.addEventListener('input', updateFromD);
    updateFromC();
  }

  document.querySelectorAll('.quick-btn').forEach(function(btn) {
    btn.addEventListener('click', function() {
      var raw = btn.dataset.cordoba;
      var val = parseInt(raw.replace(/[^0-9]/g, ''), 10);
      inputC.value = val;
      updateFromC();
    });
  });
})();
</script>

<style>
.converter-card {
  margin: 0 0 40px;
  border-radius: var(--shape-lg);
  background: var(--surface-container-high);
  border: 1px solid rgba(129, 140, 248, 0.06);
  overflow: hidden;
}

.converter-toggle {
  display: flex;
  align-items: center;
  gap: 10px;
  padding: 14px 20px;
  cursor: pointer;
  color: var(--on-surface);
  font-size: 14px;
  font-weight: 600;
  user-select: none;
  transition: background 0.2s;
}
.converter-toggle:hover { background: rgba(129, 140, 248, 0.06); }
.converter-toggle :global(svg):first-child {
  color: var(--primary);
  width: 16px;
  height: 16px;
}
.converter-toggle span { flex: 1; }
.converter-toggle :global(svg):last-child {
  transition: transform 0.3s ease;
  color: var(--on-surface-variant);
  width: 12px;
  height: 12px;
}

.converter-body {
  padding: 0 20px 20px;
  display: none;
}
.converter-body.open { display: block; }

.converter-rate {
  font-size: 12px;
  color: var(--on-surface-variant);
  margin-bottom: 16px;
  display: flex;
  align-items: center;
  gap: 6px;
}
.converter-rate :global(svg) { color: var(--primary); width: 13px; height: 13px; }

.converter-row {
  display: flex;
  align-items: flex-end;
  gap: 12px;
  margin-bottom: 16px;
}

.converter-field {
  flex: 1;
  min-width: 0;
}

.converter-field label {
  display: block;
  font-size: 11px;
  font-weight: 600;
  color: var(--on-surface-variant);
  margin-bottom: 6px;
  text-transform: uppercase;
  letter-spacing: 0.05em;
}

.converter-input-wrapper {
  display: flex;
  align-items: center;
  gap: 0;
  border-radius: var(--shape-sm);
  background: var(--surface-container);
  border: 1.5px solid var(--outline-variant);
  overflow: hidden;
  transition: border-color 0.2s, box-shadow 0.2s;
}
.converter-input-wrapper:focus-within {
  border-color: var(--primary);
  box-shadow: 0 0 16px rgba(129, 140, 248, 0.1);
}

.converter-currency {
  padding: 0 0 0 14px;
  font-size: 16px;
  font-weight: 700;
  color: var(--on-surface-variant);
}

.converter-input-wrapper input {
  flex: 1;
  background: none;
  border: none;
  color: var(--on-surface);
  font-size: 20px;
  font-weight: 700;
  padding: 12px 14px;
  outline: none;
  font-family: var(--font-family);
  min-width: 0;
}
.converter-input-wrapper input::-webkit-outer-spin-button,
.converter-input-wrapper input::-webkit-inner-spin-button {
  -webkit-appearance: none;
  margin: 0;
}
.converter-input-wrapper input[type=number] { -moz-appearance: textfield; }

.converter-equal {
  padding-bottom: 12px;
  color: var(--on-surface-variant);
  font-size: 14px;
}

.converter-quick {
  display: flex;
  flex-wrap: wrap;
  gap: 6px;
}

.quick-btn {
  padding: 6px 16px;
  border-radius: var(--shape-full);
  background: var(--surface-container);
  border: 1px solid var(--outline-variant);
  color: var(--on-surface-variant);
  font-size: 12px;
  font-weight: 500;
  cursor: pointer;
  transition: all 0.2s;
  font-family: var(--font-family);
}
.quick-btn:hover {
  border-color: var(--primary);
  color: var(--primary);
  background: rgba(129, 140, 248, 0.06);
}
</style>
