---
import { Icon } from "astro-icon/components";
---

<section class="software-logos" id="software">
  <div class="container">

    <div class="section-header">
      <h2>Software que instalamos diariamente</h2>
      <p>
        Trabajamos con los programas más utilizados por estudiantes, empresas y profesionales.
      </p>
    </div>

    <div class="logos-grid">

      <div class="logo-card windows">
        <Icon name="mdi:microsoft-windows" />
        <span>Windows</span>
      </div>

      <div class="logo-card office">
        <Icon name="mdi:microsoft-office" />
        <span>Microsoft Office</span>
      </div>

      <div class="logo-card adobe">
        <Icon name="simple-icons:adobe" />
        <span>Adobe</span>
      </div>

      <div class="logo-card corel">
         <Icon name="simple-icons:coreldraw" />
         <span>CorelDRAW</span>
      </div>

      <div class="logo-card autocad">
        <Icon name="simple-icons:autodesk" />
        <span>AutoCAD</span>
      </div>

      <div class="logo-card sketchup">
        <Icon name="simple-icons:sketchup" />
        <span>SketchUp</span>
      </div>

      <div class="logo-card revit">
        <Icon name="simple-icons:autodesk" />
        <span>Revit</span>
      </div>

      <div class="logo-card avg">
        <Icon name="mdi:shield-plus" />
        <span>AVG Antivirus</span>
      </div>

      <div class="logo-card eset">
        <Icon name="mdi:shield-star" />
        <span>ESET NOD32</span>
      </div>

      <div class="logo-card avast">
        <Icon name="simple-icons:avast" />
        <span>Avast</span>
      </div>

      <div class="logo-card kaspersky">
        <Icon name="mdi:shield-lock" />
        <span>Kaspersky</span>
      </div>

      <div class="logo-card solidworks">
        <Icon name="simple-icons:dassaultsystemes" />
        <span>SolidWorks</span>
      </div>

      <div class="logo-card visio">
        <Icon name="simple-icons:microsoft" />
        <span>Microsoft Visio</span>
      </div>

      <div class="logo-card project">
        <Icon name="simple-icons:microsoft" />
        <span>Microsoft Project</span>
      </div>

      <div class="logo-card drivers">
        <Icon name="mdi:cpu-64-bit" />
        <span>Drivers</span>
      </div>

    </div>
  </div>
</section>

<style>
/* MD3 Logo Cards */
.software-logos {
  padding: 96px 0;
  background: var(--background, #0F1115);
}

.logos-grid {
  display: grid;
  grid-template-columns: repeat(auto-fit, minmax(140px, 1fr));
  gap: 16px;
}

.logo-card {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 12px;
  padding: 28px 16px;
  border-radius: var(--shape-md);
  background: var(--surface-container, #17191E);
  box-shadow: var(--elevation-0);
  transition: box-shadow 0.2s ease, transform 0.2s ease;
  cursor: default;
}
.logo-card:hover {
  box-shadow: var(--elevation-2);
  transform: translateY(-2px);
}

.logo-card svg {
  width: 36px;
  height: 36px;
}

.logo-card span {
  font-size: 12px;
  font-weight: 500;
  color: var(--on-surface-variant);
  text-align: center;
}

.brand-colors .windows svg { color: #00A4EF; }
.brand-colors .office svg { color: #D83B01; }
.brand-colors .adobe svg { color: #FF0000; }
.brand-colors .corel svg { color: #00B388; }
.brand-colors .autocad svg { color: #E51050; }
.brand-colors .sketchup svg { color: #FF6F00; }
.brand-colors .revit svg { color: #009999; }
.brand-colors .avg svg { color: #00C853; }
.brand-colors .eset svg { color: #00ADEF; }
.brand-colors .avast svg { color: #FF7800; }
.brand-colors .kaspersky svg { color: #00A88E; }
.brand-colors .solidworks svg { color: #FF0000; }
.brand-colors .visio svg { color: #5E5E5E; }
.brand-colors .project svg { color: #217346; }

.windows svg { color: #00A4EF; }
.office svg { color: #D83B01; }
.adobe svg { color: #FF0000; }
.corel svg { color: #00B388; }
.autocad svg { color: #E51050; }
.sketchup svg { color: #FF6F00; }
.revit svg { color: #009999; }
.avg svg { color: #00C853; }
.eset svg { color: #00ADEF; }
.avast svg { color: #FF7800; }
.kaspersky svg { color: #00A88E; }
.solidworks svg { color: #FF0000; }
.visio svg { color: #5E5E5E; }
.project svg { color: #217346; }
.drivers svg { color: var(--primary); }

@media (max-width: 900px) {
  .logos-grid { grid-template-columns: repeat(3, 1fr); }
}

@media (max-width: 600px) {
  .logos-grid { grid-template-columns: repeat(2, 1fr); }
}
</style>
