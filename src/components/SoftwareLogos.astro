---
import { Icon } from "astro-icon/components";

interface SoftwareItem {
  id: string;
  nombre: string;
  icono: string;
  clase: string;
  descripcion: string;
}

const software: SoftwareItem[] = [
  { id: "windows", nombre: "Windows", icono: "mdi:microsoft-windows", clase: "windows", descripcion: "Sistema operativo para PCs de escritorio y portátiles" },
  { id: "office", nombre: "Microsoft Office", icono: "mdi:microsoft-office", clase: "office", descripcion: "Suite ofimática con Word, Excel, PowerPoint y Outlook" },
  { id: "adobe", nombre: "Adobe", icono: "simple-icons:adobe", clase: "adobe", descripcion: "Suite creativa: Photoshop, Illustrator, Premiere y más" },
  { id: "corel", nombre: "CorelDRAW", icono: "simple-icons:coreldraw", clase: "corel", descripcion: "Diseño vectorial para ilustración y diagramación" },
  { id: "autocad", nombre: "AutoCAD", icono: "simple-icons:autodesk", clase: "autocad", descripcion: "Diseño y dibujo asistido por computadora en 2D y 3D" },
  { id: "sketchup", nombre: "SketchUp", icono: "simple-icons:sketchup", clase: "sketchup", descripcion: "Modelado 3D para arquitectura, diseño e ingeniería" },
  { id: "revit", nombre: "Revit", icono: "simple-icons:autodesk", clase: "revit", descripcion: "Modelado BIM para diseño arquitectónico y construcción" },
  { id: "avg", nombre: "AVG Antivirus", icono: "mdi:shield-plus", clase: "avg", descripcion: "Protección contra virus, malware y amenazas en línea" },
  { id: "eset", nombre: "ESET NOD32", icono: "mdi:shield-star", clase: "eset", descripcion: "Antivirus ligero con protección proactiva avanzada" },
  { id: "avast", nombre: "Avast", icono: "simple-icons:avast", clase: "avast", descripcion: "Solución de seguridad con antivirus y firewall" },
  { id: "kaspersky", nombre: "Kaspersky", icono: "mdi:shield-lock", clase: "kaspersky", descripcion: "Protección integral contra ciberamenazas y ransomware" },
  { id: "solidworks", nombre: "SolidWorks", icono: "simple-icons:dassaultsystemes", clase: "solidworks", descripcion: "Diseño mecánico 3D para ingeniería y manufactura" },
  { id: "visio", nombre: "Microsoft Visio", icono: "simple-icons:microsoft", clase: "visio", descripcion: "Diagramación profesional: diagramas de flujo y organigramas" },
  { id: "project", nombre: "Microsoft Project", icono: "simple-icons:microsoft", clase: "project", descripcion: "Gestión de proyectos, planificación y seguimiento" },
  { id: "drivers", nombre: "Drivers", icono: "mdi:cpu-64-bit", clase: "drivers", descripcion: "Controladores y actualizaciones para máximo rendimiento" },
];
---

<section class="software-logos" id="software">
  <div class="container">

    <div class="section-header reveal reveal-up">
      <span class="badge">
        <i class="fa-solid fa-cube"></i>
        SOFTWARE DISPONIBLE
      </span>
      <h2>Software que instalamos diariamente</h2>
      <p>
        Trabajamos con los programas más utilizados por estudiantes, empresas y profesionales.
      </p>
    </div>

    <div class="logos-grid">
      {software.map((s, i) => (
        <div class="flip-card reveal reveal-up stagger-{Math.min(i + 1, 10)}">
          <div class="flip-card-inner">
            <div class="flip-card-front {s.clase}">
              <span class="icon-wrap">
                <Icon name={s.icono} />
              </span>
              <span class="name">{s.nombre}</span>
            </div>
            <div class="flip-card-back {s.clase}">
              <div class="back-content">
                <span class="icon-wrap">
                  <Icon name={s.icono} />
                </span>
                <p>{s.descripcion}</p>
              </div>
            </div>
          </div>
        </div>
      ))}
    </div>
  </div>
</section>

<style>
.software-logos {
  padding: 96px 0;
  background: var(--surface-container);
}

.logos-grid {
  display: grid;
  grid-template-columns: repeat(auto-fit, minmax(140px, 1fr));
  gap: 16px;
}

.flip-card {
  perspective: 800px;
  height: 130px;
}

.flip-card-inner {
  position: relative;
  width: 100%;
  height: 100%;
  transition: transform 0.5s cubic-bezier(0.2, 0, 0, 1);
  transform-style: preserve-3d;
}

.flip-card:hover .flip-card-inner {
  transform: rotateY(180deg);
}

.flip-card-front,
.flip-card-back {
  position: absolute;
  inset: 0;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  gap: 10px;
  padding: 20px 12px;
  border-radius: var(--shape-md);
  backface-visibility: hidden;
  -webkit-backface-visibility: hidden;
  overflow: hidden;
}

.flip-card-front {
  background: var(--surface-container-high);
  border: 1px solid transparent;
  transition: border-color 0.3s ease;
}
.flip-card:hover .flip-card-front {
  border-color: rgba(129, 140, 248, 0.15);
}

.flip-card-back {
  transform: rotateY(180deg);
  background: var(--surface-container);
  border: 1px solid rgba(129, 140, 248, 0.12);
}

.back-content {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 8px;
  text-align: center;
}

.back-content p {
  font-size: 11px;
  line-height: 1.4;
  color: var(--on-surface-variant);
}

.flip-card-front .name {
  font-size: 12px;
  font-weight: 500;
  color: var(--on-surface-variant);
  text-align: center;
}

/* Icon wrapper - size via font-size, color inherits to SVG */
.flip-card-front .icon-wrap {
  display: flex;
  font-size: 32px;
  line-height: 1;
}

.flip-card-back .icon-wrap {
  display: flex;
  font-size: 22px;
  line-height: 1;
  opacity: 0.8;
}

/* Brand colors on the wrapper (works across Astro scoped boundaries) */
.windows .icon-wrap { color: #00A4EF; }
.office .icon-wrap { color: #D83B01; }
.adobe .icon-wrap { color: #FF0000; }
.corel .icon-wrap { color: #00B388; }
.autocad .icon-wrap { color: #E51050; }
.sketchup .icon-wrap { color: #FF6F00; }
.revit .icon-wrap { color: #009999; }
.avg .icon-wrap { color: #00C853; }
.eset .icon-wrap { color: #00ADEF; }
.avast .icon-wrap { color: #FF7800; }
.kaspersky .icon-wrap { color: #00A88E; }
.solidworks .icon-wrap { color: #FF0000; }
.visio .icon-wrap { color: #5E5E5E; }
.project .icon-wrap { color: #217346; }
.drivers .icon-wrap { color: var(--primary); }

@media (max-width: 900px) {
  .logos-grid { grid-template-columns: repeat(3, 1fr); }
}
@media (max-width: 600px) {
  .logos-grid { grid-template-columns: repeat(2, 1fr); }
  .flip-card { height: 120px; }
}
</style>
