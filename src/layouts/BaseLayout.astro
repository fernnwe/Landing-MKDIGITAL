---
import "../styles/global.css";
---

<html lang="es">
  <head>
    <!-- BASIC SEO -->
    <meta charset="UTF-8" />
    <title>Soporte técnico remoto en Nicaragua | MK Digital</title>
    <meta name="viewport" content="width=device-width, initial-scale=1" />

    <!-- DESCRIPCIÓN (MUY IMPORTANTE) -->
